#!/usr/bin/env python3
"""Small tmux controller for driving external Agent CLIs."""

import argparse
import base64
import contextlib
import fcntl
import hashlib
import json
import math
import os
from pathlib import Path
import re
import secrets
import shlex
import shutil
import stat
import string
import subprocess
import sys
import tempfile
import time
from typing import Any, Iterator, NoReturn, Sequence
import unicodedata
import uuid


VERSION = "0.3.0"
MIN_PYTHON = (3, 10)
MIN_TMUX = (3, 2)
TMUX_COMMAND_TIMEOUT = 15.0
LOCK_ACQUIRE_TIMEOUT = 15.0
POST_ACTION_TIMEOUT = 1.0
POST_ACTION_INTERVAL = 0.1
INPUT_SETTLE_SECONDS = 0.05
LAUNCH_POLL_INTERVAL = 0.1
LAUNCH_STABLE_INTERVAL = 0.25
TOP_LEVEL_FIELDS = (
    "ok",
    "event",
    "stage",
    "target",
    "screen",
    "error",
    "recovery",
)
ROUTE_PREFIX = "with-agents:tmux?"
ROUTE_SCHEME_PREFIX = "with-agents:"
ROUTE_FIELDS = ("name", "pane_id", "socket", "params")
PRESET_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")
PANE_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")
GENERATED_SUFFIX_RE = re.compile(r"^[A-Za-z0-9]{1,6}$")
PANE_PREFIX_RE = re.compile(r"^[A-Za-z0-9]{2}$")
AGENT_TYPE_RE = re.compile(r"^[a-z0-9]+(?:[._-][a-z0-9]+)*$")
TMUX_PANE_RE = re.compile(r"^%[0-9]+$")
TMUX_LOCATION_RE = re.compile(r"^[^:\s]+:[0-9]+\.[0-9]+$")
SECRET_FLAG_RE = re.compile(
    r"(?i)(api[-_]?key|access[-_]?token|auth[-_]?token|client[-_]?secret|password|credential)"
)
PARAM_SAFE_BYTES = frozenset(
    b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~"
)
LINE_BREAK_CATEGORIES = frozenset(("Cc", "Zl", "Zp"))
TMUX_VIS_ESCAPES = {
    "\\": "\\",
    "a": "\a",
    "b": "\b",
    "e": "\x1b",
    "f": "\f",
    "n": "\n",
    "r": "\r",
    "s": " ",
    "t": "\t",
    "v": "\v",
}

BUILTIN_AGENT_DEFINITIONS: dict[str, dict[str, Any]] = {
    "codex": {"pane_prefix": "cx"},
    "claude": {"pane_prefix": "cc"},
    "pi": {"pane_prefix": "pi"},
}
RESERVED_AGENT_TYPES = frozenset(("external", "generic"))


class WAError(Exception):
    """Stable CLI failure with enough context for safe recovery."""

    def __init__(
        self,
        code: str,
        message: str,
        *,
        stage: str = "failed",
        recovery: str | None = None,
        target: dict[str, Any] | None = None,
        screen: dict[str, Any] | None = None,
        details: dict[str, Any] | None = None,
    ) -> None:
        super().__init__(message)
        self.code = code
        self.message = message
        self.stage = stage
        self.recovery = recovery
        self.target = target
        self.screen = screen
        self.details = details or {}


class WAArgumentParser(argparse.ArgumentParser):
    def error(self, message: str) -> NoReturn:
        raise WAError(
            "usage_error",
            message,
            stage="parse",
            recovery=f"Run {self.prog} --help.",
        )


def canonical_json_bytes(value: Any) -> bytes:
    return (
        json.dumps(value, ensure_ascii=False, sort_keys=True, indent=2) + "\n"
    ).encode("utf-8")


def new_envelope(
    event: str,
    stage: str,
    *,
    ok: bool = True,
    target: dict[str, Any] | None = None,
    screen: dict[str, Any] | None = None,
    error: dict[str, Any] | None = None,
    recovery: str | None = None,
) -> dict[str, Any]:
    envelope = {
        "ok": ok,
        "event": event,
        "stage": stage,
        "target": target,
        "screen": screen,
        "error": error,
        "recovery": recovery,
    }
    if tuple(envelope) != TOP_LEVEL_FIELDS:
        raise RuntimeError("internal JSON envelope field order changed")
    return envelope


def error_envelope(event: str, exc: WAError) -> dict[str, Any]:
    error: dict[str, Any] = {"code": exc.code, "message": exc.message}
    if exc.details:
        error["details"] = exc.details
    return new_envelope(
        event,
        exc.stage,
        ok=False,
        target=exc.target,
        screen=exc.screen,
        error=error,
        recovery=exc.recovery,
    )


def render_text(envelope: dict[str, Any]) -> str:
    target = envelope.get("target") or {}
    if envelope["ok"] and envelope["event"] == "route" and target.get("route"):
        return f"{target['route']}\n"
    if envelope["ok"] and envelope["event"] == "send":
        screen = envelope.get("screen") or {}
        tail = screen.get("tail")
        return "" if tail is None else str(tail).rstrip("\n") + "\n"

    lines = [f"{envelope['event']}: {envelope['stage']}"]
    if target.get("kind") == "pane":
        label = target.get("name") or target.get("pane_id")
        lines.append(
            f"target={label} pane={target.get('pane_id')} "
            f"at={target.get('session_window_pane')}"
        )
        launch = target.get("launch") or {}
        observation = launch.get("observation") or {}
        if observation:
            stable = observation.get("stable")
            rendered_stable = "unknown" if stable is None else str(bool(stable)).lower()
            lines.append(
                "launch_observation="
                f"waited:{str(bool(observation.get('waited'))).lower()} "
                f"material_change:{str(bool(observation.get('material_change'))).lower()} "
                f"stable:{rendered_stable}"
            )
        post_action = target.get("post_action") or {}
        if post_action:
            lines.append(
                "post_action="
                + ("changed" if post_action.get("changed") else "unchanged")
            )
    elif target.get("kind") == "pane-list":
        detail = bool(target.get("detail"))
        header = ["PANE", "LOCATION", "NAME", "PROCESS", "CWD", "ROUTE"]
        if detail:
            header.extend(["SOCKET", "SERVER_PID", "PANE_PID", "DEAD"])
        lines.append("\t".join(header))
        for item in target.get("items", []):
            row = [
                str(item.get("pane_id") or ""),
                str(item.get("session_window_pane") or ""),
                str(item.get("name") or "-"),
                str(item.get("process") or "-"),
                str(item.get("cwd") or ""),
                str(item.get("route") or ""),
            ]
            if detail:
                row.extend(
                    [
                        str(item.get("socket_path") or ""),
                        str(item.get("server_pid") or ""),
                        str(item.get("pane_pid") or ""),
                        str(bool(item.get("dead"))).lower(),
                    ]
                )
            lines.append("\t".join(row))
    elif target.get("kind") == "preset":
        lines.append(f"preset={target.get('name')} path={target.get('path')}")
        if target.get("argv"):
            lines.append(f"argv={shlex.join(target['argv'])}")
        if target.get("digest"):
            lines.append(f"sha256={target['digest']}")
    elif target.get("kind") == "preset-list":
        for item in target.get("items", []):
            lines.append(f"{item['name']}\t{item['path']}")
    elif target:
        for key, value in target.items():
            if key != "kind":
                lines.append(
                    f"{key}={json.dumps(value, ensure_ascii=False, sort_keys=True)}"
                )

    error = envelope.get("error") or {}
    if error:
        lines.append(f"error={error.get('code')}: {error.get('message')}")
        if error.get("details"):
            lines.append(
                "details="
                + json.dumps(error["details"], ensure_ascii=False, sort_keys=True)
            )
    if envelope.get("recovery"):
        lines.append(f"recovery={envelope['recovery']}")
    screen = envelope.get("screen") or {}
    if screen.get("tail") is not None:
        lines.append("--- screen ---")
        lines.append(screen["tail"])
    return "\n".join(lines).rstrip() + "\n"


def emit(envelope: dict[str, Any], as_json: bool) -> None:
    output = (
        json.dumps(envelope, ensure_ascii=False, sort_keys=False, indent=2) + "\n"
        if as_json
        else render_text(envelope)
    )
    (sys.stdout if envelope["ok"] else sys.stderr).write(output)


def validate_existing_private_dir(path: Path) -> bool:
    try:
        info = path.lstat()
    except FileNotFoundError:
        return False
    except OSError as exc:
        raise WAError(
            "unsafe_state_path",
            f"cannot inspect private directory {path}: {exc}",
        ) from exc
    try:
        if stat.S_ISLNK(info.st_mode):
            raise WAError(
                "unsafe_state_path", f"private directory is a symlink: {path}"
            )
        if not stat.S_ISDIR(info.st_mode) or info.st_uid != os.getuid():
            raise WAError(
                "unsafe_state_path",
                f"private path is not a current-user-owned directory: {path}",
            )
        if stat.S_IMODE(info.st_mode) != 0o700:
            path.chmod(0o700)
    except OSError as exc:
        raise WAError(
            "unsafe_state_path",
            f"cannot use private directory {path}: {exc}",
        ) from exc
    return True


def ensure_private_dir(path: Path) -> Path:
    if validate_existing_private_dir(path):
        return path
    try:
        path.mkdir(mode=0o700, parents=True, exist_ok=True)
    except OSError as exc:
        raise WAError(
            "unsafe_state_path",
            f"cannot create private directory {path}: {exc}",
        ) from exc
    if not validate_existing_private_dir(path):
        raise WAError(
            "unsafe_state_path",
            f"private directory disappeared during creation: {path}",
        )
    return path


def safe_read_json(path: Path) -> dict[str, Any]:
    try:
        info = path.lstat()
    except FileNotFoundError as exc:
        raise WAError("state_not_found", f"state file does not exist: {path}") from exc
    if not stat.S_ISREG(info.st_mode) or stat.S_ISLNK(info.st_mode):
        raise WAError("unsafe_state_path", f"state file is not regular: {path}")
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise WAError("invalid_state", f"cannot read JSON state {path}: {exc}") from exc
    if not isinstance(value, dict):
        raise WAError("invalid_state", f"JSON state is not an object: {path}")
    return value


def atomic_write_json(
    path: Path, value: dict[str, Any], *, exclusive: bool = False
) -> None:
    ensure_private_dir(path.parent)
    data = canonical_json_bytes(value)
    descriptor, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary_path = Path(temporary)
    try:
        with os.fdopen(descriptor, "wb") as handle:
            os.fchmod(handle.fileno(), 0o600)
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
        if exclusive:
            try:
                os.link(temporary_path, path, follow_symlinks=False)
            except FileExistsError as exc:
                raise WAError(
                    "state_exists", f"refusing to overwrite existing state: {path}"
                ) from exc
        else:
            os.replace(temporary_path, path)
    finally:
        with contextlib.suppress(FileNotFoundError):
            temporary_path.unlink()


def xdg_directory(name: str, fallback: Path | None) -> Path | None:
    raw = os.environ.get(name)
    if raw:
        candidate = Path(raw).expanduser()
        if candidate.is_absolute():
            return candidate
    return fallback


class RuntimeState:
    def __init__(self, override: str | None = None) -> None:
        if override:
            self.root = Path(override).expanduser().absolute()
            self.source = "override"
        elif os.environ.get("WITH_AGENTS_RUNTIME_DIR"):
            self.root = (
                Path(os.environ["WITH_AGENTS_RUNTIME_DIR"]).expanduser().absolute()
            )
            self.source = "environment"
        elif runtime_home := xdg_directory("XDG_RUNTIME_DIR", None):
            self.root = runtime_home / "with-agents"
            self.source = "xdg-runtime"
        else:
            state_home = xdg_directory(
                "XDG_STATE_HOME", Path.home() / ".local" / "state"
            )
            assert state_home is not None
            self.root = state_home / "with-agents"
            self.source = "xdg-state-fallback"

    def ensure_root(self) -> Path:
        return ensure_private_dir(self.root)

    @property
    def locks(self) -> Path:
        return ensure_private_dir(self.ensure_root() / "locks")


class ConfigState:
    def __init__(self, override: str | None = None) -> None:
        if override:
            self.root = Path(override).expanduser().absolute()
        elif os.environ.get("WITH_AGENTS_CONFIG_DIR"):
            self.root = (
                Path(os.environ["WITH_AGENTS_CONFIG_DIR"]).expanduser().absolute()
            )
        else:
            config_home = xdg_directory("XDG_CONFIG_HOME", Path.home() / ".config")
            assert config_home is not None
            self.root = config_home / "with-agents"

    @property
    def agent_config(self) -> Path:
        return self.root / "config.json"

    @property
    def presets(self) -> Path:
        path = self.root / "presets"
        if validate_existing_private_dir(self.root):
            validate_existing_private_dir(path)
        return path

    def validate_existing_presets(self) -> Path:
        return self.presets

    def ensure_presets(self) -> Path:
        return ensure_private_dir(ensure_private_dir(self.root) / "presets")


def invalid_agent_config(path: Path, message: str) -> WAError:
    return WAError(
        "invalid_agent_config",
        f"invalid Agent configuration {path}: {message}",
        stage="preflight",
        recovery="Fix or atomically replace config.json, then run with-agents doctor.",
        details={"path": str(path)},
    )


def validate_agent_type(value: Any, *, path: Path) -> str:
    if not isinstance(value, str) or AGENT_TYPE_RE.fullmatch(value) is None:
        raise invalid_agent_config(path, f"invalid agent type: {value!r}")
    if value in RESERVED_AGENT_TYPES:
        raise invalid_agent_config(path, f"reserved agent type: {value}")
    return value


def builtin_agent_registry() -> dict[str, dict[str, Any]]:
    return {
        agent_type: {"pane_prefix": definition["pane_prefix"]}
        for agent_type, definition in BUILTIN_AGENT_DEFINITIONS.items()
    }


def validate_agent_registry(
    registry: dict[str, dict[str, Any]], *, path: Path
) -> dict[str, dict[str, Any]]:
    normalized: dict[str, dict[str, Any]] = {}
    for raw_agent_type, raw_definition in registry.items():
        agent_type = validate_agent_type(raw_agent_type, path=path)
        if not isinstance(raw_definition, dict) or set(raw_definition) != {
            "pane_prefix"
        }:
            raise invalid_agent_config(
                path,
                f"agents.{agent_type} fields must be exactly pane_prefix",
            )
        prefix = raw_definition.get("pane_prefix")
        if not isinstance(prefix, str) or PANE_PREFIX_RE.fullmatch(prefix) is None:
            raise invalid_agent_config(
                path,
                f"agents.{agent_type}.pane_prefix must be exactly two ASCII alphanumeric characters",
            )
        normalized[agent_type] = {"pane_prefix": prefix}
    return normalized


def load_agent_registry(config: ConfigState) -> dict[str, dict[str, Any]]:
    path = config.agent_config
    try:
        root_exists = validate_existing_private_dir(config.root)
    except WAError as exc:
        raise invalid_agent_config(path, exc.message) from exc
    if not root_exists:
        return validate_agent_registry(builtin_agent_registry(), path=path)
    if not path.exists() and not path.is_symlink():
        return validate_agent_registry(builtin_agent_registry(), path=path)
    try:
        value = safe_read_json(path)
    except WAError as exc:
        raise invalid_agent_config(path, exc.message) from exc
    if set(value) != {"version", "agents"}:
        raise invalid_agent_config(
            path, "top-level fields must be exactly version and agents"
        )
    if value.get("version") != 1 or isinstance(value.get("version"), bool):
        raise invalid_agent_config(path, "unsupported version")
    overrides = value.get("agents")
    if not isinstance(overrides, dict):
        raise invalid_agent_config(path, "agents must be an object")
    registry = builtin_agent_registry()
    for raw_agent_type, raw_override in overrides.items():
        agent_type = validate_agent_type(raw_agent_type, path=path)
        if not isinstance(raw_override, dict):
            raise invalid_agent_config(path, f"agents.{agent_type} must be an object")
        unknown = set(raw_override) - {"pane_prefix"}
        if unknown:
            raise invalid_agent_config(
                path,
                f"agents.{agent_type} has unknown fields: {', '.join(sorted(unknown))}",
            )
        if agent_type not in registry and set(raw_override) != {"pane_prefix"}:
            raise invalid_agent_config(
                path,
                f"new agent {agent_type!r} requires pane_prefix",
            )
        merged = dict(registry.get(agent_type, {}))
        merged.update(raw_override)
        registry[agent_type] = merged
    return validate_agent_registry(registry, path=path)


def canonical_socket_path(value: str) -> str:
    if "\x00" in value:
        raise WAError(
            "route_invalid",
            "route socket contains a NUL byte",
            stage="route_parse",
        )
    path = Path(value)
    if not path.is_absolute():
        raise WAError(
            "route_invalid",
            "route socket must be an absolute path",
            stage="route_parse",
        )
    return os.path.realpath(os.fspath(path))


def parse_tmux_environment(value: str) -> tuple[str, int, int]:
    fields = value.rsplit(",", 2)
    if (
        len(fields) != 3
        or not fields[0]
        or "\x00" in fields[0]
        or not fields[1].isdigit()
        or not fields[1].isascii()
        or not fields[2].isdigit()
        or not fields[2].isascii()
        or not Path(fields[0]).is_absolute()
    ):
        raise WAError(
            "caller_identity_unavailable",
            "TMUX must end with numeric server PID and session index fields",
            stage="caller_identity",
        )
    return fields[0], int(fields[1]), int(fields[2])


def decode_tmux_vis(value: str) -> str:
    result: list[str] = []
    index = 0
    while index < len(value):
        character = value[index]
        if character != "\\":
            result.append(character)
            index += 1
            continue
        if index + 1 >= len(value):
            raise WAError(
                "tmux_output_invalid",
                "tmux returned an incomplete vis escape",
                stage="resolve_target",
            )
        escaped = value[index + 1]
        if escaped in TMUX_VIS_ESCAPES:
            result.append(TMUX_VIS_ESCAPES[escaped])
            index += 2
            continue
        octal = value[index + 1 : index + 4]
        if len(octal) == 3 and all(digit in "01234567" for digit in octal):
            result.append(chr(int(octal, 8)))
            index += 4
            continue
        raise WAError(
            "tmux_output_invalid",
            "tmux returned an unknown vis escape",
            stage="resolve_target",
        )
    return "".join(result)


class TmuxClient:
    PANE_FORMAT = "\t".join(
        [
            "#{socket_path}",
            "#{pid}",
            "#{pane_id}",
            "#{pane_pid}",
            "#{pane_dead}",
            "#{pane_dead_status}",
            "#{window_name}",
            "#{session_name}",
            "#{window_index}",
            "#{pane_index}",
            "#{pane_current_command}",
            "#{pane_current_path}",
            "#{pane_title}",
        ]
    )

    def __init__(self, explicit_socket: str | None = None) -> None:
        self.inherits_caller = False
        if explicit_socket:
            self.socket_hint = os.path.realpath(explicit_socket)
        elif os.environ.get("TMUX"):
            socket_path, _, _ = parse_tmux_environment(os.environ["TMUX"])
            self.socket_hint = os.path.realpath(socket_path)
            self.inherits_caller = True
        else:
            self.socket_hint = None
        self._server: dict[str, Any] | None = None

    @property
    def prefix(self) -> list[str]:
        command = ["tmux"]
        if self.socket_hint:
            command.extend(["-S", self.socket_hint])
        return command

    def run(
        self,
        arguments: Sequence[str],
        *,
        input_text: str | None = None,
        stage: str = "tmux",
        check: bool = True,
    ) -> subprocess.CompletedProcess[str]:
        try:
            completed = subprocess.run(
                [*self.prefix, *arguments],
                input=input_text,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=TMUX_COMMAND_TIMEOUT,
                check=False,
            )
        except FileNotFoundError as exc:
            raise WAError(
                "tmux_unavailable",
                "tmux is not installed or is not on PATH",
                stage=stage,
                recovery="Install tmux or read references/tmux-recovery.md.",
            ) from exc
        except subprocess.TimeoutExpired as exc:
            raise WAError(
                "tmux_timeout",
                f"tmux did not respond within {TMUX_COMMAND_TIMEOUT:g} seconds",
                stage=stage,
                recovery="Inspect the target before retrying a possibly partial action.",
                details={"tmux_args": list(arguments)},
            ) from exc
        if check and completed.returncode != 0:
            raise WAError(
                "tmux_command_failed",
                completed.stderr.strip() or "tmux command failed",
                stage=stage,
                recovery="Run with-agents doctor, then inspect the target.",
                details={
                    "tmux_args": list(arguments),
                    "returncode": completed.returncode,
                },
            )
        return completed

    def server(self) -> dict[str, Any]:
        if self._server is None:
            output = self.run(
                ["display-message", "-p", "#{socket_path}\t#{pid}"],
                stage="server_identity",
            ).stdout.rstrip("\n")
            socket_path, _, raw_pid = output.partition("\t")
            self._server = {
                "socket_path": canonical_socket_path(
                    socket_path or self.socket_hint or ""
                ),
                "server_pid": int(raw_pid) if raw_pid.isdigit() else None,
            }
        return dict(self._server)

    def parse_pane(self, line: str) -> dict[str, Any]:
        fields = line.rstrip("\n").split("\t")
        if len(fields) < 13:
            fields.extend([""] * (13 - len(fields)))
        (
            socket_path,
            server_pid,
            pane_id,
            pane_pid,
            dead,
            dead_status,
            name,
            session,
            window_index,
            pane_index,
            process,
            cwd,
            title,
        ) = fields[:13]
        return {
            "kind": "pane",
            "socket_path": canonical_socket_path(
                socket_path or self.socket_hint or ""
            ),
            "server_pid": int(server_pid) if server_pid.isdigit() else None,
            "pane_id": pane_id,
            "pane_pid": int(pane_pid) if pane_pid.isdigit() else None,
            "session": session,
            "window_index": window_index,
            "pane_index": pane_index,
            "session_window_pane": f"{session}:{window_index}.{pane_index}",
            "process": process,
            "cwd": cwd,
            "dead": dead == "1",
            "dead_status": (
                int(dead_status) if dead_status.lstrip("-").isdigit() else None
            ),
            "name": decode_tmux_vis(name),
            "title": title or None,
        }

    def list_panes(self) -> list[dict[str, Any]]:
        completed = self.run(["list-panes", "-a", "-F", self.PANE_FORMAT], stage="list")
        return [self.parse_pane(line) for line in completed.stdout.split("\n") if line]

    def pane(self, target: str) -> dict[str, Any]:
        completed = self.run(
            ["display-message", "-p", "-t", target, self.PANE_FORMAT],
            stage="resolve_target",
            check=False,
        )
        if completed.returncode != 0 or not completed.stdout.strip():
            raise WAError(
                "target_not_found",
                f"cannot resolve pane target: {target}",
                stage="resolve_target",
                recovery="Run with-agents list and choose an exact target.",
            )
        pane = self.parse_pane(completed.stdout)
        mismatched_native_target = (
            TMUX_PANE_RE.fullmatch(target) is not None
            and pane.get("pane_id") != target
        ) or (
            TMUX_LOCATION_RE.fullmatch(target) is not None
            and pane.get("session_window_pane") != target
        )
        if (
            mismatched_native_target
            or TMUX_PANE_RE.fullmatch(str(pane.get("pane_id") or "")) is None
            or not isinstance(pane.get("pane_pid"), int)
        ):
            raise WAError(
                "target_not_found",
                f"cannot resolve pane target: {target}",
                stage="resolve_target",
                recovery="Run with-agents list and choose an exact target.",
            )
        return pane

    def capture(self, pane_id: str, lines: int = 80) -> str:
        completed = self.run(
            ["capture-pane", "-p", "-J", "-t", pane_id, "-S", f"-{lines}"],
            stage="capture",
        )
        return completed.stdout.rstrip("\n")

    def list_sessions(self) -> list[str]:
        completed = self.run(
            ["list-sessions", "-F", "#{session_name}"],
            stage="list_sessions",
            check=False,
        )
        if completed.returncode != 0:
            return []
        return [line for line in completed.stdout.split("\n") if line]


def address_of(pane: dict[str, Any]) -> dict[str, Any]:
    return {
        "socket_path": pane.get("socket_path"),
        "pane_id": pane.get("pane_id"),
    }


def decimal_pane_id(pane_id: Any) -> str:
    if not isinstance(pane_id, str) or TMUX_PANE_RE.fullmatch(pane_id) is None:
        raise WAError("route_invalid", "pane ID is not a tmux %pane-id")
    return str(int(pane_id[1:]))


def is_line_safe(value: str) -> bool:
    return all(
        unicodedata.category(character) not in LINE_BREAK_CATEGORIES
        for character in value
    )


def route_name(pane: dict[str, Any]) -> str:
    value = pane.get("name")
    if not isinstance(value, str) or not value or not is_line_safe(value):
        return f"pane-{decimal_pane_id(pane.get('pane_id'))}"
    return value


def escape_route_value(value: str) -> str:
    if not is_line_safe(value):
        raise WAError(
            "route_invalid",
            "route fields must be single-line text without control characters",
            stage="route_parse",
        )
    return value.replace("\\", "\\\\").replace("&", "\\&").replace("]", "\\]")


def unescape_route_value(value: str) -> str:
    result: list[str] = []
    index = 0
    while index < len(value):
        character = value[index]
        if character != "\\":
            result.append(character)
            index += 1
            continue
        if index + 1 >= len(value) or value[index + 1] not in "\\&]":
            raise WAError(
                "route_invalid",
                "route contains an unknown backslash escape",
                stage="route_parse",
            )
        result.append(value[index + 1])
        index += 2
    decoded = "".join(result)
    if not is_line_safe(decoded):
        raise WAError(
            "route_invalid",
            "route fields must be single-line text without control characters",
            stage="route_parse",
        )
    return decoded


def encode_param_component(value: str) -> str:
    return "".join(
        chr(byte) if byte in PARAM_SAFE_BYTES else f"%{byte:02X}"
        for byte in value.encode("utf-8")
    )


def decode_param_component(value: str) -> str:
    decoded = bytearray()
    index = 0
    while index < len(value):
        character = value[index]
        if character == "%":
            if index + 2 >= len(value):
                raise WAError(
                    "route_invalid",
                    "params contains an incomplete percent escape",
                    stage="route_parse",
                )
            try:
                decoded.append(int(value[index + 1 : index + 3], 16))
            except ValueError as exc:
                raise WAError(
                    "route_invalid",
                    "params contains an invalid percent escape",
                    stage="route_parse",
                ) from exc
            index += 3
            continue
        codepoint = ord(character)
        if codepoint >= 128 or codepoint not in PARAM_SAFE_BYTES:
            raise WAError(
                "route_invalid",
                "params contains an unescaped field byte",
                stage="route_parse",
            )
        decoded.append(codepoint)
        index += 1
    try:
        return decoded.decode("utf-8")
    except UnicodeDecodeError as exc:
        raise WAError(
            "route_invalid",
            "params is not valid UTF-8",
            stage="route_parse",
        ) from exc


def render_params(params: dict[str, str]) -> str:
    return ",".join(
        f"{encode_param_component(key)}={encode_param_component(value)}"
        for key, value in params.items()
    )


def parse_params(value: str) -> dict[str, str]:
    if not value:
        raise WAError("route_invalid", "params must not be empty", stage="route_parse")
    result: dict[str, str] = {}
    for pair in value.split(","):
        if pair.count("=") != 1:
            raise WAError(
                "route_invalid",
                "each params entry needs one raw equals delimiter",
                stage="route_parse",
            )
        raw_key, raw_value = pair.split("=", 1)
        key = decode_param_component(raw_key)
        item = decode_param_component(raw_value)
        if key in result:
            raise WAError(
                "route_invalid",
                f"duplicate params key: {key}",
                stage="route_parse",
            )
        result[key] = item
    return result


def render_route(
    pane: dict[str, Any],
    *,
    params: dict[str, str] | None = None,
) -> str:
    fields = [
        ("name", escape_route_value(route_name(pane))),
        ("pane_id", decimal_pane_id(pane.get("pane_id"))),
        (
            "socket",
            escape_route_value(
                canonical_socket_path(str(pane.get("socket_path") or ""))
            ),
        ),
    ]
    if params:
        fields.append(("params", f"'{render_params(params)}'"))
    return ROUTE_PREFIX + "&".join(f"{key}={value}" for key, value in fields)


def split_route_fields(value: str) -> list[str]:
    query = value[len(ROUTE_PREFIX) :]
    fields: list[str] = []
    current: list[str] = []
    escaped = False
    in_params = False
    index = 0
    while index < len(query):
        character = query[index]
        if escaped:
            if character not in "\\&]":
                raise WAError(
                    "route_invalid",
                    "route contains an unknown backslash escape",
                    stage="route_parse",
                )
            current.extend(("\\", character))
            escaped = False
            index += 1
            continue
        if not in_params and character == "\\":
            escaped = True
            index += 1
            continue
        if not in_params and character == "'" and "".join(current) == "params=":
            in_params = True
            current.append(character)
            index += 1
            continue
        if in_params and character == "'":
            in_params = False
            current.append(character)
            index += 1
            continue
        if not in_params and character == "&":
            fields.append("".join(current))
            current = []
            index += 1
            continue
        if not in_params and character == "]":
            if index != len(query) - 1:
                raise WAError(
                    "route_invalid",
                    "unexpected text follows the route header terminator",
                    stage="route_parse",
                )
            break
        current.append(character)
        index += 1
    if escaped or in_params:
        raise WAError(
            "route_invalid",
            "route ends inside an escape or quoted params field",
            stage="route_parse",
        )
    fields.append("".join(current))
    return fields


def parse_route(value: str) -> tuple[dict[str, Any], dict[str, str]]:
    if not value.startswith(ROUTE_PREFIX):
        unsupported = value[len(ROUTE_SCHEME_PREFIX) :].split("?", 1)[0]
        raise WAError(
            "route_invalid",
            "unsupported route type",
            stage="route_parse",
            details={"unsupported_type": unsupported},
        )
    if not is_line_safe(value):
        raise WAError(
            "route_invalid",
            "route must be single-line text without control characters",
            stage="route_parse",
        )
    raw_fields = split_route_fields(value)
    pairs: list[tuple[str, str]] = []
    seen: set[str] = set()
    for field in raw_fields:
        key, separator, item = field.partition("=")
        if not separator:
            raise WAError(
                "route_invalid",
                "route fields require key=value form",
                stage="route_parse",
            )
        if key not in ROUTE_FIELDS:
            raise WAError(
                "route_invalid",
                f"unknown route field: {key}",
                stage="route_parse",
                details={"field": key},
            )
        if key in seen:
            raise WAError(
                "route_invalid",
                f"duplicate route field: {key}",
                stage="route_parse",
                details={"field": key},
            )
        seen.add(key)
        pairs.append((key, item))
    keys = [key for key, _ in pairs]
    valid_orders = (
        ["name", "pane_id", "socket"],
        ["name", "pane_id", "socket", "params"],
    )
    if keys not in valid_orders:
        raise WAError(
            "route_invalid",
            "route fields are missing or out of canonical order",
            stage="route_parse",
            details={"fields": keys},
        )
    values = dict(pairs)
    name = unescape_route_value(values["name"])
    if not name or not is_line_safe(name):
        raise WAError(
            "route_invalid",
            "route name must be non-empty single-line text",
            stage="route_parse",
        )
    raw_pane_id = values["pane_id"]
    if not raw_pane_id.isdecimal() or not raw_pane_id.isascii():
        raise WAError(
            "route_invalid",
            "route pane_id must be decimal digits",
            stage="route_parse",
        )
    socket_path = canonical_socket_path(unescape_route_value(values["socket"]))
    params: dict[str, str] = {}
    if "params" in values:
        raw_params = values["params"]
        if len(raw_params) < 2 or raw_params[0] != "'" or raw_params[-1] != "'":
            raise WAError(
                "route_invalid",
                "params must be enclosed in single quotes",
                stage="route_parse",
            )
        params = parse_params(raw_params[1:-1])
    address = {
        "name": name,
        "pane_id": f"%{raw_pane_id.lstrip('0') or '0'}",
        "socket_path": socket_path,
    }
    return address, params


def public_pane(pane: dict[str, Any], *, detail: bool = False) -> dict[str, Any]:
    allowed = (
        "kind",
        "pane_id",
        "name",
        "session",
        "window_index",
        "pane_index",
        "session_window_pane",
        "process",
        "cwd",
        "title",
    )
    result = {key: pane.get(key) for key in allowed}
    if detail:
        result.update(
            {
                "socket_path": pane.get("socket_path"),
                "server_pid": pane.get("server_pid"),
                "pane_pid": pane.get("pane_pid"),
                "dead": pane.get("dead"),
                "dead_status": pane.get("dead_status"),
            }
        )
    result["route"] = render_route(pane)
    return result


def safe_public_pane(pane: dict[str, Any]) -> dict[str, Any]:
    try:
        return public_pane(pane)
    except WAError:
        return {
            "kind": "pane",
            "pane_id": pane.get("pane_id"),
            "name": pane.get("name"),
        }


def screen_object(text: str, lines: int) -> dict[str, Any]:
    return {"tail": text, "lines": lines}


class ResolvedTarget:
    def __init__(
        self,
        client: TmuxClient,
        pane: dict[str, Any],
    ) -> None:
        self.client = client
        self.pane = pane


def resolve_target(client: TmuxClient, target: str) -> ResolvedTarget:
    if target.startswith(ROUTE_SCHEME_PREFIX):
        address, _ = parse_route(target)
        route_client = TmuxClient(str(address["socket_path"]))
        pane = route_client.pane(str(address["pane_id"]))
        return ResolvedTarget(route_client, pane)
    if TMUX_PANE_RE.fullmatch(target) or TMUX_LOCATION_RE.fullmatch(target):
        return ResolvedTarget(client, client.pane(target))
    matches = [
        pane
        for pane in client.list_panes()
        if pane.get("name") == target
    ]
    if not matches:
        raise WAError(
            "target_not_found",
            f"cannot resolve logical pane target: {target}",
            stage="resolve_target",
            recovery="Run with-agents list and use a live window name, pane ID, or route.",
        )
    if len(matches) > 1:
        raise WAError(
            "target_ambiguous",
            f"multiple panes match logical target: {target}",
            stage="resolve_target",
            recovery="Use the exact %pane-id or route from with-agents route TARGET.",
        )
    return ResolvedTarget(client, matches[0])


def revalidate_target(resolved: ResolvedTarget) -> dict[str, Any]:
    return resolved.client.pane(str(resolved.pane["pane_id"]))


def resolve_caller_pane(
    *, required: bool
) -> tuple[TmuxClient, dict[str, Any]] | None:
    pane_id = os.environ.get("TMUX_PANE")
    tmux = os.environ.get("TMUX")
    if not pane_id or not tmux:
        if required:
            raise WAError(
                "caller_identity_unavailable",
                "cannot derive caller identity from TMUX and TMUX_PANE",
                stage="caller_identity",
                recovery="Retry with send --no-header only when a raw message is intended.",
            )
        return None
    try:
        socket, _, _ = parse_tmux_environment(tmux)
        client = TmuxClient(socket)
        return client, client.pane(pane_id)
    except WAError as exc:
        if required:
            raise WAError(
                "caller_identity_unavailable",
                "cannot resolve the live caller pane",
                stage="caller_identity",
                recovery="Retry with send --no-header only when a raw message is intended.",
            ) from exc
        return None


def ensure_not_self(pane: dict[str, Any]) -> None:
    caller_pane_id = os.environ.get("TMUX_PANE")
    if not caller_pane_id or pane.get("pane_id") != caller_pane_id:
        return
    tmux = os.environ.get("TMUX")
    if not tmux:
        raise WAError(
            "self_target_unverified",
            "cannot prove a same-ID target belongs to another tmux server",
            stage="preflight",
            target=public_pane(pane),
        )
    try:
        caller_socket, _, _ = parse_tmux_environment(tmux)
        caller_path = canonical_socket_path(caller_socket)
        target_path = canonical_socket_path(str(pane.get("socket_path") or ""))
    except WAError as exc:
        raise WAError(
            "self_target_unverified",
            "cannot prove a same-ID target belongs to another tmux server",
            stage="preflight",
            target=public_pane(pane),
        ) from exc
    if caller_path == target_path:
        raise WAError(
            "self_target_denied",
            "refusing to mutate the caller's own pane",
            stage="preflight",
            target=public_pane(pane),
        )


def stable_key(*parts: Any) -> str:
    material = "\x00".join(str(part) for part in parts)
    return hashlib.sha256(material.encode("utf-8")).hexdigest()[:32]


def acquire_lock(
    descriptor: int, label: str, *, timeout: float = LOCK_ACQUIRE_TIMEOUT
) -> None:
    deadline = time.monotonic() + timeout
    while True:
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
            return
        except BlockingIOError:
            if time.monotonic() >= deadline:
                raise WAError(
                    "lock_timeout",
                    f"timed out waiting for {label} input lock",
                    stage="lock",
                    recovery="Inspect the existing operation before retrying.",
                )
            time.sleep(0.05)


@contextlib.contextmanager
def pane_lock(runtime: RuntimeState, pane: dict[str, Any]) -> Iterator[None]:
    address = address_of(pane)
    key = stable_key(address["socket_path"], address["pane_id"])
    path = runtime.locks / f"pane-{key}.lock"
    descriptor = os.open(path, os.O_RDWR | os.O_CREAT, 0o600)
    try:
        os.fchmod(descriptor, 0o600)
        acquire_lock(descriptor, f"pane {pane.get('pane_id')}")
        yield
    finally:
        fcntl.flock(descriptor, fcntl.LOCK_UN)
        os.close(descriptor)


def validate_pane_name(name: str) -> str:
    if PANE_NAME_RE.fullmatch(name) is None:
        raise WAError(
            "invalid_pane_name",
            "pane name must be 1-64 restricted ASCII characters",
            stage="preflight",
        )
    return name


def validate_generated_suffix(suffix: str) -> str:
    if GENERATED_SUFFIX_RE.fullmatch(suffix) is None:
        raise WAError(
            "invalid_pane_name",
            "generated pane suffix must be 1-6 ASCII alphanumeric characters",
            stage="preflight",
        )
    return suffix


def validate_preset_name(name: str) -> str:
    if PRESET_NAME_RE.fullmatch(name) is None:
        raise WAError(
            "invalid_preset_name",
            "preset name must be 1-64 restricted ASCII characters",
            stage="preflight",
        )
    return name


def validate_cwd(value: str | None) -> str:
    path = Path(value or os.getcwd()).expanduser().resolve()
    if not path.is_dir():
        raise WAError("cwd_not_found", f"working directory does not exist: {path}")
    return str(path)


def validate_message(value: str) -> str:
    if not value:
        raise WAError("empty_message", "message must not be empty", stage="preflight")
    if any(
        unicodedata.category(character) == "Cc" and character not in ("\n", "\t")
        for character in value
    ):
        raise WAError(
            "unsafe_message",
            "message contains an unsupported control character",
            stage="preflight",
        )
    return value


def argv_from_remainder(values: list[str], *, required: bool = True) -> list[str]:
    argv = list(values)
    if argv and argv[0] == "--":
        argv.pop(0)
    if required and not argv:
        raise WAError(
            "launch_argv_required",
            "an executable argv is required after --",
            stage="preflight",
        )
    if any("\x00" in item for item in argv):
        raise WAError("invalid_argv", "argv contains a NUL byte", stage="preflight")
    return argv


def exec_payload(argv: list[str]) -> str:
    encoded = base64.urlsafe_b64encode(json.dumps(argv).encode("utf-8")).decode(
        "ascii"
    )
    helper = [sys.executable, str(Path(__file__).resolve()), "_exec", encoded]
    return "exec " + shlex.join(helper)


def internal_exec(payload: str) -> int:
    argv: list[str] = []
    try:
        decoded = json.loads(base64.urlsafe_b64decode(payload.encode("ascii")))
        if (
            not isinstance(decoded, list)
            or not decoded
            or not all(isinstance(item, str) for item in decoded)
        ):
            raise ValueError("payload is not a non-empty string argv")
        argv = decoded
        os.execvp(argv[0], argv)
    except FileNotFoundError:
        sys.stderr.write(f"[with-agents exec error] executable not found: {argv[0]}\n")
        return 127
    except Exception as exc:
        sys.stderr.write(f"[with-agents exec error] {exc}\n")
        return 126
    return 126


def set_pane_lifecycle(client: TmuxClient, pane_id: str) -> None:
    client.run(
        ["set-option", "-p", "-t", pane_id, "remain-on-exit", "on"],
        stage="metadata",
    )


def choose_new_pane(
    client: TmuxClient,
    runtime: RuntimeState,
    *,
    name: str | None,
    cwd: str,
    session: str | None,
    split: str | None,
) -> tuple[TmuxClient, str]:
    if split and session:
        raise WAError(
            "layout_source_conflict",
            "do not combine --session with --split",
            stage="preflight",
        )
    if split:
        split_target = resolve_target(client, split)
        with pane_lock(runtime, split_target.pane):
            current = revalidate_target(split_target)
            if current.get("dead"):
                raise WAError(
                    "target_process_exited",
                    f"pane {current['pane_id']} has no live target process",
                    stage="preflight",
                    target=public_pane(current),
                )
            pane_id = split_target.client.run(
                [
                    "split-window",
                    "-d",
                    "-P",
                    "-F",
                    "#{pane_id}",
                    "-t",
                    str(current["pane_id"]),
                    "-c",
                    cwd,
                ],
                stage="create",
            ).stdout.strip()
        return split_target.client, pane_id

    if name is None:
        raise WAError(
            "pane_name_required",
            "launching a new window from direct argv requires --name",
            stage="preflight",
        )

    sessions = client.list_sessions()
    selected_session = session
    if (
        selected_session is None
        and client.inherits_caller
        and os.environ.get("TMUX_PANE")
    ):
        with contextlib.suppress(WAError):
            selected_session = client.pane(os.environ["TMUX_PANE"])["session"]
    if selected_session is not None:
        if selected_session not in sessions:
            raise WAError(
                "session_not_found",
                f"tmux session does not exist: {selected_session}",
            )
        pane_id = client.run(
            [
                "new-window",
                "-d",
                "-P",
                "-F",
                "#{pane_id}",
                "-t",
                f"{selected_session}:",
                "-n",
                name,
                "-c",
                cwd,
            ],
            stage="create",
        ).stdout.strip()
        return client, pane_id
    if len(sessions) == 1:
        pane_id = client.run(
            [
                "new-window",
                "-d",
                "-P",
                "-F",
                "#{pane_id}",
                "-t",
                f"{sessions[0]}:",
                "-n",
                name,
                "-c",
                cwd,
            ],
            stage="create",
        ).stdout.strip()
        return client, pane_id
    if len(sessions) > 1:
        raise WAError(
            "session_required",
            "multiple tmux sessions are available outside a resolvable caller session",
            recovery="Choose one with --session or use --split TARGET.",
            details={"sessions": sessions},
        )
    pane_id = client.run(
        [
            "new-session",
            "-d",
            "-P",
            "-F",
            "#{pane_id}",
            "-s",
            "with_agents",
            "-n",
            name,
            "-c",
            cwd,
        ],
        stage="create",
    ).stdout.strip()
    return client, pane_id


def normalized_snapshot(value: str) -> str:
    return "\n".join(line.rstrip() for line in value.replace("\r", "").splitlines()).strip()


def validate_ready_timeout(value: float) -> float:
    if not math.isfinite(value) or value <= 0:
        raise WAError(
            "invalid_ready_timeout",
            "--ready-timeout must be positive and finite",
            stage="preflight",
        )
    return value


def observe_launch(
    resolved: ResolvedTarget,
    *,
    baseline: str,
    timeout: float,
    no_wait: bool,
    lines: int = 80,
) -> tuple[dict[str, Any], dict[str, Any], dict[str, Any]]:
    baseline_normalized = normalized_snapshot(baseline)
    if no_wait:
        captured = resolved.client.capture(str(resolved.pane["pane_id"]), lines)
        current = revalidate_target(resolved)
        material = bool(normalized_snapshot(captured)) and (
            normalized_snapshot(captured) != baseline_normalized
        )
        return (
            current,
            screen_object(captured, lines),
            {"waited": False, "material_change": material, "stable": None},
        )

    deadline = time.monotonic() + timeout
    material_change = False
    stable_value: str | None = None
    stable_since: float | None = None
    captured = ""
    current = resolved.pane
    while True:
        captured = resolved.client.capture(str(resolved.pane["pane_id"]), lines)
        current = revalidate_target(resolved)
        normalized = normalized_snapshot(captured)
        now = time.monotonic()
        if current.get("dead"):
            return (
                current,
                screen_object(captured, lines),
                {
                    "waited": True,
                    "material_change": bool(normalized)
                    and normalized != baseline_normalized,
                    "stable": False,
                },
            )
        if not material_change:
            if normalized and normalized != baseline_normalized:
                material_change = True
                stable_value = normalized
                stable_since = now
        elif normalized != stable_value:
            stable_value = normalized
            stable_since = now
        elif stable_since is not None and now - stable_since >= LAUNCH_STABLE_INTERVAL:
            return (
                current,
                screen_object(captured, lines),
                {"waited": True, "material_change": True, "stable": True},
            )
        if now >= deadline:
            return (
                current,
                screen_object(captured, lines),
                {
                    "waited": True,
                    "material_change": material_change,
                    "stable": False,
                },
            )
        time.sleep(min(LAUNCH_POLL_INTERVAL, max(0.0, deadline - now)))


def launch_process_error(
    pane: dict[str, Any],
    screen: dict[str, Any],
    target: dict[str, Any],
) -> WAError | None:
    if not pane.get("dead"):
        return None
    code = (
        "executable_not_found"
        if pane.get("dead_status") == 127
        else "launch_process_exited"
    )
    return WAError(
        code,
        f"launched process exited with status {pane.get('dead_status')}",
        stage="process_exited",
        target=target,
        screen=screen,
    )


def post_action_observation(
    resolved: ResolvedTarget,
    *,
    baseline: str,
    uncertain_stage: str,
    lines: int = 80,
) -> tuple[dict[str, Any], dict[str, Any], dict[str, Any]]:
    deadline = time.monotonic() + POST_ACTION_TIMEOUT
    captured = ""
    current = resolved.pane
    changed = False
    try:
        while True:
            captured = resolved.client.capture(str(resolved.pane["pane_id"]), lines)
            current = revalidate_target(resolved)
            changed = captured != baseline
            if changed or time.monotonic() >= deadline:
                break
            time.sleep(
                min(
                    POST_ACTION_INTERVAL,
                    max(0.0, deadline - time.monotonic()),
                )
            )
    except WAError as exc:
        raise WAError(
            "post_action_observation_failed",
            "the tmux action completed but its resulting screen could not be observed",
            stage=uncertain_stage,
            recovery="Do not replay the action blindly; inspect the target first.",
            target=public_pane(current),
        ) from exc
    except KeyboardInterrupt as exc:
        raise WAError(
            "interrupted",
            "post-action observation was interrupted after the tmux action",
            stage=uncertain_stage,
            recovery="Do not replay the action blindly; inspect the target first.",
            target=safe_public_pane(current),
        ) from exc
    return (
        current,
        screen_object(captured, lines),
        {"changed": changed, "window_seconds": POST_ACTION_TIMEOUT},
    )


def parse_extra_params(raw: str | None) -> dict[str, str]:
    if raw is None:
        return {}

    def pairs_hook(pairs: list[tuple[str, Any]]) -> dict[str, Any]:
        result: dict[str, Any] = {}
        for key, value in pairs:
            if key in result:
                raise WAError(
                    "params_invalid",
                    f"duplicate JSON params key: {key}",
                    stage="preflight",
                )
            result[key] = value
        return result

    try:
        value = json.loads(raw, object_pairs_hook=pairs_hook)
    except WAError:
        raise
    except json.JSONDecodeError as exc:
        raise WAError(
            "params_invalid",
            f"--params must be strict JSON: {exc.msg}",
            stage="preflight",
        ) from exc
    if not isinstance(value, dict) or not all(
        isinstance(key, str) and isinstance(item, str)
        for key, item in value.items()
    ):
        raise WAError(
            "params_invalid",
            "--params must be a JSON object whose keys and values are strings",
            stage="preflight",
        )
    try:
        for key, item in value.items():
            key.encode("utf-8")
            item.encode("utf-8")
    except UnicodeEncodeError as exc:
        raise WAError(
            "params_invalid",
            "--params keys and values must be valid Unicode text",
            stage="preflight",
        ) from exc
    conflicts = [key for key in ("reply", "correlation_id") if key in value]
    if conflicts:
        raise WAError(
            "params_source_conflict",
            f"--params cannot set reserved keys: {', '.join(conflicts)}",
            stage="preflight",
        )
    return value


def new_correlation_id() -> str:
    alphabet = string.ascii_letters + string.digits
    return "".join(secrets.choice(alphabet) for _ in range(8))


def build_send_message(
    args: argparse.Namespace, resolved: ResolvedTarget
) -> tuple[str, dict[str, Any]]:
    body = validate_message(args.message)
    if args.no_header and (
        args.request or args.correlation_id is not None or args.params is not None
    ):
        raise WAError(
            "message_option_conflict",
            "--no-header cannot be combined with --request, --correlation-id, or --params",
            stage="preflight",
        )
    if args.no_header:
        return body, {
            "header": False,
            "sender_route": None,
            "params": {},
            "correlation_id": None,
        }

    correlation = args.correlation_id
    if correlation == "":
        raise WAError(
            "invalid_correlation_id",
            "--correlation-id must not be empty",
            stage="preflight",
        )
    if args.request and correlation is None:
        correlation = new_correlation_id()
    params: dict[str, str] = {}
    if args.request:
        params["reply"] = "required"
    if correlation is not None:
        params["correlation_id"] = correlation
    params.update(parse_extra_params(args.params))

    caller = resolve_caller_pane(required=True)
    assert caller is not None
    _, caller_pane = caller
    sender_route = render_route(
        caller_pane,
        params=params or None,
    )
    return f"[{sender_route}] {body}", {
        "header": True,
        "sender_route": sender_route,
        "params": params,
        "correlation_id": correlation,
    }


def atomic_submit(
    runtime: RuntimeState,
    resolved: ResolvedTarget,
    *,
    message: str,
) -> tuple[ResolvedTarget, str]:
    validate_message(message)
    with pane_lock(runtime, resolved.pane):
        current = revalidate_target(resolved)
        ensure_not_self(current)
        if current.get("dead"):
            raise WAError(
                "target_process_exited",
                f"pane {current['pane_id']} has no live target process",
                stage="preflight",
                target=public_pane(current),
            )
        baseline = resolved.client.capture(str(current["pane_id"]), 80)
        buffer_name = f"with-agents-{uuid.uuid4().hex}"
        pasted = False
        try:
            resolved.client.run(
                ["load-buffer", "-b", buffer_name, "-"],
                input_text=message,
                stage="text_not_written",
            )
            try:
                resolved.client.run(
                    [
                        "paste-buffer",
                        "-p",
                        "-b",
                        buffer_name,
                        "-d",
                        "-t",
                        str(current["pane_id"]),
                    ],
                    stage="text_written_not_submitted",
                )
                pasted = True
            except WAError as exc:
                exc.stage = "text_written_not_submitted"
                exc.recovery = (
                    "Text may have reached the pane. Do not resend it; inspect the "
                    "target before deciding whether to submit only."
                )
                exc.target = public_pane(current)
                raise
            except KeyboardInterrupt as exc:
                raise WAError(
                    "interrupted",
                    "input was interrupted while paste delivery was uncertain",
                    stage="text_written_not_submitted",
                    recovery=(
                        "Text may have reached the pane. Do not resend it; inspect "
                        "the target before deciding whether to submit only."
                    ),
                    target=public_pane(current),
                ) from exc
        except KeyboardInterrupt as exc:
            stage = "text_written_not_submitted" if pasted else "text_not_written"
            raise WAError(
                "interrupted",
                "input was interrupted before submission",
                stage=stage,
                recovery=(
                    "Inspect the target before retrying."
                    if pasted
                    else "No pane paste was confirmed; inspect before retrying."
                ),
                target=public_pane(current),
            ) from exc
        finally:
            with contextlib.suppress(WAError):
                resolved.client.run(
                    ["delete-buffer", "-b", buffer_name],
                    stage="buffer_cleanup",
                    check=False,
                )
        try:
            time.sleep(INPUT_SETTLE_SECONDS)
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "input was interrupted after text was pasted and before submission",
                stage="text_written_not_submitted",
                recovery="Do not resend the text; inspect the target first.",
                target=public_pane(current),
            ) from exc
        try:
            resolved.client.run(
                ["send-keys", "-t", str(current["pane_id"]), "Enter"],
                stage="text_written_not_submitted",
            )
        except WAError as exc:
            if exc.code == "tmux_timeout":
                exc.stage = "submitted_state_unknown"
                exc.recovery = (
                    "The submit key may have reached the pane. Do not resend; "
                    "inspect the target first."
                )
            else:
                exc.stage = "text_written_not_submitted"
                exc.recovery = (
                    "The text was pasted but the submit command failed. Inspect "
                    "the target before sending only the submit key."
                )
            exc.target = public_pane(current)
            with contextlib.suppress(WAError):
                exc.screen = screen_object(
                    resolved.client.capture(str(current["pane_id"]), 80), 80
                )
            raise
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "submit-key delivery was interrupted and may have reached the pane",
                stage="submitted_state_unknown",
                recovery="Do not resend; inspect the target first.",
                target=public_pane(current),
            ) from exc
        resolved.pane = current
        return resolved, baseline


def atomic_key(
    runtime: RuntimeState,
    resolved: ResolvedTarget,
    keys: list[str],
) -> tuple[ResolvedTarget, str]:
    with pane_lock(runtime, resolved.pane):
        current = revalidate_target(resolved)
        ensure_not_self(current)
        if current.get("dead"):
            raise WAError(
                "target_process_exited",
                f"pane {current['pane_id']} has no live target process",
                stage="preflight",
                target=public_pane(current),
            )
        baseline = resolved.client.capture(str(current["pane_id"]), 80)
        try:
            resolved.client.run(
                ["send-keys", "-t", str(current["pane_id"]), *keys],
                stage="key_state_unknown",
            )
        except WAError as exc:
            exc.stage = "key_state_unknown"
            exc.recovery = (
                "The key may have reached the pane. Do not replay it; inspect the "
                "target first."
            )
            exc.target = public_pane(current)
            raise
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "key delivery was interrupted and may have reached the pane",
                stage="key_state_unknown",
                recovery="Do not replay the key; inspect the target first.",
                target=public_pane(current),
            ) from exc
        resolved.pane = current
        return resolved, baseline


def preset_path(config: ConfigState, name: str) -> Path:
    validate_preset_name(name)
    return config.validate_existing_presets() / f"{name}.json"


def load_preset(config: ConfigState, name: str) -> tuple[dict[str, Any], Path]:
    path = preset_path(config, name)
    if not path.is_file():
        raise WAError(
            "preset_not_found",
            f"preset does not exist: {name}",
            details={"searched_path": str(path)},
        )
    value = safe_read_json(path)
    argv = value.get("argv")
    agent_type = value.get("agent_type")
    pane_name = value.get("pane_name")
    expected_fields = {"version", "agent_type", "argv"}
    if pane_name is not None:
        expected_fields.add("pane_name")
    if (
        set(value) != expected_fields
        or value.get("version") != 1
        or isinstance(value.get("version"), bool)
        or not isinstance(argv, list)
        or not argv
        or not all(isinstance(item, str) for item in argv)
        or any("\x00" in item for item in argv)
    ):
        raise WAError("invalid_preset", f"preset has an invalid version or argv: {path}")
    if not isinstance(agent_type, str) or AGENT_TYPE_RE.fullmatch(agent_type) is None:
        raise WAError("invalid_preset", f"preset has an invalid agent_type: {path}")
    if pane_name is not None and (
        not isinstance(pane_name, str) or PANE_NAME_RE.fullmatch(pane_name) is None
    ):
        raise WAError("invalid_preset", f"preset has an invalid pane_name: {path}")
    return value, path


def reject_secret_argv(argv: list[str]) -> None:
    findings: list[str] = []
    for index, argument in enumerate(argv):
        flag, separator, _ = argument.partition("=")
        if SECRET_FLAG_RE.search(flag):
            findings.append(flag)
            if not separator and index + 1 < len(argv):
                findings.append(f"{flag} <next-argument>")
        if "=" in argument:
            variable = argument.split("=", 1)[0]
            if SECRET_FLAG_RE.fullmatch(variable):
                findings.append(variable)
    if findings:
        raise WAError(
            "preset_secret_suspected",
            "launch argv contains a credential-like field and will not be persisted",
            details={"suspicious_fields": sorted(set(findings))},
        )


def resolve_launch_spec(
    args: argparse.Namespace, config: ConfigState
) -> tuple[list[str], str | None]:
    has_name = args.name is not None
    has_suffix = args.name_suffix is not None
    has_preset = args.preset is not None
    if has_name and has_suffix:
        raise WAError(
            "pane_name_source_conflict",
            "do not combine --name with --name-suffix",
            stage="preflight",
        )
    if has_suffix and not has_preset:
        raise WAError(
            "name_suffix_requires_preset",
            "--name-suffix requires --preset",
            stage="preflight",
        )
    if args.split and (has_name or has_suffix):
        raise WAError(
            "pane_name_source_conflict",
            "--split cannot be combined with --name or --name-suffix",
            stage="preflight",
        )
    if has_preset:
        if args.argv:
            raise WAError(
                "launch_source_conflict", "do not combine --preset with direct argv"
            )
        preset, _ = load_preset(config, args.preset)
        if args.split:
            name = None
        elif has_name:
            name = validate_pane_name(args.name)
        elif has_suffix:
            registry = load_agent_registry(config)
            definition = registry.get(preset["agent_type"])
            if definition is None:
                raise WAError(
                    "agent_prefix_not_configured",
                    f"preset agent type has no pane prefix: {preset['agent_type']}",
                )
            name = f"{definition['pane_prefix']}-{validate_generated_suffix(args.name_suffix)}"
        elif preset.get("pane_name") is not None:
            name = validate_pane_name(preset["pane_name"])
        else:
            registry = load_agent_registry(config)
            definition = registry.get(preset["agent_type"])
            if definition is None:
                raise WAError(
                    "agent_prefix_not_configured",
                    f"preset agent type has no pane prefix: {preset['agent_type']}",
                )
            suffix = "".join(secrets.choice(string.digits) for _ in range(4))
            name = f"{definition['pane_prefix']}-{suffix}"
        return list(preset["argv"]), name
    argv = argv_from_remainder(args.argv)
    if args.split:
        return argv, None
    if not has_name:
        raise WAError("pane_name_required", "direct launch requires --name")
    return argv, validate_pane_name(args.name)


def command_list(
    args: argparse.Namespace, _: RuntimeState, __: ConfigState
) -> dict[str, Any]:
    client = TmuxClient(args.socket)
    panes = [
        public_pane(pane, detail=args.detail)
        for pane in client.list_panes()
    ]
    return new_envelope(
        "list",
        "listed",
        target={"kind": "pane-list", "detail": args.detail, "items": panes},
    )


def command_route(
    args: argparse.Namespace, _: RuntimeState, __: ConfigState
) -> dict[str, Any]:
    if args.target is None:
        caller = resolve_caller_pane(required=True)
        assert caller is not None
        _, pane = caller
    else:
        resolved = resolve_target(TmuxClient(args.socket), args.target)
        pane = revalidate_target(resolved)
    return new_envelope(
        "route",
        "shown",
        target=public_pane(pane),
    )


def command_read(
    args: argparse.Namespace, _: RuntimeState, __: ConfigState
) -> dict[str, Any]:
    if args.lines <= 0:
        raise WAError("invalid_lines", "--lines must be a positive integer")
    resolved = resolve_target(TmuxClient(args.socket), args.target)
    captured = resolved.client.capture(str(resolved.pane["pane_id"]), args.lines)
    pane = revalidate_target(resolved)
    return new_envelope(
        "read",
        "observed",
        target=public_pane(pane),
        screen=screen_object(captured, args.lines),
    )


def command_launch(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    timeout = validate_ready_timeout(args.ready_timeout)
    argv, name = resolve_launch_spec(args, config)
    cwd = validate_cwd(args.cwd)
    try:
        client, pane_id = choose_new_pane(
            TmuxClient(args.socket),
            runtime,
            name=name,
            cwd=cwd,
            session=args.session,
            split=args.split,
        )
    except WAError as exc:
        if exc.code != "tmux_timeout":
            raise
        raise WAError(
            exc.code,
            "launch pane creation timed out and may already have taken effect",
            stage="launch_state_unknown",
            recovery="List panes and inspect the intended session before retrying.",
        ) from exc
    except KeyboardInterrupt as exc:
        raise WAError(
            "interrupted",
            "launch pane creation was interrupted and may already have taken effect",
            stage="launch_state_unknown",
            recovery="List panes and inspect the intended session before retrying.",
        ) from exc
    pane: dict[str, Any] = {"kind": "pane", "pane_id": pane_id, "name": name or ""}
    baseline = ""
    try:
        set_pane_lifecycle(client, pane_id)
        baseline = client.capture(pane_id, 80)
        client.run(
            ["respawn-pane", "-k", "-t", pane_id, "-c", cwd, exec_payload(argv)],
            stage="launch",
        )
        pane = client.pane(pane_id)
    except (WAError, KeyboardInterrupt) as exc:
        with contextlib.suppress(WAError):
            pane = client.pane(pane_id)
        captured = ""
        with contextlib.suppress(WAError):
            captured = client.capture(pane_id, 80)
        raise WAError(
            exc.code if isinstance(exc, WAError) else "interrupted",
            "the pane exists but launch state could not be confirmed",
            stage="launch_state_unknown",
            recovery="Resolve and read the pane before sending another mutation.",
            target=safe_public_pane(pane),
            screen=screen_object(captured, 80),
        ) from exc
    resolved = ResolvedTarget(client, pane)
    try:
        pane, screen, observation = observe_launch(
            resolved,
            baseline=baseline,
            timeout=timeout,
            no_wait=args.no_wait,
        )
    except (WAError, KeyboardInterrupt) as exc:
        captured = ""
        with contextlib.suppress(WAError):
            captured = client.capture(pane_id, 80)
        raise WAError(
            exc.code if isinstance(exc, WAError) else "interrupted",
            "the process was launched but its screen could not be confirmed",
            stage="launch_state_unknown",
            recovery="Resolve and read the pane before another mutation.",
            target=safe_public_pane(pane),
            screen=screen_object(captured, 80),
        ) from exc
    target = {
        **public_pane(pane),
        "launch": {
            "observation": observation,
        },
    }
    process_error = launch_process_error(pane, screen, target)
    if process_error is not None:
        raise process_error
    if observation["waited"] and not observation["material_change"]:
        raise WAError(
            "launch_timeout",
            "launched process produced no material screen change before timeout",
            stage="launch_timeout",
            target=target,
            screen=screen,
        )
    return new_envelope("launch", "launched", target=target, screen=screen)


def command_send(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    resolved = resolve_target(TmuxClient(args.socket), args.target)
    message, message_metadata = build_send_message(args, resolved)
    resolved, baseline = atomic_submit(
        runtime,
        resolved,
        message=message,
    )
    pane, screen, observation = post_action_observation(
        resolved, baseline=baseline, uncertain_stage="submitted_state_unknown"
    )
    return new_envelope(
        "send",
        "submitted",
        target={
            **public_pane(pane),
            "message": message_metadata,
            "post_action": observation,
        },
        screen=screen,
    )


def command_key(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    keys = argv_from_remainder(args.keys, required=False)
    if not keys:
        raise WAError("keys_required", "key requires at least one tmux key name")
    resolved = resolve_target(TmuxClient(args.socket), args.target)
    resolved, baseline = atomic_key(runtime, resolved, keys)
    pane, screen, observation = post_action_observation(
        resolved, baseline=baseline, uncertain_stage="key_state_unknown"
    )
    return new_envelope(
        "key",
        "sent",
        target={**public_pane(pane), "post_action": observation},
        screen=screen,
    )


def command_wait(
    args: argparse.Namespace, _: RuntimeState, __: ConfigState
) -> dict[str, Any]:
    if (
        not math.isfinite(args.timeout)
        or not math.isfinite(args.interval)
        or args.timeout < 0
        or args.interval <= 0
        or args.lines <= 0
    ):
        raise WAError(
            "invalid_wait",
            "timeout must be nonnegative; interval and lines must be positive",
        )
    resolved = resolve_target(TmuxClient(args.socket), args.target)
    initial = resolved.client.capture(str(resolved.pane["pane_id"]), args.lines)
    current = revalidate_target(resolved)
    stage = "process_exit" if current.get("dead") else "unchanged"
    captured = initial
    deadline = time.monotonic() + args.timeout
    while stage == "unchanged" and time.monotonic() < deadline:
        time.sleep(min(args.interval, max(0.0, deadline - time.monotonic())))
        try:
            captured = resolved.client.capture(
                str(resolved.pane["pane_id"]), args.lines
            )
            current = revalidate_target(resolved)
        except WAError as exc:
            if exc.code == "tmux_timeout":
                raise
            if exc.code == "target_not_found":
                stage = "process_exit"
                break
            if exc.code == "tmux_command_failed":
                try:
                    current = revalidate_target(resolved)
                except WAError as lookup_error:
                    if lookup_error.code == "target_not_found":
                        stage = "process_exit"
                        break
                    raise
            raise
        if current.get("dead"):
            stage = "process_exit"
        elif captured != initial:
            stage = "changed"
    return new_envelope(
        "wait",
        stage,
        target=public_pane(current),
        screen=screen_object(captured, args.lines),
    )


def command_close(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    if args.lines <= 0:
        raise WAError("invalid_lines", "--lines must be a positive integer")
    resolved = resolve_target(TmuxClient(args.socket), args.target)
    with pane_lock(runtime, resolved.pane):
        current = revalidate_target(resolved)
        ensure_not_self(current)
        captured = resolved.client.capture(str(current["pane_id"]), args.lines)
        try:
            resolved.client.run(
                ["kill-pane", "-t", str(current["pane_id"])], stage="close"
            )
        except WAError as exc:
            exc.stage = "close_state_unknown"
            exc.recovery = (
                "The pane may already be closed. Resolve the exact target before "
                "another lifecycle action."
            )
            exc.target = public_pane(current)
            exc.screen = screen_object(captured, args.lines)
            raise
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "close was interrupted and the pane may already be gone",
                stage="close_state_unknown",
                recovery="Resolve or list the target before another lifecycle action.",
                target=public_pane(current),
                screen=screen_object(captured, args.lines),
            ) from exc
    return new_envelope(
        "close",
        "closed",
        target=public_pane(current),
        screen=screen_object(captured, args.lines),
    )


def command_preset_list(
    _: argparse.Namespace, __: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    directory = config.validate_existing_presets()
    items = [
        {"name": path.stem, "path": str(path)}
        for path in sorted(directory.glob("*.json"))
        if path.is_file()
        and not path.is_symlink()
        and PRESET_NAME_RE.fullmatch(path.stem)
    ]
    return new_envelope(
        "preset.list", "listed", target={"kind": "preset-list", "items": items}
    )


def command_preset_show(
    args: argparse.Namespace, _: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    value, path = load_preset(config, args.name)
    digest = hashlib.sha256(canonical_json_bytes(value)).hexdigest()
    return new_envelope(
        "preset.show",
        "shown",
        target={
            "kind": "preset",
            "name": args.name,
            "path": str(path),
            "digest": digest,
            **value,
        },
    )


def mutate_preset(
    args: argparse.Namespace,
    config: ConfigState,
    *,
    update: bool,
) -> dict[str, Any]:
    if AGENT_TYPE_RE.fullmatch(args.agent_type) is None:
        raise WAError(
            "invalid_preset",
            "--agent-type must be a lowercase restricted identifier",
            stage="preflight",
        )
    argv = argv_from_remainder(args.argv)
    reject_secret_argv(argv)
    value: dict[str, Any] = {
        "version": 1,
        "agent_type": args.agent_type,
        "argv": argv,
    }
    if args.pane_name is not None:
        value["pane_name"] = validate_pane_name(args.pane_name)
    path = preset_path(config, args.name)
    exists = path.exists()
    if path.is_symlink():
        raise WAError("unsafe_state_path", f"preset path is a symlink: {path}")
    if update:
        if not args.replace:
            raise WAError("replace_required", "preset update requires --replace")
        if not exists:
            raise WAError("preset_not_found", f"preset does not exist: {args.name}")
    elif exists:
        raise WAError("preset_exists", f"preset already exists: {args.name}")
    digest = hashlib.sha256(canonical_json_bytes(value)).hexdigest()
    if not args.dry_run:
        config.ensure_presets()
        atomic_write_json(path, value, exclusive=not update)
    stage = "dry_run" if args.dry_run else ("updated" if update else "saved")
    return new_envelope(
        "preset.update" if update else "preset.save",
        stage,
        target={
            "kind": "preset",
            "name": args.name,
            "path": str(path),
            "digest": digest,
            "dry_run": args.dry_run,
            **value,
        },
    )


def command_preset_save(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    del runtime
    return mutate_preset(args, config, update=False)


def command_preset_update(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    del runtime
    return mutate_preset(args, config, update=True)


def command_preset_remove(
    args: argparse.Namespace, _: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    path = preset_path(config, args.name)
    if not path.is_file() or path.is_symlink():
        raise WAError("preset_not_found", f"preset does not exist: {args.name}")
    value = safe_read_json(path)
    digest = hashlib.sha256(canonical_json_bytes(value)).hexdigest()
    path.unlink()
    return new_envelope(
        "preset.remove",
        "removed",
        target={
            "kind": "preset",
            "name": args.name,
            "path": str(path),
            "digest": digest,
        },
    )


def tmux_version_tuple(text: str) -> tuple[int, int] | None:
    match = re.search(r"(\d+)\.(\d+)", text)
    return (int(match.group(1)), int(match.group(2))) if match else None


def command_doctor(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    runtime_check: dict[str, Any] = {
        "path": str(runtime.root),
        "source": runtime.source,
        "ok": False,
    }
    try:
        runtime.ensure_root()
    except WAError as exc:
        runtime_check["error"] = {"code": exc.code, "message": exc.message}
    else:
        runtime_check["ok"] = True
    config_check: dict[str, Any] = {
        "path": str(config.agent_config),
        "present": config.agent_config.exists() or config.agent_config.is_symlink(),
        "ok": False,
    }
    try:
        registry = load_agent_registry(config)
    except WAError as exc:
        config_check["error"] = {"code": exc.code, "message": exc.message}
    else:
        config_check.update({"ok": True, "agents": sorted(registry)})
    tmux_check: dict[str, Any] = {"path": shutil.which("tmux"), "ok": False}
    if tmux_check["path"]:
        try:
            output = subprocess.run(
                [str(tmux_check["path"]), "-V"],
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=3,
                check=False,
            ).stdout.strip()
        except (OSError, subprocess.TimeoutExpired) as exc:
            tmux_check["version_error"] = str(exc)
        else:
            parsed = tmux_version_tuple(output)
            tmux_check.update(
                {
                    "version": output,
                    "minimum": f"{MIN_TMUX[0]}.{MIN_TMUX[1]}",
                    "ok": parsed is not None and parsed >= MIN_TMUX,
                }
            )
            client = TmuxClient(args.socket)
            try:
                tmux_check["server"] = client.server()
                tmux_check["server_running"] = True
                tmux_check["panes"] = len(client.list_panes())
            except WAError:
                tmux_check["server_running"] = False
    checks = {
        "with_agents_version": VERSION,
        "python": {
            "version": ".".join(str(part) for part in sys.version_info[:3]),
            "minimum": ".".join(str(part) for part in MIN_PYTHON),
            "ok": sys.version_info[:2] >= MIN_PYTHON,
        },
        "runtime": runtime_check,
        "agent_config": config_check,
        "tmux": tmux_check,
        "fcntl": {"ok": True},
    }
    ok = all(
        bool(check.get("ok")) for check in checks.values() if isinstance(check, dict)
    )
    return new_envelope(
        "doctor",
        "ok" if ok else "issues",
        ok=ok,
        target={"kind": "doctor", "checks": checks},
        error=None
        if ok
        else {"code": "doctor_issues", "message": "one or more prerequisites failed"},
    )


def common_parser() -> WAArgumentParser:
    parser = WAArgumentParser(add_help=False)
    parser.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    parser.add_argument(
        "--socket", default=argparse.SUPPRESS, help="exact tmux socket path"
    )
    parser.add_argument(
        "--runtime-dir", default=argparse.SUPPRESS, help=argparse.SUPPRESS
    )
    parser.add_argument(
        "--config-dir", default=argparse.SUPPRESS, help=argparse.SUPPRESS
    )
    return parser


def build_parser() -> WAArgumentParser:
    common = common_parser()
    parser = WAArgumentParser(
        prog="with-agents",
        description="Observe and act on external Agent CLIs through tmux.",
        parents=[common],
    )
    parser.add_argument("--version", action="version", version=VERSION)
    subparsers = parser.add_subparsers(dest="command", required=True)

    def command(name: str, help_text: str) -> WAArgumentParser:
        return subparsers.add_parser(name, help=help_text, parents=[common])

    read = command("read", "capture a pane snapshot")
    read.add_argument("target")
    read.add_argument("--lines", type=int, default=80)
    read.set_defaults(handler=command_read)

    send = command("send", "submit one complete message")
    send.add_argument("target")
    send.add_argument("--no-header", action="store_true")
    send.add_argument("--request", action="store_true")
    send.add_argument("--correlation-id")
    send.add_argument("--params")
    send.add_argument("message")
    send.set_defaults(handler=command_send)

    listing = command("list", "list panes")
    listing.add_argument("--detail", action="store_true")
    listing.set_defaults(handler=command_list)

    launch = command("launch", "launch an exact argv in a new pane")
    launch.add_argument("--name")
    launch.add_argument("--cwd")
    launch.add_argument("--session")
    launch.add_argument("--split")
    launch.add_argument("--preset")
    launch.add_argument("--name-suffix")
    launch.add_argument("--no-wait", action="store_true")
    launch.add_argument("--ready-timeout", type=float, default=120.0)
    launch.add_argument("argv", nargs=argparse.REMAINDER)
    launch.set_defaults(handler=command_launch)

    wait = command("wait", "wait for one pane change")
    wait.add_argument("target")
    wait.add_argument("--timeout", type=float, default=10.0)
    wait.add_argument("--interval", type=float, default=0.25)
    wait.add_argument("--lines", type=int, default=80)
    wait.set_defaults(handler=command_wait)

    key = command("key", "send explicit tmux key names")
    key.add_argument("target")
    key.add_argument("keys", nargs=argparse.REMAINDER)
    key.set_defaults(handler=command_key)

    close = command("close", "capture and close a pane")
    close.add_argument("target")
    close.add_argument("--lines", type=int, default=120)
    close.set_defaults(handler=command_close)

    preset = command("preset", "manage private launch presets")
    actions = preset.add_subparsers(dest="preset_command", required=True)
    preset_list = actions.add_parser("list", parents=[common])
    preset_list.set_defaults(handler=command_preset_list)
    preset_show = actions.add_parser("show", parents=[common])
    preset_show.add_argument("name")
    preset_show.set_defaults(handler=command_preset_show)
    for action_name, handler in (
        ("save", command_preset_save),
        ("update", command_preset_update),
    ):
        action = actions.add_parser(action_name, parents=[common])
        action.add_argument("name")
        action.add_argument("--agent-type", required=True)
        action.add_argument("--pane-name")
        action.add_argument("--dry-run", action="store_true")
        if action_name == "update":
            action.add_argument("--replace", action="store_true")
        action.add_argument("argv", nargs="*")
        action.set_defaults(handler=handler)
    preset_remove = actions.add_parser("remove", parents=[common])
    preset_remove.add_argument("name")
    preset_remove.set_defaults(handler=command_preset_remove)

    command("doctor", "diagnose prerequisites").set_defaults(handler=command_doctor)

    route = command("route", "print a portable pane route")
    route.add_argument("target", nargs="?")
    route.set_defaults(handler=command_route)
    return parser


def wants_json(argv: list[str]) -> bool:
    try:
        boundary = argv.index("--")
    except ValueError:
        boundary = len(argv)
    return "--json" in argv[:boundary]


def main(argv: list[str] | None = None) -> int:
    values = list(sys.argv[1:] if argv is None else argv)
    if values and values[0] == "_exec":
        if len(values) != 2:
            sys.stderr.write(
                "[with-agents exec error] invalid internal exec invocation\n"
            )
            return 126
        return internal_exec(values[1])
    as_json = wants_json(values)
    event = values[0] if values and not values[0].startswith("-") else "with-agents"
    try:
        args = build_parser().parse_args(values)
        for option, default in (
            ("socket", None),
            ("runtime_dir", None),
            ("config_dir", None),
            ("json", False),
        ):
            if not hasattr(args, option):
                setattr(args, option, default)
        as_json = bool(getattr(args, "json", as_json))
        event = args.command
        if sys.version_info[:2] < MIN_PYTHON:
            raise WAError(
                "python_too_old",
                f"Python {MIN_PYTHON[0]}.{MIN_PYTHON[1]} or newer is required",
            )
        runtime = RuntimeState(args.runtime_dir)
        config = ConfigState(args.config_dir)
        envelope = args.handler(args, runtime, config)
    except WAError as exc:
        envelope = error_envelope(event, exc)
    except KeyboardInterrupt:
        envelope = error_envelope(
            event,
            WAError(
                "interrupted",
                "operation interrupted by the caller",
                stage="interrupted",
            ),
        )
    except Exception as exc:
        envelope = error_envelope(
            event,
            WAError(
                "internal_error",
                f"unexpected controller error: {exc}",
                recovery="Run with-agents doctor and report the JSON error.",
            ),
        )
    emit(envelope, as_json)
    return 0 if envelope["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
