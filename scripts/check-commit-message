#!/usr/bin/env bash
set -euo pipefail

message_file="${1:-}"

if [[ -z "$message_file" || ! -f "$message_file" ]]; then
  echo "commit message file not found" >&2
  exit 1
fi

first_line="$(sed -n '1p' "$message_file")"
pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._-]+\))?!?: .+'

if [[ ! "$first_line" =~ $pattern ]]; then
  echo "commit message must follow Conventional Commits:" >&2
  echo "  <type>[optional scope]: <description>" >&2
  echo "allowed types: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test" >&2
  echo "got: $first_line" >&2
  exit 1
fi
