#!/usr/bin/env python3
"""Low-freedom tmux controller for the with-agents skill.

The executable intentionally uses only the Python standard library and tmux.
It keeps task text out of persistent state, represents launch commands as argv,
and exposes one user-meaningful event per command.
"""

import argparse
import base64
import contextlib
import datetime as dt
import fcntl
import hashlib
import json
import math
import os
from pathlib import Path
import re
import shlex
import shutil
import stat
import subprocess
import sys
import tempfile
import time
from typing import Any, Iterator, NoReturn, Sequence
import unicodedata
import uuid


VERSION = "0.2.0"
MIN_PYTHON = (3, 10)
MIN_TMUX = (3, 2)
MESSAGE_LIMIT = 1024
RESULT_LIMIT = 16 * 1024 * 1024
REQUEST_RESULT_LIMIT = 64 * 1024 * 1024
NONTERMINAL_EVENT_LIMIT = 64
TOTAL_EVENT_LIMIT = NONTERMINAL_EVENT_LIMIT + 1
AUTO_GC_TERMINAL_SECONDS = 7 * 24 * 60 * 60
TMUX_COMMAND_TIMEOUT = 15.0
LOCK_ACQUIRE_TIMEOUT = 15.0
TOP_LEVEL_FIELDS = (
    "ok",
    "event",
    "stage",
    "target",
    "request",
    "notification",
    "screen",
    "error",
    "recovery",
)
REQUEST_ID_RE = re.compile(r"^wa-[0-9]{8}T[0-9]{6}-[0-9a-f]{12}$")
PRESET_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")
PANE_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$")
AGENT_TYPE_RE = re.compile(r"^[a-z0-9]+(?:[._-][a-z0-9]+)*$")
PANE_COMPONENT_RE = re.compile(r"^[A-Za-z0-9]+(?:[._-][A-Za-z0-9]+)*$")
EXECUTABLE_BASENAME_RE = re.compile(r"^[a-z0-9]+(?:[._-][a-z0-9]+)*$")
EVENT_FILENAME_RE = re.compile(r"^(?P<seq>[0-9]{6})\.json$")
EVENT_TEMP_FILENAME_RE = re.compile(r"^\.[0-9]{6}\.json\..+$")
SHA256_RE = re.compile(r"^[0-9a-f]{64}$")
ANSI_RE = re.compile(r"\x1b(?:\[[0-?]*[ -/]*[@-~]|\][^\x07]*(?:\x07|\x1b\\))")
SGR_RE = re.compile(r"\x1b\[([0-9:;]*)m")

BUILTIN_AGENT_DEFINITIONS: dict[str, dict[str, Any]] = {
    "codex": {"pane_prefix": "cx", "executables": ["codex"]},
    "claude": {"pane_prefix": "cc", "executables": ["claude"]},
    "pi": {"pane_prefix": "pi", "executables": ["pi"]},
}
RESERVED_AGENT_TYPES = frozenset(("external", "generic"))
EVENT_STATUS_TERMINAL = {
    "progress": False,
    "question": False,
    "done": True,
    "blocked": True,
    "failed": True,
}


class WAError(Exception):
    """A stable CLI error with enough context for recovery."""

    def __init__(
        self,
        code: str,
        message: str,
        *,
        stage: str = "failed",
        recovery: str | None = None,
        target: dict[str, Any] | None = None,
        request: dict[str, Any] | None = None,
        notification: dict[str, Any] | None = None,
        screen: dict[str, Any] | None = None,
        details: dict[str, Any] | None = None,
    ) -> None:
        super().__init__(message)
        self.code = code
        self.message = message
        self.stage = stage
        self.recovery = recovery
        self.target = target
        self.request = request
        self.notification = notification
        self.screen = screen
        self.details = details or {}


class WAArgumentParser(argparse.ArgumentParser):
    def error(self, message: str) -> NoReturn:
        raise WAError(
            "usage_error",
            message,
            stage="parse",
            recovery=f"Run {self.prog} --help.",
        )


def utc_now() -> dt.datetime:
    return dt.datetime.now(dt.timezone.utc)


def iso_now() -> str:
    return utc_now().isoformat(timespec="seconds")


def canonical_json_bytes(value: Any) -> bytes:
    return (
        json.dumps(value, ensure_ascii=False, sort_keys=True, indent=2) + "\n"
    ).encode("utf-8")


def new_envelope(
    event: str,
    stage: str,
    *,
    ok: bool = True,
    target: dict[str, Any] | None = None,
    request: dict[str, Any] | None = None,
    notification: dict[str, Any] | None = None,
    screen: dict[str, Any] | None = None,
    error: dict[str, Any] | None = None,
    recovery: str | None = None,
) -> dict[str, Any]:
    envelope = {
        "ok": ok,
        "event": event,
        "stage": stage,
        "target": target,
        "request": request,
        "notification": notification,
        "screen": screen,
        "error": error,
        "recovery": recovery,
    }
    if tuple(envelope) != TOP_LEVEL_FIELDS:
        raise RuntimeError("internal JSON envelope field order changed")
    return envelope


def error_envelope(event: str, exc: WAError) -> dict[str, Any]:
    error: dict[str, Any] = {"code": exc.code, "message": exc.message}
    if exc.details:
        error["details"] = exc.details
    return new_envelope(
        event,
        exc.stage,
        ok=False,
        target=exc.target,
        request=exc.request,
        notification=exc.notification,
        screen=exc.screen,
        error=error,
        recovery=exc.recovery,
    )


def render_text(envelope: dict[str, Any]) -> str:
    lines = [f"{envelope['event']}: {envelope['stage']}"]
    target = envelope.get("target") or {}
    if target.get("kind") == "pane":
        label = target.get("name") or target.get("pane_id")
        lines.append(
            f"target={label} pane={target.get('pane_id')} "
            f"at={target.get('session_window_pane')} owned={str(target.get('owned')).lower()}"
        )
        launch = target.get("launch") or {}
        if launch.get("argv"):
            lines.append(f"argv={shlex.join(launch['argv'])}")
        if launch.get("record_path"):
            lines.append(f"record={launch['record_path']}")
        readiness = target.get("readiness") or {}
        if readiness:
            ready = readiness.get("ready_for_send")
            rendered_ready = "unknown" if ready is None else str(bool(ready)).lower()
            lines.append(
                f"readiness=adapter:{readiness.get('adapter')} "
                f"state:{readiness.get('state')} ready_for_send:{rendered_ready}"
            )
        submission = target.get("submission") or {}
        if submission:
            lines.append(
                "submission="
                f"tmux_accepted:{str(bool(submission.get('tmux_accepted'))).lower()} "
                f"tui_acceptance:{submission.get('tui_acceptance')}"
            )
    elif target.get("kind") == "pane-list":
        items = target.get("items", [])
        lines.append("PANE\tLOCATION\tNAME\tPROCESS\tOWNED\tCWD")
        for item in items:
            lines.append(
                "\t".join(
                    [
                        str(item.get("pane_id", "")),
                        str(item.get("session_window_pane", "")),
                        str(item.get("name") or "-"),
                        str(item.get("process") or "-"),
                        str(bool(item.get("owned"))).lower(),
                        str(item.get("cwd") or ""),
                    ]
                )
            )
    elif target.get("kind") == "preset":
        lines.append(f"preset={target.get('name')} path={target.get('path')}")
        if target.get("argv"):
            lines.append(f"argv={shlex.join(target['argv'])}")
        if target.get("digest"):
            lines.append(f"sha256={target['digest']}")
    elif target.get("kind") == "preset-list":
        for item in target.get("items", []):
            lines.append(f"{item['name']}\t{item['path']}")
    elif target:
        for key, value in target.items():
            if key != "kind":
                lines.append(
                    f"{key}={json.dumps(value, ensure_ascii=False, sort_keys=True)}"
                )

    request = envelope.get("request") or {}
    if request.get("request_id"):
        lines.append(f"request={request['request_id']}")
    for key in ("phase", "status", "message", "result_path", "ticket_path"):
        if request.get(key) is not None:
            lines.append(f"{key}={request[key]}")
    result = request.get("result") or {}
    if result.get("path"):
        lines.append(f"result_path={result['path']}")
    if "stop_polling" in request:
        lines.append(f"stop_polling={str(bool(request['stop_polling'])).lower()}")
    for key in ("removed", "stale"):
        if request.get(key) is not None:
            lines.append(
                f"{key}={json.dumps(request[key], ensure_ascii=False, sort_keys=True)}"
            )
    if "notify_mode" in request:
        lines.append(
            f"notify={request.get('notify_mode')} "
            f"armed={str(bool(request.get('notify_armed'))).lower()}"
        )
    if request.get("items") is not None:
        for item in request["items"]:
            line = f"{item['request_id']}\t{item['state']}"
            if item.get("status"):
                line += f"\t{item['status']}"
            if item.get("message"):
                line += f"\t{item['message']}"
            if item.get("result_path"):
                line += f"\t{item['result_path']}"
            item_notification = item.get("notification") or {}
            if item_notification.get("reason"):
                line += f"\tnotify:{item_notification['reason']}"
            lines.append(line)

    notification = envelope.get("notification") or {}
    if notification:
        lines.append(
            "notification="
            f"spooled:{str(bool(notification.get('spooled'))).lower()} "
            f"attempted:{str(bool(notification.get('injection_attempted'))).lower()} "
            f"tmux_accepted:{str(bool(notification.get('tmux_accepted'))).lower()} "
            f"reason:{notification.get('reason')}"
        )

    error = envelope.get("error") or {}
    if error:
        lines.append(f"error={error.get('code')}: {error.get('message')}")
        if error.get("details"):
            lines.append(
                "details="
                + json.dumps(error["details"], ensure_ascii=False, sort_keys=True)
            )
    if envelope.get("recovery"):
        lines.append(f"recovery={envelope['recovery']}")
    screen = envelope.get("screen") or {}
    if screen.get("tail") is not None:
        lines.append("--- screen ---")
        lines.append(screen["tail"])
    return "\n".join(lines).rstrip() + "\n"


def emit(envelope: dict[str, Any], as_json: bool) -> None:
    output = (
        json.dumps(envelope, ensure_ascii=False, sort_keys=False, indent=2) + "\n"
        if as_json
        else render_text(envelope)
    )
    stream = sys.stdout if envelope["ok"] else sys.stderr
    stream.write(output)


def ensure_private_dir(path: Path) -> Path:
    if path.is_symlink():
        raise WAError("unsafe_state_path", f"state directory is a symlink: {path}")
    path.mkdir(mode=0o700, parents=True, exist_ok=True)
    info = path.stat()
    if not stat.S_ISDIR(info.st_mode) or info.st_uid != os.getuid():
        raise WAError(
            "unsafe_state_path",
            f"state directory is not a current-user-owned directory: {path}",
        )
    if stat.S_IMODE(info.st_mode) != 0o700:
        path.chmod(0o700)
    return path


def safe_read_json(path: Path) -> dict[str, Any]:
    try:
        info = path.lstat()
    except FileNotFoundError as exc:
        raise WAError("state_not_found", f"state file does not exist: {path}") from exc
    if not stat.S_ISREG(info.st_mode) or stat.S_ISLNK(info.st_mode):
        raise WAError("unsafe_state_path", f"state file is not a regular file: {path}")
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise WAError("invalid_state", f"cannot read JSON state {path}: {exc}") from exc
    if not isinstance(value, dict):
        raise WAError("invalid_state", f"JSON state is not an object: {path}")
    return value


def atomic_write_json(
    path: Path, value: dict[str, Any], *, exclusive: bool = False
) -> None:
    ensure_private_dir(path.parent)
    data = canonical_json_bytes(value)
    if exclusive:
        fd, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
        temporary_path = Path(temporary)
        try:
            with os.fdopen(fd, "wb") as handle:
                os.fchmod(handle.fileno(), 0o600)
                handle.write(data)
                handle.flush()
                os.fsync(handle.fileno())
            try:
                os.link(temporary_path, path, follow_symlinks=False)
            except FileExistsError as exc:
                raise WAError(
                    "state_exists", f"refusing to overwrite existing state: {path}"
                ) from exc
        finally:
            with contextlib.suppress(FileNotFoundError):
                temporary_path.unlink()
        return

    fd, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    temporary_path = Path(temporary)
    try:
        with os.fdopen(fd, "wb") as handle:
            os.fchmod(handle.fileno(), 0o600)
            handle.write(data)
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary_path, path)
    finally:
        with contextlib.suppress(FileNotFoundError):
            temporary_path.unlink()


def xdg_directory(name: str, fallback: Path | None) -> Path | None:
    raw = os.environ.get(name)
    if raw:
        candidate = Path(raw).expanduser()
        if candidate.is_absolute():
            return candidate
    return fallback


class RuntimeState:
    def __init__(self, override: str | None = None) -> None:
        if override:
            self.root = Path(override).expanduser().absolute()
            self.fallback = False
            self.source = "override"
        elif os.environ.get("WITH_AGENTS_RUNTIME_DIR"):
            self.root = (
                Path(os.environ["WITH_AGENTS_RUNTIME_DIR"]).expanduser().absolute()
            )
            self.fallback = False
            self.source = "environment"
        elif runtime_home := xdg_directory("XDG_RUNTIME_DIR", None):
            self.root = runtime_home / "with-agents"
            self.fallback = False
            self.source = "xdg-runtime"
        else:
            state_home = xdg_directory(
                "XDG_STATE_HOME", Path.home() / ".local" / "state"
            )
            assert state_home is not None
            self.root = state_home / "with-agents"
            self.fallback = True
            self.source = "xdg-state-fallback"
        ensure_private_dir(self.root)
        self.panes = ensure_private_dir(self.root / "panes")
        self.observations = ensure_private_dir(self.root / "observations")
        self.locks = ensure_private_dir(self.root / "locks")
        self.requests = ensure_private_dir(self.root / "requests")
        if self.fallback:
            self.auto_gc_terminal()

    def auto_gc_terminal(self) -> None:
        cutoff = time.time() - AUTO_GC_TERMINAL_SECONDS
        for directory in list_request_dirs(self):
            try:
                with request_lock(self, directory, timeout=0.0):
                    if not directory.is_dir():
                        continue
                    record, directory = load_request(self, directory.name)
                    facts = request_gc_facts(record, directory)
                    if facts["terminal"] and facts["retention_epoch"] < cutoff:
                        safe_remove_request_dir(self, directory)
            except WAError as exc:
                if exc.code == "lock_timeout":
                    continue
                # Corrupted or partially written requests are never auto-deleted.
                continue


class ConfigState:
    def __init__(self, override: str | None = None) -> None:
        if override:
            root = Path(override).expanduser().absolute()
        elif os.environ.get("WITH_AGENTS_CONFIG_DIR"):
            root = Path(os.environ["WITH_AGENTS_CONFIG_DIR"]).expanduser().absolute()
        else:
            config_home = xdg_directory("XDG_CONFIG_HOME", Path.home() / ".config")
            assert config_home is not None
            root = config_home / "with-agents"
        self.root = root

    @property
    def agent_config(self) -> Path:
        return self.root / "config.json"

    @property
    def presets(self) -> Path:
        path = self.root / "presets"
        if self.root.exists() or self.root.is_symlink():
            ensure_private_dir(self.root)
        if path.exists() or path.is_symlink():
            ensure_private_dir(path)
        return path

    def validate_existing_presets(self) -> Path:
        return self.presets

    def ensure_presets(self) -> Path:
        root = ensure_private_dir(self.root)
        return ensure_private_dir(root / "presets")


def invalid_agent_config(path: Path, message: str) -> WAError:
    return WAError(
        "invalid_agent_config",
        f"invalid Agent configuration {path}: {message}",
        stage="preflight",
        recovery="Fix or atomically replace config.json, then run with-agents doctor.",
        details={"path": str(path)},
    )


def validate_agent_type(value: Any, *, path: Path) -> str:
    if not isinstance(value, str) or AGENT_TYPE_RE.fullmatch(value) is None:
        raise invalid_agent_config(path, f"invalid agent type: {value!r}")
    if value in RESERVED_AGENT_TYPES:
        raise invalid_agent_config(path, f"reserved agent type: {value}")
    return value


def validate_pane_component(value: Any, *, field: str, path: Path) -> str:
    if (
        not isinstance(value, str)
        or len(value) > 64
        or PANE_COMPONENT_RE.fullmatch(value) is None
    ):
        raise invalid_agent_config(path, f"{field} is not a valid pane-name component")
    return value


def normalize_executable_basename(value: Any, *, path: Path) -> str:
    if not isinstance(value, str) or not value or "/" in value or "\\" in value:
        raise invalid_agent_config(
            path, "executables must contain basenames, not paths"
        )
    normalized = value.lower().removesuffix(".exe")
    if EXECUTABLE_BASENAME_RE.fullmatch(normalized) is None:
        raise invalid_agent_config(path, f"invalid executable basename: {value!r}")
    return normalized


def builtin_agent_registry() -> dict[str, dict[str, Any]]:
    return {
        agent_type: {
            "pane_prefix": definition["pane_prefix"],
            "executables": list(definition["executables"]),
        }
        for agent_type, definition in BUILTIN_AGENT_DEFINITIONS.items()
    }


def validate_agent_registry(
    registry: dict[str, dict[str, Any]], *, path: Path
) -> dict[str, dict[str, Any]]:
    executable_owners: dict[str, str] = {}
    normalized: dict[str, dict[str, Any]] = {}
    for raw_agent_type, raw_definition in registry.items():
        agent_type = validate_agent_type(raw_agent_type, path=path)
        prefix = validate_pane_component(
            raw_definition.get("pane_prefix"),
            field=f"agents.{agent_type}.pane_prefix",
            path=path,
        )
        raw_executables = raw_definition.get("executables")
        if not isinstance(raw_executables, list) or not raw_executables:
            raise invalid_agent_config(
                path, f"agents.{agent_type}.executables must be a non-empty array"
            )
        executables: list[str] = []
        for value in raw_executables:
            executable = normalize_executable_basename(value, path=path)
            owner = executable_owners.get(executable)
            if owner is not None:
                raise invalid_agent_config(
                    path,
                    f"executable {executable!r} belongs to both {owner!r} and {agent_type!r}",
                )
            executable_owners[executable] = agent_type
            executables.append(executable)
        normalized[agent_type] = {
            "pane_prefix": prefix,
            "executables": executables,
        }
    return normalized


def load_agent_registry(config: ConfigState) -> dict[str, dict[str, Any]]:
    path = config.agent_config
    if config.root.is_symlink():
        raise invalid_agent_config(path, "configuration directory is a symlink")
    if not config.root.exists():
        return validate_agent_registry(builtin_agent_registry(), path=path)
    try:
        ensure_private_dir(config.root)
    except WAError as exc:
        raise invalid_agent_config(path, exc.message) from exc
    if not path.exists() and not path.is_symlink():
        return validate_agent_registry(builtin_agent_registry(), path=path)
    try:
        value = safe_read_json(path)
    except WAError as exc:
        raise invalid_agent_config(path, exc.message) from exc
    if set(value) != {"version", "agents"}:
        raise invalid_agent_config(
            path, "top-level fields must be exactly version and agents"
        )
    if value.get("version") != 1 or isinstance(value.get("version"), bool):
        raise invalid_agent_config(path, "unsupported version")
    overrides = value.get("agents")
    if not isinstance(overrides, dict):
        raise invalid_agent_config(path, "agents must be an object")
    registry = builtin_agent_registry()
    for raw_agent_type, raw_override in overrides.items():
        agent_type = validate_agent_type(raw_agent_type, path=path)
        if not isinstance(raw_override, dict):
            raise invalid_agent_config(path, f"agents.{agent_type} must be an object")
        unknown = set(raw_override) - {"pane_prefix", "executables"}
        if unknown:
            raise invalid_agent_config(
                path,
                f"agents.{agent_type} has unknown fields: {', '.join(sorted(unknown))}",
            )
        if agent_type not in registry and set(raw_override) != {
            "pane_prefix",
            "executables",
        }:
            raise invalid_agent_config(
                path,
                f"new agent {agent_type!r} requires pane_prefix and executables",
            )
        merged = dict(registry.get(agent_type, {}))
        if "pane_prefix" in raw_override:
            merged["pane_prefix"] = raw_override["pane_prefix"]
        if "executables" in raw_override:
            merged["executables"] = raw_override["executables"]
        registry[agent_type] = merged
    return validate_agent_registry(registry, path=path)


def list_request_dirs(runtime: RuntimeState) -> list[Path]:
    result: list[Path] = []
    for path in runtime.requests.iterdir():
        if (
            path.is_symlink()
            or not path.is_dir()
            or not REQUEST_ID_RE.fullmatch(path.name)
        ):
            continue
        result.append(path)
    return sorted(result)


def safe_remove_request_dir(runtime: RuntimeState, request_dir: Path) -> None:
    try:
        resolved_parent = request_dir.resolve().parent
    except FileNotFoundError:
        return
    if (
        request_dir.is_symlink()
        or resolved_parent != runtime.requests.resolve()
        or not REQUEST_ID_RE.fullmatch(request_dir.name)
    ):
        raise WAError(
            "unsafe_state_path", f"refusing to remove request path: {request_dir}"
        )
    shutil.rmtree(request_dir)
    with contextlib.suppress(FileNotFoundError):
        request_lock_path(runtime, request_dir).unlink()


class TmuxClient:
    PANE_FORMAT = "\t".join(
        [
            "#{socket_path}",
            "#{pid}",
            "#{pane_id}",
            "#{pane_pid}",
            "#{pane_dead}",
            "#{pane_dead_status}",
            "#{@with_agents_owner}",
            "#{@with_agents_run_id}",
            "#{@with_agents_name}",
            "#{@with_agents_preset}",
            "#{session_name}",
            "#{window_index}",
            "#{pane_index}",
            "#{pane_current_command}",
            "#{pane_current_path}",
            "#{pane_title}",
        ]
    )

    def __init__(self, explicit_socket: str | None = None) -> None:
        self.inherits_caller = False
        if explicit_socket:
            self.socket_hint = explicit_socket
        elif os.environ.get("TMUX"):
            self.socket_hint = os.environ["TMUX"].split(",", 1)[0]
            self.inherits_caller = True
        else:
            self.socket_hint = None
        self._server: dict[str, Any] | None = None

    @property
    def prefix(self) -> list[str]:
        command = ["tmux"]
        if self.socket_hint:
            command.extend(["-S", self.socket_hint])
        return command

    def run(
        self,
        arguments: Sequence[str],
        *,
        input_text: str | None = None,
        stage: str = "tmux",
        check: bool = True,
    ) -> subprocess.CompletedProcess[str]:
        command = [*self.prefix, *arguments]
        try:
            completed = subprocess.run(
                command,
                input=input_text,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=TMUX_COMMAND_TIMEOUT,
                check=False,
            )
        except FileNotFoundError as exc:
            raise WAError(
                "tmux_unavailable",
                "tmux is not installed or is not on PATH",
                stage=stage,
                recovery="Install tmux or read references/tmux-recovery.md.",
            ) from exc
        except subprocess.TimeoutExpired as exc:
            raise WAError(
                "tmux_timeout",
                f"tmux did not respond within {TMUX_COMMAND_TIMEOUT:g} seconds",
                stage=stage,
                recovery="Run with-agents doctor; do not retry a potentially partial send blindly.",
                details={"tmux_args": list(arguments)},
            ) from exc
        if check and completed.returncode != 0:
            stderr = completed.stderr.strip() or "tmux command failed"
            raise WAError(
                "tmux_command_failed",
                stderr,
                stage=stage,
                recovery="Run with-agents doctor, then inspect the target with read.",
                details={
                    "tmux_args": list(arguments),
                    "returncode": completed.returncode,
                },
            )
        return completed

    def server(self) -> dict[str, Any]:
        if self._server is None:
            output = self.run(
                ["display-message", "-p", "#{socket_path}\t#{pid}"],
                stage="server_identity",
            ).stdout.rstrip("\n")
            parts = output.split("\t", 1)
            socket_path = (
                parts[0] if parts and parts[0] else self.socket_hint or "default"
            )
            server_pid = (
                int(parts[1]) if len(parts) > 1 and parts[1].isdigit() else None
            )
            self._server = {"socket_path": socket_path, "server_pid": server_pid}
        return dict(self._server)

    def parse_pane(self, line: str) -> dict[str, Any]:
        fields = line.rstrip("\n").split("\t")
        if len(fields) < 16:
            fields.extend([""] * (16 - len(fields)))
        (
            socket_path,
            server_pid,
            pane_id,
            pane_pid,
            dead,
            dead_status,
            owner,
            run_id,
            name,
            preset,
            session,
            window_index,
            pane_index,
            process,
            cwd,
            title,
        ) = fields[:16]
        pane = {
            "kind": "pane",
            "socket_path": socket_path or self.socket_hint or "default",
            "server_pid": int(server_pid) if server_pid.isdigit() else None,
            "pane_id": pane_id,
            "pane_pid": int(pane_pid) if pane_pid.isdigit() else None,
            "session": session,
            "window_index": window_index,
            "pane_index": pane_index,
            "session_window_pane": f"{session}:{window_index}.{pane_index}",
            "process": process,
            "cwd": cwd,
            "dead": dead == "1",
            "dead_status": int(dead_status)
            if dead_status.lstrip("-").isdigit()
            else None,
            "owned": owner == "1",
            "run_id": run_id or None,
            "name": name or None,
            "preset": preset or None,
            "title": title or None,
        }
        return pane

    def list_panes(self) -> list[dict[str, Any]]:
        completed = self.run(["list-panes", "-a", "-F", self.PANE_FORMAT], stage="list")
        return [self.parse_pane(line) for line in completed.stdout.splitlines() if line]

    def pane(self, target: str) -> dict[str, Any]:
        completed = self.run(
            ["display-message", "-p", "-t", target, self.PANE_FORMAT],
            stage="resolve_target",
            check=False,
        )
        if completed.returncode != 0 or not completed.stdout.strip():
            raise WAError(
                "target_not_found",
                f"cannot resolve pane target: {target}",
                stage="resolve_target",
                recovery="Run with-agents list and choose an unambiguous pane ID or name.",
            )
        return self.parse_pane(completed.stdout)

    def resolve(self, target: str) -> dict[str, Any]:
        if target.startswith("%") or ":" in target:
            return self.pane(target)
        matches = [
            pane
            for pane in self.list_panes()
            if pane.get("name") == target or pane.get("run_id") == target
        ]
        if len(matches) == 1:
            return matches[0]
        if len(matches) > 1:
            raise WAError(
                "target_ambiguous",
                f"multiple panes match target: {target}",
                stage="resolve_target",
                recovery="Use the exact %pane-id from with-agents list.",
            )
        return self.pane(target)

    def capture(
        self, pane_id: str, lines: int = 80, *, preserve_escape: bool = False
    ) -> str:
        arguments = ["capture-pane", "-p"]
        if preserve_escape:
            arguments.append("-e")
        arguments.extend(["-J", "-t", pane_id, "-S", f"-{lines}"])
        completed = self.run(
            arguments,
            stage="capture",
        )
        return completed.stdout.rstrip("\n")

    def list_sessions(self) -> list[str]:
        completed = self.run(
            ["list-sessions", "-F", "#{session_name}"],
            stage="list_sessions",
            check=False,
        )
        if completed.returncode != 0:
            return []
        return [line for line in completed.stdout.splitlines() if line]


def public_pane(pane: dict[str, Any]) -> dict[str, Any]:
    allowed = (
        "kind",
        "socket_path",
        "server_pid",
        "pane_id",
        "pane_pid",
        "session",
        "window_index",
        "pane_index",
        "session_window_pane",
        "process",
        "cwd",
        "dead",
        "dead_status",
        "owned",
        "run_id",
        "name",
        "preset",
        "title",
    )
    return {key: pane.get(key) for key in allowed}


def screen_object(text: str, lines: int) -> dict[str, Any]:
    return {"tail": text, "lines": lines}


def identity_of(pane: dict[str, Any]) -> dict[str, Any]:
    return {
        "socket_path": pane.get("socket_path"),
        "server_pid": pane.get("server_pid"),
        "pane_id": pane.get("pane_id"),
        "pane_pid": pane.get("pane_pid"),
        "run_id": pane.get("run_id") if pane.get("owned") else None,
    }


def identity_matches(expected: dict[str, Any], current: dict[str, Any]) -> bool:
    actual = identity_of(current)
    for field in ("socket_path", "server_pid", "pane_id", "pane_pid"):
        if expected.get(field) != actual.get(field):
            return False
    if expected.get("run_id") is not None and expected.get("run_id") != actual.get(
        "run_id"
    ):
        return False
    return True


def caller_key() -> str:
    pane = os.environ.get("TMUX_PANE")
    if pane:
        socket = os.environ.get("TMUX", "").split(",", 1)[0]
        try:
            caller = TmuxClient(socket or None).pane(pane)
            identity = identity_of(caller)
            return "tmux:" + stable_key(
                identity.get("socket_path"),
                identity.get("server_pid"),
                identity.get("pane_id"),
                identity.get("pane_pid"),
                identity.get("run_id"),
            )
        except WAError as exc:
            raise WAError(
                "caller_identity_unavailable",
                "cannot establish the tmux caller identity for an observation",
                stage="observation",
                recovery="Restore the caller tmux server before observing or writing.",
            ) from exc
    explicit = os.environ.get("WITH_AGENTS_CALLER_ID")
    if explicit:
        return f"external-explicit:{explicit}"
    return f"external-default:{os.getuid()}"


def stable_key(*parts: Any) -> str:
    material = "\x00".join(str(part) for part in parts)
    return hashlib.sha256(material.encode("utf-8")).hexdigest()[:32]


def observation_path(
    runtime: RuntimeState, pane: dict[str, Any], caller: str | None = None
) -> Path:
    key = stable_key(
        pane.get("socket_path"),
        pane.get("server_pid"),
        pane.get("pane_id"),
        caller or caller_key(),
    )
    return runtime.observations / f"{key}.json"


def mark_observed(runtime: RuntimeState, pane: dict[str, Any]) -> None:
    caller = caller_key()
    atomic_write_json(
        observation_path(runtime, pane, caller),
        {
            "version": 1,
            "observed_at": iso_now(),
            "caller_key": caller,
            "identity": identity_of(pane),
        },
    )


def require_observed(runtime: RuntimeState, pane: dict[str, Any]) -> Path:
    caller = caller_key()
    path = observation_path(runtime, pane, caller)
    if not path.is_file():
        raise WAError(
            "observation_required",
            f"pane {pane['pane_id']} must be observed before interaction",
            stage="preflight",
            recovery=f"Run with-agents read {pane['pane_id']}.",
            target=public_pane(pane),
        )
    observed = safe_read_json(path)
    expected = observed.get("identity")
    if (
        observed.get("caller_key") != caller
        or not isinstance(expected, dict)
        or not identity_matches(expected, pane)
    ):
        with contextlib.suppress(FileNotFoundError):
            path.unlink()
        raise WAError(
            "observation_expired",
            f"pane identity changed after the last observation: {pane['pane_id']}",
            stage="preflight",
            recovery=f"Run with-agents read {pane['pane_id']} again.",
            target=public_pane(pane),
        )
    return path


def consume_observation_path(path: Path) -> None:
    with contextlib.suppress(FileNotFoundError):
        path.unlink()


@contextlib.contextmanager
def pane_lock(runtime: RuntimeState, pane: dict[str, Any]) -> Iterator[None]:
    key = stable_key(
        pane.get("socket_path"), pane.get("server_pid"), pane.get("pane_id")
    )
    path = runtime.locks / f"pane-{key}.lock"
    descriptor = os.open(path, os.O_RDWR | os.O_CREAT, 0o600)
    try:
        os.fchmod(descriptor, 0o600)
        acquire_lock(descriptor, f"pane {pane.get('pane_id')}")
        yield
    finally:
        fcntl.flock(descriptor, fcntl.LOCK_UN)
        os.close(descriptor)


@contextlib.contextmanager
def request_lock(
    runtime: RuntimeState,
    request_dir: Path,
    *,
    timeout: float = LOCK_ACQUIRE_TIMEOUT,
) -> Iterator[None]:
    # The lock must survive deletion of the request directory. Keeping it under
    # runtime/locks makes reply, inbox, and GC synchronize on the same inode even
    # while GC removes the ticket itself.
    path = request_lock_path(runtime, request_dir)
    descriptor = os.open(path, os.O_RDWR | os.O_CREAT, 0o600)
    try:
        os.fchmod(descriptor, 0o600)
        acquire_lock(descriptor, f"request {request_dir.name}", timeout=timeout)
        yield
    finally:
        fcntl.flock(descriptor, fcntl.LOCK_UN)
        os.close(descriptor)


def request_lock_path(runtime: RuntimeState, request_dir: Path) -> Path:
    key = stable_key(request_dir.name)
    return runtime.locks / f"request-{key}.lock"


def acquire_lock(
    descriptor: int, label: str, *, timeout: float = LOCK_ACQUIRE_TIMEOUT
) -> None:
    deadline = time.monotonic() + timeout
    while True:
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
            return
        except BlockingIOError:
            if time.monotonic() >= deadline:
                raise WAError(
                    "lock_timeout",
                    f"timed out waiting for {label} input lock",
                    stage="lock",
                    recovery="Inspect the existing with-agents operation before retrying.",
                )
            time.sleep(0.05)


def owned_record_path(runtime: RuntimeState, run_id: str) -> Path:
    return runtime.panes / f"{run_id}.json"


def load_owned_record(
    runtime: RuntimeState, pane: dict[str, Any]
) -> dict[str, Any] | None:
    run_id = pane.get("run_id")
    if not pane.get("owned") or not run_id:
        return None
    path = owned_record_path(runtime, run_id)
    if not path.is_file():
        return None
    record = safe_read_json(path)
    identity = record.get("identity")
    if not isinstance(identity, dict) or not identity_matches(identity, pane):
        return None
    return record


def save_owned_record(
    runtime: RuntimeState,
    pane: dict[str, Any],
    *,
    argv: list[str],
    cwd: str,
    name: str,
    preset: str | None,
    created_at: str | None = None,
) -> Path:
    run_id = pane.get("run_id")
    if not run_id:
        raise WAError("invalid_owned_state", "owned pane has no run ID")
    path = owned_record_path(runtime, run_id)
    atomic_write_json(
        path,
        {
            "version": 1,
            "run_id": run_id,
            "created_at": created_at or iso_now(),
            "updated_at": iso_now(),
            "identity": identity_of(pane),
            "name": name,
            "cwd": cwd,
            "preset": preset,
            "argv": argv,
        },
    )
    return path


def validate_pane_name(name: str) -> str:
    if not PANE_NAME_RE.fullmatch(name):
        raise WAError(
            "invalid_pane_name",
            "pane name must be 1-64 ASCII letters, digits, dots, underscores, or hyphens",
            stage="preflight",
        )
    return name


def validate_pane_name_suffix(suffix: str) -> str:
    if len(suffix) > 64 or PANE_COMPONENT_RE.fullmatch(suffix) is None:
        raise WAError(
            "invalid_pane_name",
            "pane name suffix must be 1-64 restricted ASCII characters without repeated separators",
            stage="preflight",
        )
    return suffix


def validate_preset_name(name: str) -> str:
    if not PRESET_NAME_RE.fullmatch(name):
        raise WAError(
            "invalid_preset_name",
            "preset name must be 1-64 ASCII letters, digits, dots, underscores, or hyphens",
            stage="preflight",
        )
    return name


def validate_cwd(value: str | None) -> str:
    path = Path(value or os.getcwd()).expanduser().resolve()
    if not path.is_dir():
        raise WAError("cwd_not_found", f"working directory does not exist: {path}")
    return str(path)


def validate_message(value: str) -> str:
    if not value:
        raise WAError("empty_message", "message must not be empty", stage="preflight")
    if any(
        unicodedata.category(character) == "Cc" and character != "\n"
        for character in value
    ):
        raise WAError(
            "unsafe_message",
            "message contains a control character other than newline",
            stage="preflight",
        )
    return value


def ensure_not_self(_client: TmuxClient, pane: dict[str, Any]) -> None:
    caller = os.environ.get("TMUX_PANE")
    if not caller or pane.get("pane_id") != caller:
        return
    caller_socket = os.environ.get("TMUX", "").split(",", 1)[0] or None
    try:
        caller_pane = TmuxClient(caller_socket).pane(caller)
    except WAError as exc:
        raise WAError(
            "self_target_unverified",
            "cannot prove that a same-ID target is different from the caller pane",
            stage="preflight",
            recovery="Resolve the caller and target tmux servers before retrying.",
            target=public_pane(pane),
        ) from exc
    if identity_matches(identity_of(caller_pane), pane):
        raise WAError(
            "self_target_denied",
            "refusing to mutate the caller's own pane",
            stage="preflight",
            target=public_pane(pane),
        )


def require_writable_target(
    runtime: RuntimeState,
    client: TmuxClient,
    pane: dict[str, Any],
    *,
    allow_foreign: bool,
) -> Path:
    ensure_not_self(client, pane)
    observation = require_observed(runtime, pane)
    if pane.get("dead"):
        raise WAError(
            "target_process_exited",
            f"pane {pane['pane_id']} has no live target process",
            stage="preflight",
            recovery="Inspect the screen, then restart or close the pane.",
            target=public_pane(pane),
        )
    if not pane.get("owned") and not allow_foreign:
        raise WAError(
            "foreign_write_denied",
            f"pane {pane['pane_id']} is not owned by with-agents",
            stage="preflight",
            recovery="Read it, then repeat with --allow-foreign only when that pane is in scope.",
            target=public_pane(pane),
        )
    return observation


def set_owned_metadata(
    client: TmuxClient,
    pane_id: str,
    *,
    name: str,
    run_id: str,
    preset: str | None,
) -> None:
    options = {
        "@with_agents_run_id": run_id,
        "@with_agents_owner": "1",
        "@with_agents_name": name,
        "@with_agents_preset": preset or "",
    }
    for option, value in options.items():
        client.run(["set-option", "-p", "-t", pane_id, option, value], stage="metadata")
    client.run(
        ["set-option", "-p", "-t", pane_id, "remain-on-exit", "on"], stage="metadata"
    )
    client.run(["select-pane", "-t", pane_id, "-T", name], stage="metadata")


def choose_new_pane(
    client: TmuxClient,
    *,
    name: str,
    cwd: str,
    session: str | None,
    split: str | None,
) -> str:
    if split and session:
        raise WAError(
            "layout_source_conflict",
            "do not combine --session with --split",
            stage="preflight",
        )
    sessions = client.list_sessions()
    if split:
        split_pane = client.resolve(split)
        return client.run(
            [
                "split-window",
                "-d",
                "-P",
                "-F",
                "#{pane_id}",
                "-t",
                split_pane["pane_id"],
                "-c",
                cwd,
            ],
            stage="create",
        ).stdout.strip()

    selected_session = session
    if (
        selected_session is None
        and client.inherits_caller
        and os.environ.get("TMUX_PANE")
    ):
        with contextlib.suppress(WAError):
            selected_session = client.pane(os.environ["TMUX_PANE"])["session"]
    if selected_session is not None:
        if selected_session not in sessions:
            raise WAError(
                "session_not_found",
                f"tmux session does not exist: {selected_session}",
                recovery="Run with-agents list or omit --session when no server session exists.",
            )
        return client.run(
            [
                "new-window",
                "-d",
                "-P",
                "-F",
                "#{pane_id}",
                "-t",
                f"{selected_session}:",
                "-n",
                name,
                "-c",
                cwd,
            ],
            stage="create",
        ).stdout.strip()
    if len(sessions) == 1:
        return client.run(
            [
                "new-window",
                "-d",
                "-P",
                "-F",
                "#{pane_id}",
                "-t",
                f"{sessions[0]}:",
                "-n",
                name,
                "-c",
                cwd,
            ],
            stage="create",
        ).stdout.strip()
    if len(sessions) > 1:
        raise WAError(
            "session_required",
            "multiple tmux sessions are available outside a resolvable caller session",
            recovery="Choose one with --session or choose an existing pane with --split.",
            details={"sessions": sessions},
        )
    generated_session = "with-agents"
    suffix = 1
    while generated_session in sessions:
        suffix += 1
        generated_session = f"with-agents-{suffix}"
    return client.run(
        [
            "new-session",
            "-d",
            "-P",
            "-F",
            "#{pane_id}",
            "-s",
            generated_session,
            "-n",
            name,
            "-c",
            cwd,
        ],
        stage="create",
    ).stdout.strip()


def argv_from_remainder(values: list[str]) -> list[str]:
    argv = list(values)
    if argv and argv[0] == "--":
        argv.pop(0)
    if not argv:
        raise WAError(
            "launch_argv_required",
            "an executable argv is required after --",
            stage="preflight",
        )
    if any("\x00" in item for item in argv):
        raise WAError("invalid_argv", "argv contains a NUL byte", stage="preflight")
    return argv


def exec_payload(argv: list[str]) -> str:
    encoded = base64.urlsafe_b64encode(json.dumps(argv).encode("utf-8")).decode("ascii")
    helper = [sys.executable, str(Path(__file__).resolve()), "_exec", encoded]
    return "exec " + shlex.join(helper)


def internal_exec(payload: str) -> int:
    argv: list[str] = []
    try:
        decoded = json.loads(base64.urlsafe_b64decode(payload.encode("ascii")))
        if (
            not isinstance(decoded, list)
            or not decoded
            or not all(isinstance(item, str) for item in decoded)
        ):
            raise ValueError("payload is not a non-empty string argv")
        argv = decoded
        os.execvp(argv[0], argv)
    except FileNotFoundError:
        sys.stderr.write(f"[with-agents exec error] executable not found: {argv[0]}\n")
        return 127
    except Exception as exc:
        sys.stderr.write(f"[with-agents exec error] {exc}\n")
        return 126
    return 126


def create_owned_shell(
    runtime: RuntimeState,
    client: TmuxClient,
    *,
    name: str,
    cwd: str,
    session: str | None,
    split: str | None,
) -> tuple[dict[str, Any], Path]:
    validate_pane_name(name)
    pane_id = choose_new_pane(client, name=name, cwd=cwd, session=session, split=split)
    run_id = f"run-{uuid.uuid4().hex}"
    try:
        set_owned_metadata(client, pane_id, name=name, run_id=run_id, preset=None)
        pane = client.pane(pane_id)
        path = save_owned_record(
            runtime, pane, argv=[], cwd=cwd, name=name, preset=None
        )
        return pane, path
    except BaseException:
        with contextlib.suppress(WAError):
            client.run(["kill-pane", "-t", pane_id], stage="rollback", check=False)
        raise


def launch_in_new_pane(
    runtime: RuntimeState,
    client: TmuxClient,
    *,
    name: str,
    cwd: str,
    session: str | None,
    split: str | None,
    argv: list[str],
    preset: str | None,
) -> tuple[dict[str, Any], dict[str, Any], Path]:
    validate_pane_name(name)
    pane_id = choose_new_pane(client, name=name, cwd=cwd, session=session, split=split)
    run_id = f"run-{uuid.uuid4().hex}"
    try:
        set_owned_metadata(client, pane_id, name=name, run_id=run_id, preset=preset)
        client.run(
            ["respawn-pane", "-k", "-t", pane_id, "-c", cwd, exec_payload(argv)],
            stage="launch",
        )
    except BaseException:
        with contextlib.suppress(WAError):
            client.run(["kill-pane", "-t", pane_id], stage="rollback", check=False)
        raise
    pane: dict[str, Any] = {"kind": "pane", "pane_id": pane_id}
    path: Path | None = None
    try:
        time.sleep(0.2)
        pane = client.pane(pane_id)
        path = save_owned_record(
            runtime, pane, argv=argv, cwd=cwd, name=name, preset=preset
        )
        screen = screen_object(client.capture(pane_id, 80), 80)
        mark_observed(runtime, pane)
    except WAError as exc:
        exc.stage = "launch_state_unknown"
        exc.recovery = (
            "The pane exists; resolve and read it before sending or restarting."
        )
        exc.target = {
            **public_pane(pane),
            "launch": {
                "argv": argv,
                "record_path": str(path) if path is not None else None,
                "preset": preset,
            },
        }
        raise
    except KeyboardInterrupt as exc:
        raise WAError(
            "interrupted",
            "launch was interrupted after the pane process was started",
            stage="launch_state_unknown",
            recovery="The pane exists; resolve and read it before sending or restarting.",
            target={
                **public_pane(pane),
                "launch": {
                    "argv": argv,
                    "record_path": str(path) if path is not None else None,
                    "preset": preset,
                },
            },
        ) from exc
    assert path is not None
    if pane.get("dead"):
        code = (
            "executable_not_found"
            if pane.get("dead_status") == 127
            else "launch_process_exited"
        )
        raise WAError(
            code,
            f"launched process exited with status {pane.get('dead_status')}",
            stage="process_exited",
            recovery=f"Inspect the screen, then run with-agents restart {name} -- <correct argv>.",
            target={
                **public_pane(pane),
                "launch": {"argv": argv, "record_path": str(path), "preset": preset},
            },
            screen=screen,
        )
    return pane, screen, path


def restart_pane(
    runtime: RuntimeState,
    client: TmuxClient,
    pane: dict[str, Any],
    *,
    argv: list[str],
    preset: str | None,
    force_foreign: bool,
) -> tuple[dict[str, Any], dict[str, Any], Path, str]:
    with pane_lock(runtime, pane):
        current = client.pane(pane["pane_id"])
        observation = require_observed(runtime, current)
        ensure_not_self(client, current)
        if not current.get("owned") and not force_foreign:
            raise WAError(
                "foreign_restart_denied",
                "restart is limited to owned panes unless --force-foreign is explicit",
                target=public_pane(current),
            )
        final_screen = client.capture(current["pane_id"], 120)
        old_run_id = current.get("run_id")
        name = current.get("name") or f"agent-{current['pane_id'].lstrip('%')}"
        cwd = current.get("cwd") or os.getcwd()
        new_run_id = f"run-{uuid.uuid4().hex}"
        # Rotate the identity before replacing the process. A callback tied to
        # the old run then fails closed even if metadata or respawn only partly
        # succeeds. set_owned_metadata writes run_id first for the same reason.
        consume_observation_path(observation)
        try:
            set_owned_metadata(
                client,
                current["pane_id"],
                name=name,
                run_id=new_run_id,
                preset=preset,
            )
            if old_run_id:
                with contextlib.suppress(FileNotFoundError):
                    owned_record_path(runtime, old_run_id).unlink()
            client.run(
                [
                    "respawn-pane",
                    "-k",
                    "-t",
                    current["pane_id"],
                    "-c",
                    cwd,
                    exec_payload(argv),
                ],
                stage="restart",
            )
        except WAError as exc:
            exc.stage = "restart_state_unknown"
            exc.recovery = (
                "The pane identity or process may have changed. Do not retry blindly; "
                "resolve and read the pane before restarting again."
            )
            exc.target = {
                **public_pane(current),
                "previous_screen": final_screen,
            }
            raise
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "restart was interrupted after lifecycle mutation began",
                stage="restart_state_unknown",
                recovery=(
                    "The pane identity or process may have changed. Resolve and read "
                    "it before another lifecycle action."
                ),
                target={
                    **public_pane(current),
                    "previous_screen": final_screen,
                },
            ) from exc
        restarted = current
        path: Path | None = None
        try:
            time.sleep(0.2)
            restarted = client.pane(current["pane_id"])
            path = save_owned_record(
                runtime, restarted, argv=argv, cwd=cwd, name=name, preset=preset
            )
            screen = screen_object(client.capture(restarted["pane_id"], 80), 80)
            mark_observed(runtime, restarted)
        except WAError as exc:
            exc.stage = "restart_state_unknown"
            exc.recovery = (
                "The pane was restarted but its screen could not be captured. "
                "Resolve and read it before another mutation."
            )
            exc.target = {
                **public_pane(restarted),
                "launch": {
                    "argv": argv,
                    "record_path": str(path) if path is not None else None,
                    "preset": preset,
                },
                "previous_screen": final_screen,
            }
            raise
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "restart was interrupted after tmux accepted the process replacement",
                stage="restart_state_unknown",
                recovery="Resolve and read the pane before another lifecycle action.",
                target={
                    **public_pane(restarted),
                    "launch": {
                        "argv": argv,
                        "record_path": str(path) if path is not None else None,
                        "preset": preset,
                    },
                    "previous_screen": final_screen,
                },
            ) from exc
        assert path is not None
        if restarted.get("dead"):
            code = (
                "executable_not_found"
                if restarted.get("dead_status") == 127
                else "launch_process_exited"
            )
            raise WAError(
                code,
                f"restarted process exited with status {restarted.get('dead_status')}",
                stage="process_exited",
                target={
                    **public_pane(restarted),
                    "launch": {
                        "argv": argv,
                        "record_path": str(path),
                        "preset": preset,
                    },
                    "previous_screen": final_screen,
                },
                screen=screen,
            )
        return restarted, screen, path, final_screen


ADAPTERS: dict[str, dict[str, Any]] = {
    "codex": {
        "notification_capability": True,
        "forward_tested_major_minor": (0, 145),
        "submit_key": "Enter",
        "busy_key": "Enter",
        "delay": 0.5,
        "multiline": True,
    },
    "pi": {
        "notification_capability": True,
        "forward_tested_major_minor": (0, 80),
        "submit_key": "Enter",
        "busy_key": "Enter",
        "delay": 0.1,
        "multiline": True,
    },
    "claude": {
        "submit_key": "Enter",
        "delay": 0.1,
        "multiline": True,
    },
    "generic": {
        "submit_key": "Enter",
        "delay": 0.05,
        "multiline": False,
    },
}


def kind_from_argv(argv: list[str]) -> str | None:
    basename = executable_basename_from_argv(argv)
    if basename in BUILTIN_AGENT_DEFINITIONS:
        return basename
    return None


def process_rows() -> list[tuple[int, int, str, str]]:
    try:
        completed = subprocess.run(
            ["ps", "-ax", "-o", "pid=,ppid=,comm=,args="],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=3,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return []
    rows: list[tuple[int, int, str, str]] = []
    for line in completed.stdout.splitlines():
        parts = line.strip().split(None, 3)
        if len(parts) < 3 or not parts[0].isdigit() or not parts[1].isdigit():
            continue
        rows.append(
            (int(parts[0]), int(parts[1]), parts[2], parts[3] if len(parts) > 3 else "")
        )
    return rows


PROCESS_LAUNCHERS = {
    "env",
    "node",
    "nodejs",
    "python",
    "python3",
    "python.exe",
    "python3.exe",
}


def normalized_executable_basename(value: str) -> str:
    return Path(value).name.lower().removesuffix(".exe")


def executable_word_from_argv(argv: Sequence[str]) -> str | None:
    if not argv:
        return None
    first = normalized_executable_basename(argv[0])
    if first not in PROCESS_LAUNCHERS:
        return argv[0]
    for word in argv[1:]:
        if word.startswith("-") or (first == "env" and "=" in word):
            continue
        return word
    return None


def executable_basename_from_argv(argv: Sequence[str]) -> str | None:
    word = executable_word_from_argv(argv)
    return normalized_executable_basename(word) if word is not None else None


def registry_agent_type_from_argv(
    argv: Sequence[str], registry: dict[str, dict[str, Any]]
) -> str | None:
    executable = executable_basename_from_argv(argv)
    if executable is None:
        return None
    return next(
        (
            agent_type
            for agent_type, definition in registry.items()
            if executable in definition["executables"]
        ),
        None,
    )


def process_executable_candidates(
    row: tuple[int, int, str, str],
) -> list[tuple[str, str | None]]:
    _, _, command, arguments = row
    words: list[str] = []
    with contextlib.suppress(ValueError):
        words = shlex.split(arguments)

    executable_words: list[str] = [command]
    if words:
        executable_words.append(words[0])
        unwrapped = executable_word_from_argv(words)
        if unwrapped is not None:
            executable_words.append(unwrapped)

    candidates: list[tuple[str, str | None]] = []
    seen: set[str] = set()
    for word in executable_words:
        name = normalized_executable_basename(word)
        if name in seen:
            continue
        seen.add(name)
        candidate = Path(word)
        executable: str | None = None
        if (
            len(candidate.parts) > 1
            and candidate.is_file()
            and os.access(candidate, os.X_OK)
        ):
            executable = str(candidate.resolve())
        elif resolved := shutil.which(name):
            executable = str(Path(resolved).resolve())
        candidates.append((name, executable))
    return candidates


def process_agent_candidate(
    row: tuple[int, int, str, str],
) -> tuple[str, str | None] | None:
    for name, executable in process_executable_candidates(row):
        if name in BUILTIN_AGENT_DEFINITIONS:
            return name, executable
    return None


def descendant_process_rows(pane: dict[str, Any]) -> list[tuple[int, int, str, str]]:
    root_pid = pane.get("pane_pid")
    if not isinstance(root_pid, int):
        return []
    rows = process_rows()
    children: dict[int, list[tuple[int, int, str, str]]] = {}
    for row in rows:
        children.setdefault(row[1], []).append(row)
    stack: list[tuple[int, int]] = [(root_pid, 0)]
    candidates: list[tuple[int, tuple[int, int, str, str]]] = []
    while stack:
        parent, depth = stack.pop()
        for row in children.get(parent, []):
            candidates.append((depth + 1, row))
            stack.append((row[0], depth + 1))
    root = [row for row in rows if row[0] == root_pid]
    return [row for _, row in sorted(candidates, reverse=True)] + root


def detect_agent(
    runtime: RuntimeState, pane: dict[str, Any]
) -> tuple[str, str | None, str | None]:
    record = load_owned_record(runtime, pane)
    if record:
        argv = record.get("argv")
        if isinstance(argv, list) and all(isinstance(item, str) for item in argv):
            kind = kind_from_argv(argv)
            if kind:
                executable = executable_word_from_argv(argv)
                assert executable is not None
                if (
                    not Path(executable).is_absolute()
                    and len(Path(executable).parts) > 1
                ):
                    executable = str(
                        (Path(str(record.get("cwd") or ".")) / executable).resolve()
                    )
                fingerprint = (
                    "owned:"
                    + hashlib.sha256(
                        canonical_json_bytes(
                            {"run_id": pane.get("run_id"), "argv": argv}
                        )
                    ).hexdigest()
                )
                return kind, executable, fingerprint
    for row in descendant_process_rows(pane):
        detected = process_agent_candidate(row)
        if detected is None:
            continue
        kind, executable = detected
        fingerprint = (
            "process:"
            + hashlib.sha256(
                f"{row[0]}\x00{row[1]}\x00{row[2]}\x00{row[3]}".encode("utf-8")
            ).hexdigest()
        )
        return kind, executable or shutil.which(kind), fingerprint
    process = str(pane.get("process") or "").lower()
    if process in ("codex", "claude", "pi"):
        return (
            process,
            shutil.which(process),
            f"pane-process:{pane.get('pane_pid')}:{process}",
        )
    return "generic", None, None


def parse_version(text: str) -> tuple[int, int, int] | None:
    match = re.search(r"(?<!\d)(\d+)\.(\d+)\.(\d+)(?!\d)", text)
    if not match:
        return None
    return int(match.group(1)), int(match.group(2)), int(match.group(3))


def executable_owner_map(
    registry: dict[str, dict[str, Any]],
) -> dict[str, str]:
    return {
        executable: agent_type
        for agent_type, definition in registry.items()
        for executable in definition["executables"]
    }


def foreground_process_rows(pane: dict[str, Any]) -> list[tuple[int, int, str, str]]:
    current = normalized_executable_basename(str(pane.get("process") or ""))
    if not current:
        return []
    return [
        row
        for row in descendant_process_rows(pane)
        if normalized_executable_basename(row[2]) == current
    ]


def live_registered_agent(
    pane: dict[str, Any], executable_owners: dict[str, str]
) -> dict[str, Any] | None:
    for row in foreground_process_rows(pane):
        for basename, executable in process_executable_candidates(row):
            if agent_type := executable_owners.get(basename):
                return {
                    "agent_type": agent_type,
                    "executable_basename": basename,
                    "executable": executable,
                    "process_pid": row[0],
                }
    process = normalized_executable_basename(str(pane.get("process") or ""))
    if agent_type := executable_owners.get(process):
        return {
            "agent_type": agent_type,
            "executable_basename": process,
            "executable": shutil.which(process),
            "process_pid": pane.get("pane_pid"),
        }
    return None


def notification_strategy(config: ConfigState, pane: dict[str, Any]) -> dict[str, Any]:
    capability = live_registered_agent(pane, {"codex": "codex", "pi": "pi"})
    if capability is not None:
        adapter_id = str(capability["agent_type"])
        return {
            "mode": "capability",
            "id": adapter_id,
            "adapter": ADAPTERS[adapter_id],
            "agent": capability,
        }

    try:
        registry = load_agent_registry(config)
    except WAError as exc:
        builtin = live_registered_agent(
            pane, executable_owner_map(builtin_agent_registry())
        )
        if builtin is not None:
            return {
                "mode": "generic",
                "id": "generic",
                "adapter": ADAPTERS["generic"],
                "agent": builtin,
                "config_diagnostic": {
                    "code": exc.code,
                    "message": exc.message,
                },
            }
        return {
            "mode": "skip",
            "reason": "invalid_agent_config",
            "config_diagnostic": {"code": exc.code, "message": exc.message},
        }

    registered = live_registered_agent(pane, executable_owner_map(registry))
    if registered is None:
        return {"mode": "skip", "reason": "caller_not_agent"}
    return {
        "mode": "generic",
        "id": "generic",
        "adapter": ADAPTERS["generic"],
        "agent": registered,
    }


DANGER_PATTERNS = [
    re.compile(
        r"(?i)(allow|approve|permission|confirm).{0,80}(\[?[yn]/[yn]\]?|yes/no|enter to)"
    ),
    re.compile(r"(?i)press\s+(enter|return|any key)"),
    re.compile(r"(?i)(select|choose).{0,40}(option|number|one of)"),
    re.compile(r"(?i)(esc|escape).{0,20}(cancel|deny)"),
]
EMPTY_PROMPT_RE = re.compile(r"^\s*[>›❯]\s*$")
NONEMPTY_PROMPT_RE = re.compile(r"^\s*[>›❯]\s+\S")
BUSY_RE = re.compile(
    r"(?i)((esc|ctrl[-+ ]?c).{0,35}(interrupt|stop|cancel)|"
    r"(interrupt|stop|cancel).{0,35}(esc|ctrl[-+ ]?c))"
)
PI_BORDER_RE = re.compile(r"^\s*─{8,}\s*$")
PI_BUSY_RE = re.compile(r"^\s*[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏]\s+\S")


def clean_screen(value: str) -> str:
    return ANSI_RE.sub("", value).replace("\r", "")


def sgr_dim_after(parameters: str, current: bool) -> bool:
    fields = parameters.split(";") if parameters else ["0"]
    index = 0
    while index < len(fields):
        field = fields[index]
        first = field.split(":", 1)[0]
        code = int(first) if first.isdigit() else 0
        if code in (38, 48, 58):
            if ":" in field:
                index += 1
                continue
            mode = fields[index + 1] if index + 1 < len(fields) else ""
            if mode == "5":
                index += 3
            elif mode == "2":
                index += 5
            else:
                index += 2
            continue
        if code == 0:
            current = False
        elif code == 2:
            current = True
        elif code == 22:
            current = False
        index += 1
    return current


def sgr_visible_characters(raw_line: str) -> list[tuple[str, bool]] | None:
    visible: list[tuple[str, bool]] = []
    dim = False
    offset = 0
    for match in SGR_RE.finditer(raw_line):
        segment = raw_line[offset : match.start()]
        if "\x1b" in segment:
            return None
        visible.extend((character, dim) for character in segment if character != "\r")
        dim = sgr_dim_after(match.group(1), dim)
        offset = match.end()
    tail = raw_line[offset:]
    if "\x1b" in tail:
        return None
    visible.extend((character, dim) for character in tail if character != "\r")
    return visible


def codex_empty_or_dim_placeholder(raw_line: str) -> bool:
    visible = sgr_visible_characters(raw_line)
    if visible is None:
        return False
    first = next(
        (
            index
            for index, (character, _) in enumerate(visible)
            if not character.isspace()
        ),
        None,
    )
    if first is None or visible[first][0] not in ">›❯":
        return False
    content = [
        (character, dim)
        for character, dim in visible[first + 1 :]
        if not character.isspace()
    ]
    return not content or all(dim for _, dim in content)


def positive_empty_composer(kind: str, raw_line: str, cleaned_line: str) -> bool:
    if EMPTY_PROMPT_RE.fullmatch(cleaned_line):
        return True
    return kind == "codex" and codex_empty_or_dim_placeholder(raw_line)


def pi_bordered_composer(lines: list[str]) -> tuple[str, int | None]:
    border_rows = [
        index for index, line in enumerate(lines) if PI_BORDER_RE.fullmatch(line)
    ]
    for top, bottom in reversed(list(zip(border_rows, border_rows[1:], strict=False))):
        if bottom - top < 2 or len(lines) - bottom - 1 > 8:
            continue
        content = lines[top + 1 : bottom]
        if all(not line.strip() for line in content):
            return "empty", top
        return "unsafe", top
    return "unknown", None


def classify_adapter_state(kind: str, screen: str) -> str:
    if kind not in ("codex", "pi"):
        return "unknown"
    raw_lines = screen.replace("\r", "").splitlines()[-24:]
    lines = [clean_screen(line) for line in raw_lines]
    recent = "\n".join(lines)
    if any(pattern.search(recent) for pattern in DANGER_PATTERNS):
        return "unsafe"
    if kind == "pi":
        composer, top = pi_bordered_composer(lines)
        if composer == "unsafe":
            return "unsafe"
        if composer == "empty" and top is not None:
            status_lines = lines[max(0, top - 3) : top]
            return (
                "busy_queueable"
                if any(PI_BUSY_RE.search(line) for line in status_lines)
                else "idle"
            )
    prompt_rows = [
        (raw_line, cleaned_line)
        for raw_line, cleaned_line in zip(raw_lines[-8:], lines[-8:], strict=True)
        if EMPTY_PROMPT_RE.fullmatch(cleaned_line)
        or NONEMPTY_PROMPT_RE.match(cleaned_line)
    ]
    if not prompt_rows:
        return "unknown"
    raw_prompt, cleaned_prompt = prompt_rows[-1]
    if not positive_empty_composer(kind, raw_prompt, cleaned_prompt):
        return "unsafe"
    if kind == "codex" and BUSY_RE.search(recent):
        return "busy_queueable"
    return "idle"


def adapter_for_send(
    runtime: RuntimeState, pane: dict[str, Any]
) -> tuple[str, dict[str, Any]]:
    kind, _, _ = detect_agent(runtime, pane)
    return kind, ADAPTERS.get(kind, ADAPTERS["generic"])


def launch_readiness(
    runtime: RuntimeState,
    pane: dict[str, Any],
    screen: dict[str, Any],
    client: TmuxClient | None = None,
) -> dict[str, Any]:
    kind, _, _ = detect_agent(runtime, pane)
    captured = str(screen.get("tail") or "")
    if client is not None and kind in ("codex", "pi"):
        with contextlib.suppress(WAError):
            captured = client.capture(
                pane["pane_id"], int(screen.get("lines") or 80), preserve_escape=True
            )
    state = (
        classify_adapter_state(kind, captured) if kind in ("codex", "pi") else "unknown"
    )
    return {
        "adapter": kind,
        "state": state,
        "ready_for_send": state == "idle" if kind in ("codex", "pi") else None,
    }


def send_core(
    runtime: RuntimeState,
    client: TmuxClient,
    pane: dict[str, Any],
    *,
    message: str,
    allow_foreign: bool,
) -> tuple[dict[str, Any], dict[str, Any]]:
    validate_message(message)
    with pane_lock(runtime, pane):
        current = client.pane(pane["pane_id"])
        observation = require_writable_target(
            runtime, client, current, allow_foreign=allow_foreign
        )
        kind, adapter = adapter_for_send(runtime, current)
        if "\n" in message and not adapter.get("multiline"):
            raise WAError(
                "multiline_not_safe",
                f"safe multiline input is not enabled for adapter: {kind}",
                stage="text_not_written",
                recovery="Use a single-line request or a verified target-specific input mechanism.",
                target=public_pane(current),
            )
        try:
            if "\n" in message:
                buffer_name = f"with-agents-{uuid.uuid4().hex}"
                try:
                    client.run(
                        ["load-buffer", "-b", buffer_name, "-"],
                        input_text=message,
                        stage="text_not_written",
                    )
                    client.run(
                        [
                            "paste-buffer",
                            "-p",
                            "-b",
                            buffer_name,
                            "-d",
                            "-t",
                            current["pane_id"],
                        ],
                        stage="text_not_written",
                    )
                finally:
                    with contextlib.suppress(WAError):
                        client.run(
                            ["delete-buffer", "-b", buffer_name],
                            stage="buffer_cleanup",
                            check=False,
                        )
            else:
                client.run(
                    ["send-keys", "-t", current["pane_id"], "-l", "--", message],
                    stage="text_not_written",
                )
        except WAError as exc:
            if exc.code == "tmux_timeout":
                consume_observation_path(observation)
                exc.stage = "text_written_not_submitted"
                exc.recovery = (
                    "The text write may have reached the pane. Do not resend; "
                    "resolve and read the target before deciding whether to submit only."
                )
            exc.target = public_pane(current)
            raise
        except KeyboardInterrupt as exc:
            consume_observation_path(observation)
            raise WAError(
                "interrupted",
                "input was interrupted while its text-write state was uncertain",
                stage="text_written_not_submitted",
                recovery=(
                    "The text may have reached the pane. Do not resend; resolve and "
                    "read the target before deciding whether to submit only."
                ),
                target=public_pane(current),
            ) from exc
        consume_observation_path(observation)
        try:
            time.sleep(float(adapter.get("delay", 0.05)))
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "input was interrupted after text was written and before submission",
                stage="text_written_not_submitted",
                recovery=(
                    "Do not resend the text. Resolve and read the target, then submit "
                    "only if the intended text is positively present."
                ),
                target=public_pane(current),
            ) from exc
        try:
            client.run(
                [
                    "send-keys",
                    "-t",
                    current["pane_id"],
                    adapter.get("submit_key", "Enter"),
                ],
                stage="text_written_not_submitted",
            )
        except WAError as exc:
            if exc.code == "tmux_timeout":
                exc.stage = "submitted_state_unknown"
                exc.recovery = (
                    "The submit key may have reached the pane. Do not resend; "
                    "resolve and read the target first."
                )
            exc.target = public_pane(current)
            with contextlib.suppress(WAError):
                exc.screen = screen_object(client.capture(current["pane_id"], 80), 80)
            raise
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "input was interrupted while submit-key delivery was uncertain",
                stage="submitted_state_unknown",
                recovery="Do not resend blindly; resolve and read the target first.",
                target=public_pane(current),
            ) from exc
        try:
            time.sleep(0.05)
            captured = client.capture(current["pane_id"], 80)
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "input was interrupted after tmux accepted the submit key",
                stage="submitted_state_unknown",
                recovery="Do not resend blindly; resolve and read the target first.",
                target=public_pane(current),
            ) from exc
        except WAError as exc:
            raise WAError(
                "submitted_state_unknown",
                "tmux accepted the submit key but the resulting pane state cannot be captured",
                stage="submitted_state_unknown",
                recovery="Do not resend blindly; resolve and read the pane first.",
                target=public_pane(current),
            ) from exc
        return current, screen_object(captured, 80)


def preset_path(config: ConfigState, name: str) -> Path:
    validate_preset_name(name)
    return config.validate_existing_presets() / f"{name}.json"


def load_preset(config: ConfigState, name: str) -> tuple[dict[str, Any], Path]:
    path = preset_path(config, name)
    if not path.is_file():
        raise WAError(
            "preset_not_found",
            f"preset does not exist: {name}",
            recovery=f"Create it with with-agents preset save {name} --from <owned-pane>.",
            details={"searched_path": str(path)},
        )
    value = safe_read_json(path)
    argv = value.get("argv")
    agent_type = value.get("agent_type")
    pane_name = value.get("pane_name")
    if (
        value.get("version") != 1
        or isinstance(value.get("version"), bool)
        or not isinstance(argv, list)
        or not argv
        or not all(isinstance(item, str) for item in argv)
        or any("\x00" in item for item in argv)
    ):
        raise WAError(
            "invalid_preset", f"preset has an invalid version or argv: {path}"
        )
    if not isinstance(agent_type, str) or AGENT_TYPE_RE.fullmatch(agent_type) is None:
        raise WAError("invalid_preset", f"preset has an invalid agent_type: {path}")
    if not isinstance(pane_name, str) or not PANE_NAME_RE.fullmatch(pane_name):
        raise WAError("invalid_preset", f"preset has an invalid pane_name: {path}")
    return value, path


def preset_from_pane(
    runtime: RuntimeState,
    client: TmuxClient,
    target: str,
    registry: dict[str, dict[str, Any]],
) -> dict[str, Any]:
    pane = client.resolve(target)
    record = load_owned_record(runtime, pane)
    if not record:
        raise WAError(
            "launch_record_not_found",
            "preset sources must be an owned pane with a current launch record",
            target=public_pane(pane),
        )
    argv = record.get("argv")
    if not isinstance(argv, list) or not argv:
        raise WAError(
            "launch_record_not_found",
            "the owned pane does not have a launched argv",
            target=public_pane(pane),
        )
    reject_secret_argv(argv)
    kind = registry_agent_type_from_argv(argv, registry) or "external"
    return {
        "version": 1,
        "agent_type": kind,
        "pane_name": record.get("name") or pane.get("name"),
        "argv": argv,
    }


SECRET_FLAG_RE = re.compile(
    r"(?i)(api[-_]?key|access[-_]?token|auth[-_]?token|client[-_]?secret|password|credential)"
)


def reject_secret_argv(argv: list[str]) -> None:
    findings: list[str] = []
    for index, argument in enumerate(argv):
        flag, separator, _ = argument.partition("=")
        if SECRET_FLAG_RE.search(flag):
            findings.append(flag)
            if not separator and index + 1 < len(argv):
                findings.append(f"{flag} <next-argument>")
        if "=" in argument:
            variable = argument.split("=", 1)[0]
            if SECRET_FLAG_RE.fullmatch(variable):
                findings.append(variable)
    if findings:
        raise WAError(
            "preset_secret_suspected",
            "launch argv contains a credential-like flag or assignment and will not be persisted",
            recovery="Remove the secret from argv and use the target CLI's normal credential store or environment.",
            details={"suspicious_fields": sorted(set(findings))},
        )


def request_id() -> str:
    return f"wa-{utc_now().strftime('%Y%m%dT%H%M%S')}-{uuid.uuid4().hex[:12]}"


def request_dir(runtime: RuntimeState, identifier: str) -> Path:
    if not REQUEST_ID_RE.fullmatch(identifier):
        raise WAError("reply_ticket_invalid", f"invalid request ID: {identifier}")
    return runtime.requests / identifier


def load_request(runtime: RuntimeState, identifier: str) -> tuple[dict[str, Any], Path]:
    directory = request_dir(runtime, identifier)
    path = directory / "request.json"
    if not directory.is_dir() or directory.is_symlink() or not path.is_file():
        raise WAError("reply_ticket_invalid", f"request does not exist: {identifier}")
    record = safe_read_json(path)
    version = record.get("version")
    if (
        record.get("request_id") != identifier
        or isinstance(version, bool)
        or version not in (1, 2)
    ):
        raise WAError(
            "reply_ticket_invalid", f"request record is invalid: {identifier}"
        )
    return record, directory


def v2_request_limits() -> dict[str, int]:
    return {
        "message_bytes": MESSAGE_LIMIT,
        "nonterminal_events": NONTERMINAL_EVENT_LIMIT,
        "terminal_events": 1,
        "result_bytes_per_event": RESULT_LIMIT,
        "result_bytes_per_request": REQUEST_RESULT_LIMIT,
        "files_per_event": 1,
    }


def invalid_reply_stream(identifier: str, message: str) -> WAError:
    return WAError(
        "reply_ticket_invalid",
        f"request event stream is invalid for {identifier}: {message}",
        recovery="Preserve the request directory for diagnosis; do not append or reconstruct events manually.",
        request={"request_id": identifier, "protocol_version": 2},
    )


def require_request_subdirectory(directory: Path, name: str) -> Path:
    path = directory / name
    try:
        info = path.lstat()
    except FileNotFoundError as exc:
        raise invalid_reply_stream(
            directory.name, f"missing {name}/ directory"
        ) from exc
    if (
        stat.S_ISLNK(info.st_mode)
        or not stat.S_ISDIR(info.st_mode)
        or info.st_uid != os.getuid()
    ):
        raise invalid_reply_stream(
            directory.name, f"{name}/ is not a current-user-owned real directory"
        )
    return path


def validate_v2_request_record(record: dict[str, Any], directory: Path) -> None:
    identifier = directory.name
    created_epoch = record.get("created_epoch")
    ttl = record.get("reply_ttl_seconds")
    if record.get("version") != 2 or record.get("request_id") != identifier:
        raise invalid_reply_stream(identifier, "request identity or version mismatch")
    if record.get("phase") not in (
        "dispatching",
        "active",
        "aborted",
        "dispatch_unknown",
    ):
        raise invalid_reply_stream(identifier, "unknown dispatch phase")
    if (
        isinstance(created_epoch, bool)
        or not isinstance(created_epoch, (int, float))
        or not math.isfinite(float(created_epoch))
    ):
        raise invalid_reply_stream(identifier, "created_epoch is invalid")
    if ttl is not None and (
        isinstance(ttl, bool)
        or not isinstance(ttl, (int, float))
        or not math.isfinite(float(ttl))
        or float(ttl) <= 0
    ):
        raise invalid_reply_stream(identifier, "reply_ttl_seconds is invalid")
    if record.get("limits") != v2_request_limits():
        raise invalid_reply_stream(identifier, "fixed resource limits do not match v2")
    if record.get("result_dir") != str((directory / "result").resolve()):
        raise invalid_reply_stream(identifier, "result_dir is outside the request")
    require_request_subdirectory(directory, "events")
    require_request_subdirectory(directory, "result")


def validate_v2_event_result(
    result: Any, directory: Path, seq: int
) -> dict[str, Any] | None:
    if result is None:
        return None
    if not isinstance(result, dict) or set(result) != {"path", "bytes", "sha256"}:
        raise invalid_reply_stream(directory.name, f"event {seq} result is invalid")
    result_path = result.get("path")
    result_bytes = result.get("bytes")
    result_sha256 = result.get("sha256")
    if (
        not isinstance(result_path, str)
        or not Path(result_path).is_absolute()
        or isinstance(result_bytes, bool)
        or not isinstance(result_bytes, int)
        or not 0 <= result_bytes <= RESULT_LIMIT
        or not isinstance(result_sha256, str)
        or SHA256_RE.fullmatch(result_sha256) is None
    ):
        raise invalid_reply_stream(
            directory.name, f"event {seq} result fields are invalid"
        )
    managed_directory = directory / "result" / f"{seq:06d}"
    try:
        managed_info = managed_directory.lstat()
        file_info = Path(result_path).lstat()
    except FileNotFoundError as exc:
        raise invalid_reply_stream(
            directory.name, f"event {seq} managed result is missing"
        ) from exc
    if (
        stat.S_ISLNK(managed_info.st_mode)
        or not stat.S_ISDIR(managed_info.st_mode)
        or managed_info.st_uid != os.getuid()
        or stat.S_ISLNK(file_info.st_mode)
        or not stat.S_ISREG(file_info.st_mode)
        or file_info.st_uid != os.getuid()
        or file_info.st_size != result_bytes
        or Path(result_path).parent != managed_directory.resolve()
    ):
        raise invalid_reply_stream(
            directory.name, f"event {seq} managed result path is unsafe"
        )
    entries = list(managed_directory.iterdir())
    if len(entries) != 1 or entries[0] != Path(result_path):
        raise invalid_reply_stream(
            directory.name, f"event {seq} must own exactly one managed file"
        )
    return {"path": result_path, "bytes": result_bytes, "sha256": result_sha256}


def scan_v2_events(record: dict[str, Any], directory: Path) -> list[dict[str, Any]]:
    validate_v2_request_record(record, directory)
    events_directory = directory / "events"
    canonical_paths: list[tuple[int, Path]] = []
    for path in events_directory.iterdir():
        match = EVENT_FILENAME_RE.fullmatch(path.name)
        if match is not None:
            canonical_paths.append((int(match.group("seq")), path))
        elif EVENT_TEMP_FILENAME_RE.fullmatch(path.name) is None:
            raise invalid_reply_stream(
                directory.name, f"unexpected events/ entry: {path.name}"
            )
    canonical_paths.sort()
    if len(canonical_paths) > TOTAL_EVENT_LIMIT:
        raise invalid_reply_stream(directory.name, "too many canonical events")

    events: list[dict[str, Any]] = []
    terminal_seen = False
    nonterminal_count = 0
    expected_fields = {
        "version",
        "request_id",
        "seq",
        "created_at",
        "created_epoch",
        "status",
        "terminal",
        "message",
        "result",
    }
    for expected_seq, (filename_seq, path) in enumerate(canonical_paths, start=1):
        if filename_seq != expected_seq:
            raise invalid_reply_stream(directory.name, "event sequence has a gap")
        try:
            event = safe_read_json(path)
        except WAError as exc:
            raise invalid_reply_stream(
                directory.name, f"event {expected_seq} is not a safe JSON file"
            ) from exc
        status = event.get("status")
        terminal = event.get("terminal")
        created_epoch = event.get("created_epoch")
        if (
            set(event) != expected_fields
            or event.get("version") != 1
            or isinstance(event.get("version"), bool)
            or event.get("request_id") != directory.name
            or event.get("seq") != expected_seq
            or isinstance(event.get("seq"), bool)
            or not isinstance(event.get("created_at"), str)
            or isinstance(created_epoch, bool)
            or not isinstance(created_epoch, (int, float))
            or not math.isfinite(float(created_epoch))
            or not isinstance(status, str)
            or status not in EVENT_STATUS_TERMINAL
            or not isinstance(terminal, bool)
            or terminal is not EVENT_STATUS_TERMINAL.get(status)
        ):
            raise invalid_reply_stream(
                directory.name, f"event {expected_seq} schema is invalid"
            )
        try:
            message = validate_reply_message(event.get("message"))
        except WAError as exc:
            raise invalid_reply_stream(
                directory.name, f"event {expected_seq} message is invalid"
            ) from exc
        result = validate_v2_event_result(event.get("result"), directory, expected_seq)
        if terminal_seen:
            raise invalid_reply_stream(directory.name, "event follows terminal outcome")
        if terminal:
            terminal_seen = True
        else:
            nonterminal_count += 1
            if nonterminal_count > NONTERMINAL_EVENT_LIMIT:
                raise invalid_reply_stream(
                    directory.name, "nonterminal event limit was exceeded"
                )
        events.append({**event, "message": message, "result": result})
    return events


def v2_event_origin(record: dict[str, Any], events: list[dict[str, Any]]) -> float:
    if events:
        return float(events[-1]["created_epoch"])
    origin = record.get(
        "dispatched_epoch",
        record.get("dispatch_finished_epoch", record.get("created_epoch")),
    )
    if (
        isinstance(origin, bool)
        or not isinstance(origin, (int, float))
        or not math.isfinite(float(origin))
    ):
        raise invalid_reply_stream(
            str(record.get("request_id")), "TTL origin is invalid"
        )
    return float(origin)


def ensure_v2_ticket_not_expired(
    record: dict[str, Any], events: list[dict[str, Any]], *, now: float | None = None
) -> None:
    ttl = record.get("reply_ttl_seconds")
    if ttl is None:
        return
    current = time.time() if now is None else now
    if current > v2_event_origin(record, events) + float(ttl):
        raise WAError(
            "reply_ticket_expired",
            "v2 reply ticket has expired",
            request={
                "request_id": record["request_id"],
                "protocol_version": 2,
            },
        )


def remove_orphan_event_result(directory: Path, seq: int) -> None:
    result_root = require_request_subdirectory(directory, "result")
    managed_directory = result_root / f"{seq:06d}"
    if not managed_directory.exists() and not managed_directory.is_symlink():
        return
    info = managed_directory.lstat()
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISDIR(info.st_mode):
        raise invalid_reply_stream(
            directory.name, f"orphan result slot {seq} is not a real directory"
        )
    shutil.rmtree(managed_directory)


def current_caller_route(
    client: TmuxClient,
    *,
    reply_to: str | None,
    reply_socket: str | None,
) -> tuple[dict[str, Any], TmuxClient | None, dict[str, Any] | None]:
    if reply_to:
        caller_client = TmuxClient(reply_socket or client.server().get("socket_path"))
        caller_pane = caller_client.resolve(reply_to)
        return (
            {"kind": "tmux", **identity_of(caller_pane)},
            caller_client,
            caller_pane,
        )
    pane_id = os.environ.get("TMUX_PANE")
    if pane_id:
        socket = os.environ.get("TMUX", "").split(",", 1)[0] or None
        caller_client = TmuxClient(socket)
        caller_pane = caller_client.pane(pane_id)
        return (
            {"kind": "tmux", **identity_of(caller_pane)},
            caller_client,
            caller_pane,
        )
    return {"kind": "external"}, None, None


def protocol_suffix(
    identifier: str, runtime: RuntimeState, caller: dict[str, Any]
) -> str:
    executable = json.dumps(str(Path(__file__).resolve()), ensure_ascii=True)
    runtime_root = json.dumps(str(runtime.root.resolve()), ensure_ascii=True)
    if caller.get("kind") == "tmux":
        socket = json.dumps(str(caller.get("socket_path")), ensure_ascii=True)
        pane = json.dumps(str(caller.get("pane_id")), ensure_ascii=True)
        reply_target = f"tmux(socket={socket},pane={pane})"
    else:
        reply_target = f"controller-spool(runtime={runtime_root},request={identifier})"
    return (
        f"[with-agents async request={identifier} controller={executable} "
        f"runtime={runtime_root} reply-target={reply_target}] "
        "While able to run, provide at least one terminal outcome "
        "(done|blocked|failed); progress and question are nonterminal. "
        "Use a short message or a file for a long result, and choose any available reply transport."
    )


def managed_copy(
    source: str, destination_dir: Path, *, request_remaining: int | None = None
) -> dict[str, Any]:
    source_path = Path(source).expanduser()
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(source_path, flags)
    except OSError as exc:
        raise WAError(
            "result_file_invalid", f"cannot open result file safely: {exc}"
        ) from exc
    temporary_path: Path | None = None
    try:
        info = os.fstat(descriptor)
        if not stat.S_ISREG(info.st_mode):
            raise WAError("result_file_invalid", "result file must be a regular file")
        if info.st_size > RESULT_LIMIT:
            raise WAError(
                "result_file_too_large",
                f"result file exceeds {RESULT_LIMIT} bytes",
                details={"size": info.st_size, "limit": RESULT_LIMIT},
            )
        if request_remaining is not None and info.st_size > request_remaining:
            raise WAError(
                "reply_result_budget_exhausted",
                "result file would exceed the request's managed-byte budget",
                details={"size": info.st_size, "remaining": request_remaining},
            )
        ensure_private_dir(destination_dir)
        basename = re.sub(r"[^A-Za-z0-9._-]", "_", source_path.name) or "result.bin"
        final_path = destination_dir / basename
        temp_descriptor, temporary = tempfile.mkstemp(
            prefix=".result.", dir=destination_dir
        )
        temporary_path = Path(temporary)
        digest = hashlib.sha256()
        total = 0
        with (
            os.fdopen(os.dup(descriptor), "rb") as source_handle,
            os.fdopen(temp_descriptor, "wb") as destination_handle,
        ):
            while True:
                chunk = source_handle.read(1024 * 1024)
                if not chunk:
                    break
                total += len(chunk)
                if total > RESULT_LIMIT:
                    raise WAError(
                        "result_file_too_large",
                        f"result file exceeds {RESULT_LIMIT} bytes while copying",
                    )
                if request_remaining is not None and total > request_remaining:
                    raise WAError(
                        "reply_result_budget_exhausted",
                        "result file grew beyond the request's remaining managed-byte budget",
                    )
                digest.update(chunk)
                destination_handle.write(chunk)
            destination_handle.flush()
            os.fsync(destination_handle.fileno())
        temporary_path.chmod(0o600)
        os.replace(temporary_path, final_path)
        temporary_path = None
        return {
            "path": str(final_path.resolve()),
            "bytes": total,
            "sha256": digest.hexdigest(),
            "original_name": source_path.name,
        }
    finally:
        os.close(descriptor)
        if temporary_path is not None:
            with contextlib.suppress(FileNotFoundError):
                temporary_path.unlink()


def validate_reply_message(message: str | None) -> str | None:
    if message is None:
        return None
    encoded = message.encode("utf-8")
    if len(encoded) > MESSAGE_LIMIT:
        raise WAError(
            "reply_message_too_large",
            f"reply message exceeds {MESSAGE_LIMIT} UTF-8 bytes; use --file",
            details={"bytes": len(encoded), "limit": MESSAGE_LIMIT},
        )
    if any(
        unicodedata.category(character) in ("Cc", "Zl", "Zp") for character in message
    ):
        raise WAError(
            "reply_message_invalid",
            "reply message must be one line without control or ANSI escape characters",
        )
    return message


def persist_notification(directory: Path, notification: dict[str, Any]) -> None:
    value = {"version": 1, "created_at": iso_now(), **notification}
    with contextlib.suppress(WAError):
        atomic_write_json(directory / "notification.json", value, exclusive=True)


def notification_result(
    reason: str, *, attempted: bool = False, accepted: bool = False
) -> dict[str, Any]:
    return {
        "spooled": True,
        "injection_attempted": attempted,
        "tmux_accepted": accepted,
        "reason": reason,
    }


def notification_attempt_result(
    reason: str,
    *,
    text_attempted: bool = False,
    text_tmux_accepted: bool | None = None,
    submit_attempted: bool = False,
    submit_tmux_accepted: bool | None = None,
    tui_acceptance: str | None = None,
) -> dict[str, Any]:
    return {
        "spooled": True,
        "injection_attempted": text_attempted or submit_attempted,
        "text_attempted": text_attempted,
        "text_tmux_accepted": text_tmux_accepted,
        "submit_attempted": submit_attempted,
        "submit_tmux_accepted": submit_tmux_accepted,
        "tmux_accepted": bool(
            text_attempted
            and text_tmux_accepted is True
            and submit_attempted
            and submit_tmux_accepted is True
        ),
        "tui_acceptance": tui_acceptance,
        "reason": reason,
    }


def event_notification_result(
    request_identifier: str,
    seq: int,
    reason: str,
    *,
    text_attempted: bool = False,
    text_tmux_accepted: bool | None = None,
    submit_attempted: bool = False,
    submit_tmux_accepted: bool | None = None,
    tui_acceptance: str | None = None,
) -> dict[str, Any]:
    return {
        "version": 1,
        "request_id": request_identifier,
        "seq": seq,
        **notification_attempt_result(
            reason,
            text_attempted=text_attempted,
            text_tmux_accepted=text_tmux_accepted,
            submit_attempted=submit_attempted,
            submit_tmux_accepted=submit_tmux_accepted,
            tui_acceptance=tui_acceptance,
        ),
        "created_at": iso_now(),
    }


def persist_event_notification(directory: Path, notification: dict[str, Any]) -> None:
    path = directory / "notifications" / f"{notification['seq']:06d}.json"
    atomic_write_json(path, notification, exclusive=True)


def read_event_notification(directory: Path, seq: int) -> dict[str, Any]:
    path = directory / "notifications" / f"{seq:06d}.json"
    if not path.exists() and not path.is_symlink():
        return {"state": "missing", "reason": "notification_missing"}
    try:
        notification = safe_read_json(path)
    except WAError as exc:
        return {
            "state": "invalid",
            "reason": "notification_invalid",
            "error": {"code": exc.code, "message": exc.message},
        }
    required = {
        "version",
        "request_id",
        "seq",
        "spooled",
        "injection_attempted",
        "text_attempted",
        "text_tmux_accepted",
        "submit_attempted",
        "submit_tmux_accepted",
        "tmux_accepted",
        "tui_acceptance",
        "reason",
        "created_at",
    }
    text_attempted = notification.get("text_attempted")
    text_accepted = notification.get("text_tmux_accepted")
    submit_attempted = notification.get("submit_attempted")
    submit_accepted = notification.get("submit_tmux_accepted")
    injection_attempted = notification.get("injection_attempted")
    tmux_accepted = notification.get("tmux_accepted")
    if (
        not required.issubset(notification)
        or notification.get("version") != 1
        or isinstance(notification.get("version"), bool)
        or notification.get("request_id") != directory.name
        or notification.get("seq") != seq
        or isinstance(notification.get("seq"), bool)
        or notification.get("spooled") is not True
        or not isinstance(injection_attempted, bool)
        or not isinstance(text_attempted, bool)
        or (text_accepted is not None and not isinstance(text_accepted, bool))
        or not isinstance(submit_attempted, bool)
        or (submit_accepted is not None and not isinstance(submit_accepted, bool))
        or not isinstance(tmux_accepted, bool)
        or (
            notification.get("tui_acceptance") is not None
            and not isinstance(notification.get("tui_acceptance"), str)
        )
        or not isinstance(notification.get("reason"), str)
        or not isinstance(notification.get("created_at"), str)
        or injection_attempted is not (text_attempted or submit_attempted)
        or (not text_attempted and text_accepted is not None)
        or (not submit_attempted and submit_accepted is not None)
        or (submit_attempted and (not text_attempted or text_accepted is not True))
        or tmux_accepted
        is not (
            text_attempted
            and text_accepted is True
            and submit_attempted
            and submit_accepted is True
        )
    ):
        return {"state": "invalid", "reason": "notification_invalid"}
    return notification


def canonical_socket_path(value: Any) -> str | None:
    if not isinstance(value, str) or not value:
        return None
    return os.path.realpath(Path(value).expanduser().absolute())


def notification_route_matches(
    expected: dict[str, Any], current: dict[str, Any]
) -> bool:
    expected_pid = expected.get("server_pid")
    current_pid = current.get("server_pid")
    expected_pane = expected.get("pane_id")
    current_pane = current.get("pane_id")
    return (
        isinstance(expected_pid, int)
        and not isinstance(expected_pid, bool)
        and isinstance(current_pid, int)
        and not isinstance(current_pid, bool)
        and expected_pid == current_pid
        and isinstance(expected_pane, str)
        and bool(expected_pane)
        and expected_pane == current_pane
        and canonical_socket_path(expected.get("socket_path"))
        == canonical_socket_path(current.get("socket_path"))
    )


def notification_doorbell(request: dict[str, Any], reply: dict[str, Any]) -> str | None:
    message = reply.get("message") or "reply available in spool"
    seq = reply.get("seq")
    seq_part = (
        f" seq={seq}" if isinstance(seq, int) and not isinstance(seq, bool) else ""
    )
    doorbell = (
        f"[with-agents reply request={request['request_id']}"
        f"{seq_part} status={reply['status']}] {message}"
    )
    result = reply.get("result")
    if isinstance(result, dict) and result.get("path"):
        doorbell += f" file={result['path']}"
    if any(
        unicodedata.category(character) in ("Cc", "Zl", "Zp") for character in doorbell
    ):
        return None
    return doorbell


def run_notification_attempt(
    runtime: RuntimeState,
    config: ConfigState,
    request: dict[str, Any],
    reply: dict[str, Any],
) -> dict[str, Any]:
    if request.get("notify_mode") != "pane" or not request.get("notify_armed"):
        return notification_attempt_result("spool_only")
    caller = request.get("caller")
    if not isinstance(caller, dict) or caller.get("kind") != "tmux":
        return notification_attempt_result("caller_unaddressable")
    try:
        client = TmuxClient(str(caller.get("socket_path")))
        pane = client.pane(str(caller.get("pane_id")))
    except WAError:
        return notification_attempt_result("caller_unreachable")
    if not notification_route_matches(caller, pane):
        return notification_attempt_result("caller_identity_mismatch")
    doorbell = notification_doorbell(request, reply)
    if doorbell is None:
        return notification_attempt_result("invalid_doorbell")

    try:
        with pane_lock(runtime, pane):
            try:
                current = client.pane(pane["pane_id"])
            except WAError:
                return notification_attempt_result("caller_unreachable")
            if not notification_route_matches(caller, current):
                return notification_attempt_result("caller_identity_mismatch")
            strategy = notification_strategy(config, current)
            if strategy["mode"] == "skip":
                return notification_attempt_result(str(strategy["reason"]))
            adapter = strategy["adapter"]
            key = str(adapter["submit_key"])
            if strategy["mode"] == "capability":
                try:
                    screen = client.capture(
                        current["pane_id"], 100, preserve_escape=True
                    )
                except WAError:
                    return notification_attempt_result("caller_state_unknown")
                state = classify_adapter_state(str(strategy["id"]), screen)
                if state == "unsafe":
                    return notification_attempt_result("unsafe_callback_state")
                if state == "unknown":
                    return notification_attempt_result("unknown_callback_state")
                if state != "idle":
                    key = str(adapter["busy_key"])
            try:
                client.run(
                    ["send-keys", "-t", current["pane_id"], "-l", "--", doorbell],
                    stage="notification_text",
                )
            except KeyboardInterrupt:
                return notification_attempt_result(
                    "notification_text_state_unknown",
                    text_attempted=True,
                    text_tmux_accepted=None,
                )
            except WAError as exc:
                return notification_attempt_result(
                    (
                        "notification_text_state_unknown"
                        if exc.code == "tmux_timeout"
                        else "notification_text_not_written"
                    ),
                    text_attempted=True,
                    text_tmux_accepted=None if exc.code == "tmux_timeout" else False,
                )
            try:
                time.sleep(float(adapter.get("delay", 0.1)))
            except KeyboardInterrupt:
                return notification_attempt_result(
                    "notification_interrupted_before_submit",
                    text_attempted=True,
                    text_tmux_accepted=True,
                )
            try:
                client.run(
                    ["send-keys", "-t", current["pane_id"], key],
                    stage="notification_submit",
                )
            except KeyboardInterrupt:
                return notification_attempt_result(
                    "notification_submit_state_unknown",
                    text_attempted=True,
                    text_tmux_accepted=True,
                    submit_attempted=True,
                    submit_tmux_accepted=None,
                )
            except WAError as exc:
                return notification_attempt_result(
                    (
                        "notification_submit_state_unknown"
                        if exc.code == "tmux_timeout"
                        else "notification_text_written_not_submitted"
                    ),
                    text_attempted=True,
                    text_tmux_accepted=True,
                    submit_attempted=True,
                    submit_tmux_accepted=(
                        None if exc.code == "tmux_timeout" else False
                    ),
                )
            return notification_attempt_result(
                "tmux_accepted",
                text_attempted=True,
                text_tmux_accepted=True,
                submit_attempted=True,
                submit_tmux_accepted=True,
                tui_acceptance="unverified",
            )
    except WAError as exc:
        if exc.code == "lock_timeout":
            return notification_attempt_result("notification_lock_unavailable")
        raise


def notify_caller(
    runtime: RuntimeState,
    config: ConfigState,
    request: dict[str, Any],
    reply: dict[str, Any],
) -> dict[str, Any]:
    attempt = run_notification_attempt(runtime, config, request, reply)
    return notification_result(
        str(attempt["reason"]),
        attempted=bool(attempt["injection_attempted"]),
        accepted=bool(attempt["tmux_accepted"]),
    )


def notify_event_caller(
    runtime: RuntimeState,
    config: ConfigState,
    request: dict[str, Any],
    event: dict[str, Any],
) -> dict[str, Any]:
    try:
        attempt = run_notification_attempt(runtime, config, request, event)
    except KeyboardInterrupt:
        attempt = notification_attempt_result("notification_interrupted_before_attempt")
    return {
        "version": 1,
        "request_id": request["request_id"],
        "seq": event["seq"],
        **attempt,
        "created_at": iso_now(),
    }


def legacy_inbox_item(directory: Path) -> dict[str, Any]:
    request = safe_read_json(directory / "request.json")
    reply_path = directory / "reply.json"
    if not reply_path.is_file():
        return {
            "request_id": request["request_id"],
            "state": request.get("phase", "pending"),
            "status": None,
            "message": None,
            "result_path": None,
            "notification": None,
        }
    reply = safe_read_json(reply_path)
    notification = (
        safe_read_json(directory / "notification.json")
        if (directory / "notification.json").is_file()
        else None
    )
    result = reply.get("result") or {}
    return {
        "request_id": request["request_id"],
        "state": "replied",
        "status": reply.get("status"),
        "message": reply.get("message"),
        "result_path": result.get("path"),
        "result_bytes": result.get("bytes"),
        "result_sha256": result.get("sha256"),
        "notification": notification,
    }


def v2_inbox_events(record: dict[str, Any], directory: Path) -> list[dict[str, Any]]:
    return [
        {**event, "notification": read_event_notification(directory, event["seq"])}
        for event in scan_v2_events(record, directory)
    ]


def v2_inbox_summary(
    record: dict[str, Any], directory: Path, events: list[dict[str, Any]]
) -> dict[str, Any]:
    latest = events[-1]
    notification = read_event_notification(directory, latest["seq"])
    return {
        "protocol_version": 2,
        "request_id": record["request_id"],
        "latest_seq": latest["seq"],
        "status": latest["status"],
        "event_count": len(events),
        "terminal": latest["terminal"],
        "notification": {
            "reason": notification.get("reason", "notification_invalid"),
            "tmux_accepted": notification.get("tmux_accepted", False),
        },
    }


def same_caller_route(expected: dict[str, Any], current: dict[str, Any]) -> bool:
    if expected.get("kind") != "tmux" or current.get("kind") != "tmux":
        return False
    return all(
        expected.get(field) == current.get(field)
        for field in ("socket_path", "server_pid", "pane_id", "pane_pid", "run_id")
    )


def command_list(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    client = TmuxClient(args.socket)
    panes = [public_pane(pane) for pane in client.list_panes()]
    return new_envelope("list", "listed", target={"kind": "pane-list", "items": panes})


def command_read(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    if args.lines <= 0:
        raise WAError("invalid_lines", "--lines must be a positive integer")
    client = TmuxClient(args.socket)
    initial = client.resolve(args.target)
    captured = client.capture(initial["pane_id"], args.lines)
    pane = client.pane(initial["pane_id"])
    if not identity_matches(identity_of(initial), pane):
        raise WAError(
            "target_identity_changed",
            "pane identity changed while its screen was being captured",
            stage="identity_changed",
            recovery=f"Run with-agents read {pane['pane_id']} again.",
            target=public_pane(pane),
            screen=screen_object(captured, args.lines),
        )
    mark_observed(runtime, pane)
    return new_envelope(
        "read",
        "observed",
        target=public_pane(pane),
        screen=screen_object(captured, args.lines),
    )


def command_create(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    client = TmuxClient(args.socket)
    cwd = validate_cwd(args.cwd)
    pane, path = create_owned_shell(
        runtime,
        client,
        name=args.name,
        cwd=cwd,
        session=args.session,
        split=args.split,
    )
    target = {
        **public_pane(pane),
        "launch": {"argv": [], "record_path": str(path), "preset": None},
    }
    try:
        captured = client.capture(pane["pane_id"], 40)
        mark_observed(runtime, pane)
    except WAError as exc:
        exc.stage = "create_state_unknown"
        exc.recovery = "The pane exists; resolve and read it before writing to it."
        exc.target = target
        raise
    except KeyboardInterrupt as exc:
        raise WAError(
            "interrupted",
            "pane creation was interrupted before its initial screen was observed",
            stage="create_state_unknown",
            recovery="The pane exists; resolve and read it before writing to it.",
            target=target,
        ) from exc
    return new_envelope(
        "create",
        "created",
        target=target,
        screen=screen_object(captured, 40),
    )


def resolve_launch_spec(
    args: argparse.Namespace, config: ConfigState
) -> tuple[list[str], str, str | None]:
    name_suffix = getattr(args, "name_suffix", None)
    has_name = args.name is not None
    has_name_suffix = name_suffix is not None
    has_preset = args.preset is not None
    if has_name and has_name_suffix:
        raise WAError(
            "pane_name_source_conflict",
            "do not combine --name with --name-suffix",
            stage="preflight",
        )
    if not has_preset and has_name_suffix:
        raise WAError(
            "name_suffix_requires_preset",
            "--name-suffix requires --preset",
            stage="preflight",
        )
    if has_preset:
        if args.argv:
            raise WAError(
                "launch_source_conflict", "do not combine --preset with argv after --"
            )
        preset, _ = load_preset(config, args.preset)
        argv = list(preset["argv"])
        if has_name:
            name = validate_pane_name(args.name)
        elif has_name_suffix:
            registry = load_agent_registry(config)
            agent_type = preset["agent_type"]
            definition = registry.get(agent_type)
            if definition is None:
                raise WAError(
                    "agent_prefix_not_configured",
                    f"preset agent type has no configured pane prefix: {agent_type}",
                    stage="preflight",
                    recovery="Add a complete Agent definition to config.json or use --name.",
                    details={"agent_type": agent_type},
                )
            suffix = validate_pane_name_suffix(name_suffix)
            name = validate_pane_name(f"{definition['pane_prefix']}-{suffix}")
        else:
            name = preset["pane_name"]
        return argv, name, args.preset
    argv = argv_from_remainder(args.argv)
    if not has_name:
        raise WAError("pane_name_required", "direct launch requires --name")
    return argv, validate_pane_name(args.name), None


def command_launch(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    client = TmuxClient(args.socket)
    argv, name, preset = resolve_launch_spec(args, config)
    cwd = validate_cwd(args.cwd)
    pane, screen, path = launch_in_new_pane(
        runtime,
        client,
        name=name,
        cwd=cwd,
        session=args.session,
        split=args.split,
        argv=argv,
        preset=preset,
    )
    target = {
        **public_pane(pane),
        "launch": {"argv": argv, "record_path": str(path), "preset": preset},
        "readiness": launch_readiness(runtime, pane, screen, client),
    }
    return new_envelope("launch", "launched", target=target, screen=screen)


def command_send(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    client = TmuxClient(args.socket)
    pane = client.resolve(args.target)
    pane, screen = send_core(
        runtime,
        client,
        pane,
        message=args.message,
        allow_foreign=args.allow_foreign,
    )
    target = {
        **public_pane(pane),
        "submission": {"tmux_accepted": True, "tui_acceptance": "unverified"},
    }
    return new_envelope("send", "submitted", target=target, screen=screen)


def command_key(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    keys = list(args.keys)
    if keys and keys[0] == "--":
        keys.pop(0)
    if not keys:
        raise WAError("keys_required", "key requires at least one tmux key name")
    client = TmuxClient(args.socket)
    pane = client.resolve(args.target)
    with pane_lock(runtime, pane):
        current = client.pane(pane["pane_id"])
        observation = require_writable_target(
            runtime, client, current, allow_foreign=args.allow_foreign
        )
        try:
            client.run(["send-keys", "-t", current["pane_id"], *keys], stage="key")
        except WAError as exc:
            if exc.code == "tmux_timeout":
                consume_observation_path(observation)
                exc.stage = "key_state_unknown"
                exc.recovery = (
                    "The key event may have reached the pane. Do not replay it; "
                    "resolve and read the target first."
                )
                exc.target = public_pane(current)
            raise
        except KeyboardInterrupt as exc:
            consume_observation_path(observation)
            raise WAError(
                "interrupted",
                "key delivery was interrupted and may have reached the pane",
                stage="key_state_unknown",
                recovery="Do not replay the key; resolve and read the target first.",
                target=public_pane(current),
            ) from exc
        consume_observation_path(observation)
        try:
            time.sleep(0.05)
            captured = client.capture(current["pane_id"], 80)
        except KeyboardInterrupt as exc:
            raise WAError(
                "interrupted",
                "the key was accepted before the observation was interrupted",
                stage="key_state_unknown",
                recovery="Do not replay the key; resolve and read the target first.",
                target=public_pane(current),
            ) from exc
        except WAError as exc:
            raise WAError(
                "key_state_unknown",
                "tmux accepted the key event but the resulting pane state cannot be captured",
                stage="key_state_unknown",
                recovery="Do not replay the key; resolve and read the target first.",
                target=public_pane(current),
            ) from exc
    return new_envelope(
        "key", "sent", target=public_pane(current), screen=screen_object(captured, 80)
    )


def command_wait(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    if (
        not math.isfinite(args.timeout)
        or not math.isfinite(args.interval)
        or args.timeout < 0
        or args.interval <= 0
        or args.lines <= 0
    ):
        raise WAError(
            "invalid_wait",
            "wait timeout must be nonnegative; interval and lines must be positive",
        )
    client = TmuxClient(args.socket)
    pane = client.resolve(args.target)
    initial_screen = client.capture(pane["pane_id"], args.lines)
    current = client.pane(pane["pane_id"])
    initial_identity = identity_of(pane)
    if not identity_matches(initial_identity, current):
        return new_envelope(
            "wait",
            "identity_changed",
            target=public_pane(current),
            screen=screen_object(initial_screen, args.lines),
        )
    pane = current
    initial_identity = identity_of(pane)
    deadline = time.monotonic() + args.timeout
    stage = "process_exit" if pane.get("dead") else "unchanged"
    captured = initial_screen
    while stage == "unchanged" and time.monotonic() < deadline:
        time.sleep(min(args.interval, max(0.0, deadline - time.monotonic())))
        try:
            current = client.pane(pane["pane_id"])
            captured = client.capture(pane["pane_id"], args.lines)
        except WAError as exc:
            if exc.code == "tmux_timeout":
                raise
            stage = "process_exit"
            break
        if not identity_matches(initial_identity, current):
            stage = "identity_changed"
            break
        if current.get("dead"):
            stage = "process_exit"
            break
        if captured != initial_screen:
            stage = "changed"
            break
    if stage != "identity_changed":
        try:
            latest = client.pane(pane["pane_id"])
        except WAError as exc:
            if exc.code == "tmux_timeout":
                raise
            stage = "process_exit"
        else:
            current = latest
            if not identity_matches(initial_identity, current):
                stage = "identity_changed"
            else:
                mark_observed(runtime, current)
    return new_envelope(
        "wait",
        stage,
        target=public_pane(current),
        screen=screen_object(captured, args.lines),
    )


def command_restart(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    client = TmuxClient(args.socket)
    pane = client.resolve(args.target)
    if args.preset:
        if args.argv:
            raise WAError(
                "launch_source_conflict", "do not combine --preset with argv after --"
            )
        preset_value, _ = load_preset(config, args.preset)
        argv = list(preset_value["argv"])
        preset_name = args.preset
    else:
        argv = argv_from_remainder(args.argv)
        preset_name = None
    restarted, screen, path, previous_screen = restart_pane(
        runtime,
        client,
        pane,
        argv=argv,
        preset=preset_name,
        force_foreign=args.force_foreign,
    )
    target = {
        **public_pane(restarted),
        "launch": {"argv": argv, "record_path": str(path), "preset": preset_name},
        "readiness": launch_readiness(runtime, restarted, screen, client),
        "previous_screen": previous_screen,
    }
    return new_envelope("restart", "restarted", target=target, screen=screen)


def command_close(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    if args.lines <= 0:
        raise WAError("invalid_lines", "--lines must be a positive integer")
    client = TmuxClient(args.socket)
    pane = client.resolve(args.target)
    with pane_lock(runtime, pane):
        current = client.pane(pane["pane_id"])
        observation = require_observed(runtime, current)
        ensure_not_self(client, current)
        if not current.get("owned") and not args.force_foreign:
            raise WAError(
                "foreign_close_denied",
                "close is limited to owned panes unless --force-foreign is explicit",
                target=public_pane(current),
            )
        captured = client.capture(current["pane_id"], args.lines)
        run_id = current.get("run_id")
        try:
            client.run(["kill-pane", "-t", current["pane_id"]], stage="close")
        except WAError as exc:
            if exc.code == "tmux_timeout":
                consume_observation_path(observation)
                exc.stage = "close_state_unknown"
                exc.recovery = (
                    "The pane may already be closed. Resolve or list the exact target "
                    "before attempting another lifecycle action."
                )
                exc.target = public_pane(current)
                exc.screen = screen_object(captured, args.lines)
            raise
        except KeyboardInterrupt as exc:
            consume_observation_path(observation)
            raise WAError(
                "interrupted",
                "close was interrupted while pane removal was uncertain",
                stage="close_state_unknown",
                recovery=(
                    "The pane may already be closed. Resolve or list the exact target "
                    "before another lifecycle action."
                ),
                target=public_pane(current),
                screen=screen_object(captured, args.lines),
            ) from exc
        consume_observation_path(observation)
        if run_id:
            with contextlib.suppress(FileNotFoundError):
                owned_record_path(runtime, run_id).unlink()
    return new_envelope(
        "close",
        "closed",
        target=public_pane(current),
        screen=screen_object(captured, args.lines),
    )


def command_request(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    task_message = validate_message(args.message)
    if args.reply_socket and not args.reply_to:
        raise WAError(
            "reply_route_invalid",
            "--reply-socket requires an explicit --reply-to target",
            stage="notify_preflight",
        )
    client = TmuxClient(args.socket)
    child = client.resolve(args.target)
    caller, _caller_client, _caller_pane = current_caller_route(
        client, reply_to=args.reply_to, reply_socket=args.reply_socket
    )
    if (
        caller.get("kind") == "tmux"
        and caller.get("server_pid") == child.get("server_pid")
        and caller.get("pane_id") == child.get("pane_id")
    ):
        raise WAError(
            "notify_prerequisite_missing",
            "caller and child panes must be different for asynchronous requests",
            stage="notify_preflight",
        )
    if args.reply_ttl is not None and (
        not math.isfinite(args.reply_ttl) or args.reply_ttl <= 0
    ):
        raise WAError("invalid_reply_ttl", "--reply-ttl must be positive and finite")
    notify_armed = args.notify == "pane" and caller.get("kind") == "tmux"

    identifier = request_id()
    directory = request_dir(runtime, identifier)
    with request_lock(runtime, directory):
        directory.mkdir(mode=0o700)
        ensure_private_dir(directory / "events")
        ensure_private_dir(directory / "notifications")
        ensure_private_dir(directory / "result")
        record = {
            "version": 2,
            "request_id": identifier,
            "created_at": iso_now(),
            "created_epoch": time.time(),
            "phase": "dispatching",
            "child": identity_of(child),
            "caller": caller,
            "notify_mode": args.notify,
            "notify_armed": notify_armed,
            "result_dir": str((directory / "result").resolve()),
            "limits": v2_request_limits(),
            "reply_ttl_seconds": args.reply_ttl,
        }
        request_path = directory / "request.json"
        try:
            atomic_write_json(request_path, record, exclusive=True)
        except KeyboardInterrupt as exc:
            if request_path.is_file():
                record["phase"] = "aborted"
                record["dispatch_finished_epoch"] = time.time()
                record["dispatch_stage"] = "interrupted_before_dispatch"
                atomic_write_json(request_path, record)
                raise WAError(
                    "interrupted",
                    "request creation was interrupted before task dispatch",
                    stage="aborted",
                    request={"request_id": identifier, "phase": "aborted"},
                ) from exc
            with contextlib.suppress(WAError):
                safe_remove_request_dir(runtime, directory)
            raise
    full_message = f"{task_message}  {protocol_suffix(identifier, runtime, caller)}"
    try:
        current, screen = send_core(
            runtime,
            client,
            child,
            message=full_message,
            allow_foreign=args.allow_foreign,
        )
    except WAError as exc:
        with request_lock(runtime, directory):
            record, directory = load_request(runtime, identifier)
            record["phase"] = (
                "dispatch_unknown"
                if exc.stage
                in ("text_written_not_submitted", "submitted_state_unknown")
                else "aborted"
            )
            record["dispatch_finished_epoch"] = time.time()
            record["dispatch_stage"] = exc.stage
            atomic_write_json(directory / "request.json", record)
        exc.request = {
            "request_id": identifier,
            "phase": record["phase"],
            "notify_mode": args.notify,
            "notify_armed": notify_armed,
        }
        raise
    try:
        with request_lock(runtime, directory):
            record, directory = load_request(runtime, identifier)
            record["phase"] = "active"
            record["child"] = identity_of(current)
            record["dispatched_at"] = iso_now()
            record["dispatched_epoch"] = time.time()
            atomic_write_json(directory / "request.json", record)
    except KeyboardInterrupt as exc:
        with contextlib.suppress(Exception, KeyboardInterrupt):
            with request_lock(runtime, directory):
                record, directory = load_request(runtime, identifier)
                record["phase"] = "dispatch_unknown"
                record["dispatch_finished_epoch"] = time.time()
                record["dispatch_stage"] = "interrupted_after_submit"
                atomic_write_json(directory / "request.json", record)
        raise WAError(
            "interrupted",
            "request state recording was interrupted after task submission",
            stage="submitted_state_unknown",
            recovery=(
                "Do not dispatch the task again. Keep the request ID and use inbox "
                "only at a natural recovery point."
            ),
            target=public_pane(current),
            request={
                "request_id": identifier,
                "phase": "dispatch_unknown",
                "notify_mode": args.notify,
                "notify_armed": notify_armed,
            },
            screen=screen,
        ) from exc
    request_output = {
        "request_id": identifier,
        "protocol_version": 2,
        "phase": "active",
        "notify_mode": args.notify,
        "notify_armed": notify_armed,
        "ticket_path": str(directory),
        "stop_polling": True,
    }
    return new_envelope(
        "request",
        "submitted",
        target={
            **public_pane(current),
            "submission": {"tmux_accepted": True, "tui_acceptance": "unverified"},
        },
        request=request_output,
        notification={
            "spooled": False,
            "injection_attempted": False,
            "tmux_accepted": False,
            "reason": (
                "armed"
                if notify_armed
                else "caller_unaddressable"
                if args.notify == "pane"
                else "spool_only"
            ),
        },
        screen=screen,
    )


def command_reply_v1_locked(
    args: argparse.Namespace,
    runtime: RuntimeState,
    config: ConfigState,
    record: dict[str, Any],
    directory: Path,
    message: str | None,
) -> dict[str, Any]:
    if args.status == "progress":
        raise WAError(
            "reply_ticket_invalid", "protocol-v1 tickets do not support progress"
        )
    if record.get("phase") == "aborted":
        raise WAError(
            "reply_ticket_invalid", "request dispatch was aborted before submission"
        )
    ttl = record.get("reply_ttl_seconds")
    ttl_origin = record.get(
        "dispatched_epoch",
        record.get("dispatch_finished_epoch", record["created_epoch"]),
    )
    if isinstance(ttl, (int, float)) and time.time() > float(ttl_origin) + float(ttl):
        raise WAError("reply_ticket_invalid", "reply ticket has expired")
    if (directory / "reply.json").exists():
        raise WAError(
            "already_replied",
            f"request already has a terminal reply: {args.request_id}",
            request={"request_id": args.request_id},
        )
    managed_result = (
        managed_copy(args.file, directory / "result") if args.file else None
    )
    reply = {
        "version": 1,
        "request_id": args.request_id,
        "created_at": iso_now(),
        "status": args.status,
        "message": message,
        "result": managed_result,
    }
    reply_path = directory / "reply.json"
    notification: dict[str, Any] | None = None
    try:
        atomic_write_json(reply_path, reply, exclusive=True)
        try:
            notification = notify_caller(runtime, config, record, reply)
        except Exception as exc:
            notification = notification_result(
                f"notification_internal_error:{type(exc).__name__}"
            )
        with contextlib.suppress(Exception):
            persist_notification(directory, notification)
    except KeyboardInterrupt:
        if not reply_path.is_file():
            raise
        if notification is None:
            notification = notification_result(
                "notification_interrupted_state_unknown", attempted=True
            )
        with contextlib.suppress(Exception, KeyboardInterrupt):
            persist_notification(directory, notification)
    assert notification is not None
    return new_envelope(
        "reply",
        "spooled",
        request={
            "request_id": args.request_id,
            "status": args.status,
            "message": message,
            "result": managed_result,
            "reply_path": str(reply_path.resolve()),
        },
        notification=notification,
    )


def command_reply(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    message = validate_reply_message(args.message)
    directory = request_dir(runtime, args.request_id)
    publication_interrupted = False
    with request_lock(runtime, directory):
        record, directory = load_request(runtime, args.request_id)
        if record["version"] == 1:
            return command_reply_v1_locked(
                args, runtime, config, record, directory, message
            )
        validate_v2_request_record(record, directory)
        if record.get("phase") == "aborted":
            raise WAError(
                "reply_ticket_invalid", "request dispatch was aborted before submission"
            )
        events = scan_v2_events(record, directory)
        if events and events[-1]["terminal"]:
            raise WAError(
                "reply_stream_terminated",
                "request already has a terminal outcome",
                request={
                    "request_id": args.request_id,
                    "protocol_version": 2,
                    "terminal_seq": events[-1]["seq"],
                },
            )
        ensure_v2_ticket_not_expired(record, events)
        terminal = EVENT_STATUS_TERMINAL[args.status]
        nonterminal_count = sum(not event["terminal"] for event in events)
        if not terminal and nonterminal_count >= NONTERMINAL_EVENT_LIMIT:
            raise WAError(
                "reply_event_limit",
                "request already has 64 nonterminal events",
                request={"request_id": args.request_id, "protocol_version": 2},
            )
        if (
            terminal
            and nonterminal_count >= NONTERMINAL_EVENT_LIMIT
            and args.file is not None
        ):
            raise WAError(
                "reply_event_limit",
                "the reserved terminal event is message-only after 64 nonterminal events",
                recovery="Send the terminal outcome without --file and reference an earlier managed result.",
                request={"request_id": args.request_id, "protocol_version": 2},
            )
        seq = len(events) + 1
        remove_orphan_event_result(directory, seq)
        managed_bytes = sum(
            event["result"]["bytes"] for event in events if event["result"] is not None
        )
        managed_result: dict[str, Any] | None = None
        event_path = directory / "events" / f"{seq:06d}.json"
        try:
            if args.file is not None:
                copied = managed_copy(
                    args.file,
                    directory / "result" / f"{seq:06d}",
                    request_remaining=REQUEST_RESULT_LIMIT - managed_bytes,
                )
                managed_result = {
                    "path": copied["path"],
                    "bytes": copied["bytes"],
                    "sha256": copied["sha256"],
                }
            created_epoch = time.time()
            ensure_v2_ticket_not_expired(record, events, now=created_epoch)
            event = {
                "version": 1,
                "request_id": args.request_id,
                "seq": seq,
                "created_at": iso_now(),
                "created_epoch": created_epoch,
                "status": args.status,
                "terminal": terminal,
                "message": message,
                "result": managed_result,
            }
            try:
                atomic_write_json(event_path, event, exclusive=True)
            except KeyboardInterrupt:
                if not event_path.is_file():
                    raise
                publication_interrupted = True
        except BaseException:
            if not event_path.is_file():
                remove_orphan_event_result(directory, seq)
            raise

    if publication_interrupted:
        notification = event_notification_result(
            args.request_id, seq, "notification_interrupted_before_attempt"
        )
    else:
        try:
            notification = notify_event_caller(runtime, config, record, event)
        except KeyboardInterrupt:
            notification = event_notification_result(
                args.request_id,
                seq,
                "notification_interrupted_state_unknown",
                text_attempted=True,
                text_tmux_accepted=None,
            )
        except Exception as exc:
            notification = event_notification_result(
                args.request_id,
                seq,
                f"notification_internal_error:{type(exc).__name__}",
            )
    with contextlib.suppress(Exception, KeyboardInterrupt):
        persist_event_notification(directory, notification)
    return new_envelope(
        "reply",
        "outcome_persisted",
        request={
            "request_id": args.request_id,
            "protocol_version": 2,
            "event": event,
            "status": args.status,
            "message": message,
            "result": managed_result,
            "event_path": str(event_path.resolve()),
        },
        notification=notification,
    )


def command_inbox(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    if args.request_id:
        directory = request_dir(runtime, args.request_id)
        with request_lock(runtime, directory):
            record, directory = load_request(runtime, args.request_id)
            if record["version"] == 1:
                return new_envelope(
                    "inbox",
                    "listed",
                    request={"items": [legacy_inbox_item(directory)], "count": 1},
                )
            events = v2_inbox_events(record, directory)
            return new_envelope(
                "inbox",
                "listed",
                request={
                    "request_id": args.request_id,
                    "protocol_version": 2,
                    "events": events,
                    "count": len(events),
                    "terminal": bool(events and events[-1]["terminal"]),
                },
            )
    pane_id = os.environ.get("TMUX_PANE")
    if not pane_id:
        raise WAError(
            "caller_unaddressable",
            "inbox without a request ID requires a tmux caller pane",
            recovery="Run with-agents inbox <request-id>.",
        )
    socket = os.environ.get("TMUX", "").split(",", 1)[0] or None
    caller_client = TmuxClient(socket)
    caller_pane = caller_client.pane(pane_id)
    current = {"kind": "tmux", **identity_of(caller_pane)}
    items: list[dict[str, Any]] = []
    for directory in list_request_dirs(runtime):
        with contextlib.suppress(WAError):
            with request_lock(runtime, directory):
                if not directory.is_dir():
                    continue
                record, directory = load_request(runtime, directory.name)
                if not same_caller_route(record.get("caller") or {}, current):
                    continue
                if record["version"] == 1:
                    if (directory / "reply.json").is_file():
                        items.append(legacy_inbox_item(directory))
                    continue
                events = scan_v2_events(record, directory)
                if events:
                    items.append(v2_inbox_summary(record, directory, events))
    items.sort(key=lambda item: str(item["request_id"]))
    return new_envelope(
        "inbox", "listed", request={"items": items, "count": len(items)}
    )


def command_preset_list(
    args: argparse.Namespace, _: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    directory = config.validate_existing_presets()
    items = [
        {"name": path.stem, "path": str(path)}
        for path in sorted(directory.glob("*.json"))
        if path.is_file()
        and not path.is_symlink()
        and PRESET_NAME_RE.fullmatch(path.stem)
    ]
    return new_envelope(
        "preset.list", "listed", target={"kind": "preset-list", "items": items}
    )


def command_preset_show(
    args: argparse.Namespace, _: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    value, path = load_preset(config, args.name)
    digest = hashlib.sha256(canonical_json_bytes(value)).hexdigest()
    return new_envelope(
        "preset.show",
        "shown",
        target={
            "kind": "preset",
            "name": args.name,
            "path": str(path),
            "digest": digest,
            **value,
        },
    )


def mutate_preset(
    args: argparse.Namespace,
    runtime: RuntimeState,
    config: ConfigState,
    *,
    update: bool,
) -> dict[str, Any]:
    registry = load_agent_registry(config)
    client = TmuxClient(args.socket)
    value = preset_from_pane(runtime, client, args.source, registry)
    path = preset_path(config, args.name)
    exists = path.exists()
    if path.is_symlink():
        raise WAError("unsafe_state_path", f"preset path is a symlink: {path}")
    if update:
        if not args.replace:
            raise WAError("replace_required", "preset update requires --replace")
        if not exists:
            raise WAError("preset_not_found", f"preset does not exist: {args.name}")
    elif exists:
        raise WAError("preset_exists", f"preset already exists: {args.name}")
    data = canonical_json_bytes(value)
    digest = hashlib.sha256(data).hexdigest()
    if not args.dry_run:
        config.ensure_presets()
        atomic_write_json(path, value, exclusive=not update)
    stage = "dry_run" if args.dry_run else ("updated" if update else "saved")
    return new_envelope(
        "preset.update" if update else "preset.save",
        stage,
        target={
            "kind": "preset",
            "name": args.name,
            "path": str(path),
            "digest": digest,
            "source": args.source,
            "dry_run": args.dry_run,
            **value,
        },
    )


def command_preset_save(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    return mutate_preset(args, runtime, config, update=False)


def command_preset_update(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    return mutate_preset(args, runtime, config, update=True)


def command_preset_remove(
    args: argparse.Namespace, _: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    path = preset_path(config, args.name)
    if not path.is_file() or path.is_symlink():
        raise WAError("preset_not_found", f"preset does not exist: {args.name}")
    value = safe_read_json(path)
    digest = hashlib.sha256(canonical_json_bytes(value)).hexdigest()
    path.unlink()
    return new_envelope(
        "preset.remove",
        "removed",
        target={
            "kind": "preset",
            "name": args.name,
            "path": str(path),
            "digest": digest,
        },
    )


def numeric_request_epoch(record: dict[str, Any], value: Any, *, label: str) -> float:
    if (
        isinstance(value, bool)
        or not isinstance(value, (int, float))
        or not math.isfinite(float(value))
    ):
        if record.get("version") == 2:
            raise invalid_reply_stream(
                str(record.get("request_id")), f"{label} is invalid"
            )
        return time.time()
    return float(value)


def request_gc_facts(
    record: dict[str, Any], directory: Path
) -> dict[str, float | bool]:
    if record["version"] == 1:
        terminal = (directory / "reply.json").is_file() or record.get(
            "phase"
        ) == "aborted"
        created_epoch = numeric_request_epoch(
            record, record.get("created_epoch"), label="created_epoch"
        )
        return {
            "terminal": terminal,
            "retention_epoch": directory.stat().st_mtime,
            "activity_epoch": created_epoch,
        }

    events = scan_v2_events(record, directory)
    if record.get("phase") == "aborted":
        if events:
            raise invalid_reply_stream(directory.name, "aborted request has events")
        epoch = numeric_request_epoch(
            record,
            record.get("dispatch_finished_epoch", record.get("created_epoch")),
            label="aborted retention epoch",
        )
        return {"terminal": True, "retention_epoch": epoch, "activity_epoch": epoch}
    if events:
        epoch = float(events[-1]["created_epoch"])
        return {
            "terminal": bool(events[-1]["terminal"]),
            "retention_epoch": epoch,
            "activity_epoch": epoch,
        }
    epoch = numeric_request_epoch(
        record,
        record.get(
            "dispatched_epoch",
            record.get("dispatch_finished_epoch", record.get("created_epoch")),
        ),
        label="request activity epoch",
    )
    return {"terminal": False, "retention_epoch": epoch, "activity_epoch": epoch}


def command_gc(
    args: argparse.Namespace, runtime: RuntimeState, _: ConfigState
) -> dict[str, Any]:
    if args.delete_stale and args.stale is None:
        raise WAError("stale_selector_required", "--delete-stale requires --stale")
    if args.stale is not None and (not math.isfinite(args.stale) or args.stale < 0):
        raise WAError(
            "invalid_stale_age", "--stale days must be nonnegative and finite"
        )
    removed: list[str] = []
    stale: list[str] = []
    now = time.time()
    for directory in list_request_dirs(runtime):
        with request_lock(runtime, directory):
            if not directory.is_dir():
                continue
            record, directory = load_request(runtime, directory.name)
            facts = request_gc_facts(record, directory)
            if args.stale is None:
                if facts["terminal"]:
                    safe_remove_request_dir(runtime, directory)
                    removed.append(directory.name)
                continue
            age_days = (now - float(facts["activity_epoch"])) / 86400
            if not facts["terminal"] and age_days >= args.stale:
                stale.append(directory.name)
                if args.delete_stale:
                    safe_remove_request_dir(runtime, directory)
                    removed.append(directory.name)
    return new_envelope(
        "gc",
        "completed",
        request={"removed": removed, "stale": stale, "delete_stale": args.delete_stale},
    )


def tmux_version_tuple(text: str) -> tuple[int, int] | None:
    match = re.search(r"(\d+)\.(\d+)", text)
    return (int(match.group(1)), int(match.group(2))) if match else None


def notification_adapter_diagnostics() -> dict[str, Any]:
    adapters: dict[str, Any] = {}
    for adapter_id in ("codex", "pi"):
        adapter = ADAPTERS[adapter_id]
        forward_tested = adapter["forward_tested_major_minor"]
        executable = shutil.which(adapter_id)
        diagnostic: dict[str, Any] = {
            "executable": executable,
            "installed": executable is not None,
            "forward_tested_major_minor": list(forward_tested),
            "version_gate": False,
        }
        if executable is not None:
            try:
                completed = subprocess.run(
                    [executable, "--version"],
                    text=True,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    timeout=3,
                    check=False,
                )
            except (OSError, subprocess.TimeoutExpired) as exc:
                diagnostic["version_error"] = str(exc)
            else:
                output = completed.stdout.strip()
                parsed = parse_version(output)
                diagnostic.update(
                    {
                        "version_output": output,
                        "version_returncode": completed.returncode,
                        "version": (list(parsed) if parsed is not None else None),
                        "matches_forward_tested": (
                            parsed is not None and parsed[:2] == tuple(forward_tested)
                        ),
                    }
                )
        adapters[adapter_id] = diagnostic
    return {
        "ok": True,
        "callback_version_gate": False,
        "generic_submit_key": "Enter",
        "adapters": adapters,
    }


def command_doctor(
    args: argparse.Namespace, runtime: RuntimeState, config: ConfigState
) -> dict[str, Any]:
    checks: dict[str, Any] = {
        "with_agents_version": VERSION,
        "python": {
            "version": ".".join(str(part) for part in sys.version_info[:3]),
            "minimum": ".".join(str(part) for part in MIN_PYTHON),
            "ok": sys.version_info[:2] >= MIN_PYTHON,
        },
        "runtime": {
            "path": str(runtime.root),
            "source": runtime.source,
            "state_fallback": runtime.fallback,
            "ok": runtime.root.is_dir(),
        },
        "fcntl": {"ok": True},
    }
    checks["notification"] = notification_adapter_diagnostics()
    agent_config_check: dict[str, Any] = {
        "path": str(config.agent_config),
        "present": config.agent_config.exists() or config.agent_config.is_symlink(),
        "ok": False,
    }
    checks["agent_config"] = agent_config_check
    try:
        registry = load_agent_registry(config)
    except WAError as exc:
        agent_config_check.update({"error": {"code": exc.code, "message": exc.message}})
    else:
        agent_config_check.update(
            {
                "ok": True,
                "agents": sorted(registry),
                "source": "config" if agent_config_check["present"] else "builtins",
            }
        )
    tmux_executable = shutil.which("tmux")
    tmux_check: dict[str, Any] = {"path": tmux_executable, "ok": False}
    checks["tmux"] = tmux_check
    if tmux_executable:
        try:
            version_output = subprocess.run(
                [tmux_executable, "-V"],
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=3,
                check=False,
            ).stdout.strip()
        except (OSError, subprocess.TimeoutExpired) as exc:
            tmux_check.update(
                {
                    "minimum": f"{MIN_TMUX[0]}.{MIN_TMUX[1]}",
                    "version_error": str(exc),
                }
            )
        else:
            parsed = tmux_version_tuple(version_output)
            tmux_check.update(
                {
                    "version": version_output,
                    "minimum": f"{MIN_TMUX[0]}.{MIN_TMUX[1]}",
                    "ok": parsed is not None and parsed >= MIN_TMUX,
                }
            )
            client = TmuxClient(args.socket)
            try:
                tmux_check["server"] = client.server()
                tmux_check["server_running"] = True
                tmux_check["panes"] = len(client.list_panes())
                tmux_check["extended_keys"] = client.run(
                    ["show-options", "-s", "-v", "extended-keys"], check=False
                ).stdout.strip()
                tmux_check["extended_keys_format"] = client.run(
                    ["show-options", "-s", "-v", "extended-keys-format"], check=False
                ).stdout.strip()
            except WAError as exc:
                tmux_check["server_running"] = False
                tmux_check["server_error"] = exc.message
    ok = all(
        bool(check.get("ok")) for check in checks.values() if isinstance(check, dict)
    )
    return new_envelope(
        "doctor",
        "ok" if ok else "issues",
        ok=ok,
        target={"kind": "doctor", "checks": checks},
        error=None
        if ok
        else {"code": "doctor_issues", "message": "one or more prerequisites failed"},
        recovery=None
        if ok
        else "Fix the reported prerequisite or use tmux recovery guidance.",
    )


def command_version(
    _: argparse.Namespace, __: RuntimeState, ___: ConfigState
) -> dict[str, Any]:
    return new_envelope(
        "version", "shown", target={"kind": "version", "version": VERSION}
    )


def common_parser() -> WAArgumentParser:
    parser = WAArgumentParser(add_help=False)
    parser.add_argument("--json", action="store_true", default=argparse.SUPPRESS)
    parser.add_argument(
        "--socket", default=argparse.SUPPRESS, help="exact tmux socket path"
    )
    parser.add_argument(
        "--runtime-dir", default=argparse.SUPPRESS, help=argparse.SUPPRESS
    )
    parser.add_argument(
        "--config-dir", default=argparse.SUPPRESS, help=argparse.SUPPRESS
    )
    parser.add_argument(
        "--caller-id",
        default=argparse.SUPPRESS,
        help="stable identity for concurrent callers outside tmux",
    )
    return parser


def build_parser() -> WAArgumentParser:
    common = common_parser()
    parser = WAArgumentParser(
        prog="with-agents",
        description="Perform low-freedom atomic events against Agent CLIs in tmux.",
        parents=[common],
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    def command(name: str, help_text: str) -> WAArgumentParser:
        return subparsers.add_parser(name, help=help_text, parents=[common])

    command("list", "list panes").set_defaults(handler=command_list)

    read = command("read", "capture a pane and establish an observation credential")
    read.add_argument("target")
    read.add_argument("--lines", type=int, default=80)
    read.set_defaults(handler=command_read)

    create = command("create", "create an owned shell pane")
    create.add_argument("--name", required=True)
    create.add_argument("--cwd")
    create.add_argument("--session")
    create.add_argument("--split")
    create.set_defaults(handler=command_create)

    launch = command("launch", "create an owned pane and launch an exact argv")
    launch.add_argument("--name")
    launch.add_argument("--cwd")
    launch.add_argument("--session")
    launch.add_argument("--split")
    launch.add_argument("--preset")
    launch.add_argument("--name-suffix")
    launch.add_argument("argv", nargs=argparse.REMAINDER)
    launch.set_defaults(handler=command_launch)

    send = command("send", "submit one complete message")
    send.add_argument("target")
    send.add_argument("--allow-foreign", action="store_true")
    send.add_argument("message")
    send.set_defaults(handler=command_send)

    key = command("key", "send one or more explicit tmux key events")
    key.add_argument("target")
    key.add_argument("--allow-foreign", action="store_true")
    key.add_argument("keys", nargs=argparse.REMAINDER)
    key.set_defaults(handler=command_key)

    wait = command("wait", "wait for one screen or process change")
    wait.add_argument("target")
    wait.add_argument("--timeout", type=float, default=10.0)
    wait.add_argument("--interval", type=float, default=0.25)
    wait.add_argument("--lines", type=int, default=80)
    wait.set_defaults(handler=command_wait)

    restart = command("restart", "restart an owned pane with a new exact argv")
    restart.add_argument("target")
    restart.add_argument("--preset")
    restart.add_argument("--force-foreign", action="store_true")
    restart.add_argument("argv", nargs=argparse.REMAINDER)
    restart.set_defaults(handler=command_restart)

    close = command("close", "capture and close an owned pane")
    close.add_argument("target")
    close.add_argument("--lines", type=int, default=120)
    close.add_argument("--force-foreign", action="store_true")
    close.set_defaults(handler=command_close)

    request = command("request", "submit a task with an asynchronous outcome stream")
    request.add_argument("target")
    request.add_argument("--allow-foreign", action="store_true")
    request.add_argument("--notify", choices=("spool", "pane"), default="spool")
    request.add_argument("--reply-to")
    request.add_argument("--reply-socket")
    request.add_argument("--reply-ttl", type=float)
    request.add_argument("message")
    request.set_defaults(handler=command_request)

    reply = command("reply", "append one outcome event and optionally ring the caller")
    reply.add_argument("request_id")
    reply.add_argument(
        "--status",
        required=True,
        choices=("progress", "question", "done", "blocked", "failed"),
    )
    reply.add_argument("--message")
    reply.add_argument("--file")
    reply.set_defaults(handler=command_reply)

    inbox = command("inbox", "list recoverable replies for a caller or request")
    inbox.add_argument("request_id", nargs="?")
    inbox.set_defaults(handler=command_inbox)

    preset = command("preset", "manage private launch presets")
    preset_actions = preset.add_subparsers(dest="preset_command", required=True)

    preset_list = preset_actions.add_parser("list", parents=[common])
    preset_list.set_defaults(handler=command_preset_list)
    preset_show = preset_actions.add_parser("show", parents=[common])
    preset_show.add_argument("name")
    preset_show.set_defaults(handler=command_preset_show)
    for action_name, handler in (
        ("save", command_preset_save),
        ("update", command_preset_update),
    ):
        action = preset_actions.add_parser(action_name, parents=[common])
        action.add_argument("name")
        action.add_argument("--from", dest="source", required=True)
        action.add_argument("--dry-run", action="store_true")
        if action_name == "update":
            action.add_argument("--replace", action="store_true")
        action.set_defaults(handler=handler)
    preset_remove = preset_actions.add_parser("remove", parents=[common])
    preset_remove.add_argument("name")
    preset_remove.set_defaults(handler=command_preset_remove)

    gc = command("gc", "clean terminal requests or inspect explicit stale requests")
    gc.add_argument("--stale", type=float, nargs="?", const=30.0)
    gc.add_argument("--delete-stale", action="store_true")
    gc.set_defaults(handler=command_gc)

    command("doctor", "diagnose runtime and tmux prerequisites").set_defaults(
        handler=command_doctor
    )
    command("version", "show controller version").set_defaults(handler=command_version)
    return parser


def wants_json(argv: list[str]) -> bool:
    try:
        boundary = argv.index("--")
    except ValueError:
        boundary = len(argv)
    return "--json" in argv[:boundary]


def main(argv: list[str] | None = None) -> int:
    values = list(sys.argv[1:] if argv is None else argv)
    if values and values[0] == "_exec":
        if len(values) != 2:
            sys.stderr.write(
                "[with-agents exec error] invalid internal exec invocation\n"
            )
            return 126
        return internal_exec(values[1])
    as_json = wants_json(values)
    event = values[0] if values and not values[0].startswith("-") else "with-agents"
    try:
        parser = build_parser()
        args = parser.parse_args(values)
        for option, default in (
            ("socket", None),
            ("runtime_dir", None),
            ("config_dir", None),
            ("json", False),
            ("caller_id", None),
        ):
            if not hasattr(args, option):
                setattr(args, option, default)
        if args.caller_id:
            os.environ["WITH_AGENTS_CALLER_ID"] = args.caller_id
        as_json = bool(getattr(args, "json", as_json))
        event = getattr(args, "command", event)
        if (
            args.command not in ("doctor", "version")
            and sys.version_info[:2] < MIN_PYTHON
        ):
            raise WAError(
                "python_too_old",
                f"Python {MIN_PYTHON[0]}.{MIN_PYTHON[1]} or newer is required",
            )
        if args.command == "version":
            envelope = args.handler(args, None, None)
        else:
            runtime = RuntimeState(getattr(args, "runtime_dir", None))
            config = ConfigState(getattr(args, "config_dir", None))
            envelope = args.handler(args, runtime, config)
    except WAError as exc:
        envelope = error_envelope(event, exc)
    except KeyboardInterrupt:
        envelope = error_envelope(
            event,
            WAError(
                "interrupted",
                "operation interrupted by the caller",
                stage="interrupted",
            ),
        )
    except Exception as exc:
        envelope = error_envelope(
            event,
            WAError(
                "internal_error",
                f"unexpected controller error: {exc}",
                recovery="Run with-agents doctor and report the JSON error without retrying a partial send.",
            ),
        )
    emit(envelope, as_json)
    return 0 if envelope["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
